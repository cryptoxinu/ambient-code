#!/usr/bin/env python3
"""ambient — CLI for the Ambient (ambient.xyz) OpenAI-compatible inference API.

Commands:
  setup                First-run: paste + verify your API key, store securely
                       (--force rotates, --remove offboards)
  models               List models — READY first, price/context, defaults marked
  use       [model]    Pick the sticky default model (interactive menu if no arg)
  curate    [verb]     Choose which models the menus surface (hide/show/only/note)
  ask       [prompt]   One-shot completion (prompt arg, stdin, or both via '-':
                       cat doc.txt | ambient ask "summarize" -)
  audit     [paths…]   Second-opinion code audit (files as args, diff via stdin)
  map       "<p>" [f…] Bulk lane: run ONE prompt independently over MANY items
                       (files, or stdin lines / --jsonl objects); one result
                       streamed per item, one up-front batch cost gate,
                       cache-resumable (re-runs re-bill only missing items)
  code      [task]     Single-file code generation on the code model
  build     [task]     Plan + generate a SET of files (manifest-first; writes
                       only with --apply, inside --dir; never executes)
  agent     [args…]    Interactive agentic terminal on Ambient (opencode TUI)
  doctor               Diagnose: bad key vs out-of-funds vs busy model vs your
                       network vs Ambient itself — names the actual culprit
  usage     [--days]   Local token/cost summary
  mode      [on|off]   Delegate mode toggle (no arg = status). When ON, Claude
                       routes code writing through Ambient for the session
  link                 Put a stable `ambient` launcher on your PATH
  cache     [action]   Inspect / clear the local chunk cache
  trust-url [url]      Explicitly trust a non-Ambient endpoint (self-hosted)
  version              Print version
  codex     [args…]    Blocked upstream for now — explains why; use `agent`

No input is refused for size: anything past the model's single-shot budget is
auto map-reduced (parallel chunk calls + merge). Spend is gated: estimates print
up front, a $5 default ceiling (AMBIENT_MAX_SPEND) blocks surprises, and jobs
above $0.50 confirm on a TTY (--yes skips; --allow-cost overrides the ceiling).

Exit codes: 0 ok · 1 diagnosed error · 2 PARTIAL result · 3 no key configured
            64 usage error · 130 interrupted

Credentials: OS keychain (preferred) or ~/.config/ambient/env (chmod 600).
Model resolution: -m flag > AMBIENT_MODEL / AMBIENT_CODE_MODEL env var
                  > saved default (ambient use) > built-in default.
"""

import argparse
import ast
import collections
import concurrent.futures
import contextlib
import difflib
import fnmatch
import hashlib
import http.client
import json
import os
import random
import re
import select
import shutil
import stat
import subprocess
import sys
import tempfile
import threading
import time
import urllib.error
import urllib.parse
import urllib.request

try:
    import fcntl  # POSIX-only; Windows uses a portable lock-file fallback (B1)
except ImportError:
    fcntl = None

__version__ = "2.0.0"  # kept in sync with plugin.json + pyproject.toml (test- and CI-asserted)
CONFIG_PATH = os.path.expanduser("~/.config/ambient/env")
USAGE_PATH = os.path.expanduser("~/.config/ambient/usage.jsonl")
KEYCHAIN_SERVICE = "ambient.xyz"
KEYCHAIN_ACCOUNT = "api-key"
DEFAULT_API_URL = "https://api.ambient.xyz"
KEY_CONSOLE_URL = "https://app.ambient.xyz"   # where users create/manage API keys
SUPPORT_LINE = ("If this keeps happening, contact Ambient support with the "
                "[category] code shown above — support/community links at "
                "https://ambient.xyz")
# Exit-code contract (documented in README + --help):
#   0 clean · 1 diagnosed error · 2 PARTIAL result · 3 unconfigured (no key)
#   64 usage error · 130 interrupted
EXIT_PARTIAL = 2
EXIT_UNCONFIGURED = 3
EXIT_USAGE = 64
# Terminal-injection guard: model output comes from anonymous miners on a
# decentralized network. Strip ANSI/OSC/DCS escapes and stray C0 controls
# (keeping \n and \t) before anything model-derived reaches a terminal —
# otherwise a poisoned reply can rewrite verdicts, spoof the PARTIAL banner,
# or fire OSC-52 clipboard writes. AMBIENT_NO_SANITIZE=1 = debug escape hatch.
ANSI_RE = re.compile(
    r"\x1b(?:\[[0-?]*[ -/]*[@-~]"          # CSI
    r"|\][^\x07\x1b]*(?:\x07|\x1b\\)?"      # OSC (incl. unterminated)
    r"|[PX^_][^\x1b]*(?:\x1b\\)?"           # DCS/SOS/PM/APC
    r"|[@-Z\\-_=><~])"                      # two-char sequences
)
CTRL_RE = re.compile(r"[\x00-\x08\x0b\x0c\x0e-\x1f\x7f]")
# Kimi is the default for BOTH lanes: the live probe (docs/LIVE_PROBE_REPORT.md)
# measured it ~2-3x faster and catching planted bugs 3/3 where GLM-5.2 caught
# 1/3 — GLM is still being built up network-side and stays fully selectable
# (`ambient use z-ai/glm-5.2 --chat`).
DEFAULT_MODEL = "moonshotai/kimi-k2.7-code"
DEFAULT_CODE_MODEL = "moonshotai/kimi-k2.7-code"
DEFAULT_TIMEOUT_S = 300
DEFAULT_MAX_TOKENS = 16384
# A reasoning model (Kimi/GLM/etc.) spends tokens THINKING before it answers, so
# an output budget below this floor can't produce a usable result — the CLI
# raises it rather than let a self-defeating value run silently.
MIN_OUTPUT_TOKENS = 2048
HEARTBEAT_S = 20  # stderr liveness ping while a long generation streams
# Reasoning models sometimes spend the ENTIRE token budget thinking and emit no
# final answer. Instead of failing with "raise --max-tokens", the CLI escalates
# the budget itself, once, up to this ceiling (~$0.25 of output on the priciest
# model — bounded, visible on stderr).
MAX_AUTO_BUDGET_TOKENS = 65536
# Completions STREAM: liveness is judged by data flow, not total duration. A
# healthy generation can run for ages; silence beyond the per-op timeout
# (args.timeout, default 300s) means a hung worker and is caught immediately.
HARD_WALL_S = 5400  # absolute ceiling on one streamed generation
# A wedged worker can keep the socket alive (empty deltas / keep-alives) while
# emitting NO new content or reasoning — that fools a pure silence timeout. If
# nothing useful grows for this long, treat it as a stall.
NOPROGRESS_S = 150
# No hard "no": inputs above a model's single-shot budget are automatically
# map-reduced — split on file boundaries, processed as parallel chunk calls,
# then merged by budget-aware synthesis. The single-shot/chunk budgets are
# computed PER MODEL from its real context_length (see model_profile); the value
# below is only the pack_chunks default when no per-model budget is passed.
CHUNK_CHARS = 300_000         # default per-chunk budget (overridden per model)
# --- Per-model tuning (see model_profile) -----------------------------------
# THE crux: `max_tokens` caps reasoning + answer COMBINED. A reasoning model
# spends tokens thinking before it answers, so for reasoning-heavy work the
# output budget must cover (reasoning over the input) PLUS (the answer), and the
# input chunk must stay small enough that reasoning fits. These constants drive
# that per-model math. No Ambient model exposes a reasoning-effort knob (verified
# against supported_sampling_parameters), so output-budget + chunk-size are the
# only levers.
CHARS_PER_TOKEN = 3.2                  # aligns with estimate_cost/cost_gate
REASONING_EXPANSION = 1.5              # reasoning chars produced per input char on
                                       # dense code (empirical ~1.43, rounded up)
ANSWER_TOKENS_RESERVE = 6000           # tokens kept for the answer after reasoning
OUTPUT_SAFETY = 1.15                   # headroom for expansion variance
REASONING_SINGLE_SHOT_CHARS = 32_000   # minimum single-shot input for a reasoner
# A1: single-shot is sized to the model's REAL window (not a flat 32k), so a
# whole-repo audit stays in ONE high-quality pass on big models (GLM/Kimi have
# 200k+ context) instead of being chopped 6-8x. Capped by a cost knob so a very
# large one-pass call is deliberate; override with AMBIENT_SINGLE_SHOT_MAX_CHARS.
SINGLE_SHOT_MAX_CHARS_DEFAULT = 120_000
REASONING_CHUNK_FACTOR = 0.85          # chunk = single * this (map-prompt overhead)
MIN_REASONING_CHUNK = 8_000            # never chunk a reasoner below this
NONREASONING_OUTPUT_BUDGET = 16_384    # non-reasoners spend 0 tokens thinking
NONREASONING_CONTEXT_MARGIN = 0.85     # leave 15% of context for the system prompt
FALLBACK_CONTEXT = 200_000             # offline/unknown-model context assumption
# Conservative offline output cap: every real Ambient model allows >= 16384, so
# assuming this when the catalog is unreachable keeps an auto budget from ever
# exceeding a strict model's real cap (escalation grows it if the model has more).
FALLBACK_MAX_OUTPUT = 16_384
ABS_MAX_CHARS = 20_000_000    # sanity ceiling (~$8-25 of input) — cost guard, not a limit
MAX_PARALLEL_CHUNKS = 3       # concurrent chunk calls (be kind to miners)

AUDIT_SYSTEM_PROMPT = """You are an adversarial senior code reviewer giving a second opinion.
Audit the provided code/diff for real defects: correctness bugs, security vulnerabilities,
race conditions, data loss, error-handling gaps, and broken edge cases.

SEVERITY RUBRIC (calibrate strictly):
- CRITICAL: exploitable, causes data loss, or crashes on NORMAL use.
- HIGH: produces a wrong result on realistic input.
- MEDIUM: fails only on an edge case / uncommon input.
- LOW: latent risk, no current trigger.
Report a "confidence": HIGH if you can name the exact triggering input; else LOW —
do NOT drop a low-confidence finding, and do NOT overstate it.

LINE NUMBERS: source files are shown with absolute line-number gutters like "  42| code".
Cite THOSE numbers as file:line. For a diff, cite the new-file line from the nearest @@ hunk.

FORMAT — for each finding: SEVERITY, confidence, file:line, the defect, a concrete failure
scenario (specific inputs/state -> wrong outcome), and a suggested fix. Rank most-severe
first. Report ONLY genuine defects — never style nits; if the code is sound, say so plainly.
Never handwave. End with a one-line verdict: SHIP / FIX FIRST / NEEDS WORK.

EXAMPLE (illustrates FORMAT only — not a bug to look for):
  HIGH (confidence: HIGH) — pay.py:88 — off-by-one lets a zero-balance transfer create money.
  Scenario: bal=100, transfer(100): `if bal > amt` skips the debit but still credits the
  dest → funds created. Fix: use `>=` and validate amt > 0.
A style preference (e.g. "rename x to count") is NOT a finding — omit it."""


def read_config_file():
    conf = {}
    try:
        # Self-heal drifted permissions before reading — but only on a regular,
        # owner-owned, non-symlink file (never chmod something unexpected).
        st = os.lstat(CONFIG_PATH)
        if not stat.S_ISREG(st.st_mode):
            print(
                f"ambient: {CONFIG_PATH} is not a regular file — ignoring it",
                file=sys.stderr,
            )
            return conf
        # Ownership check is POSIX-only (Windows has no getuid / st_uid).
        if hasattr(os, "getuid") and st.st_uid != os.getuid():
            print(
                f"ambient: {CONFIG_PATH} is not owned by you — ignoring it",
                file=sys.stderr,
            )
            return conf
        mode_bits = st.st_mode & 0o777
        if mode_bits != 0o600:
            os.chmod(CONFIG_PATH, 0o600)
            print(
                f"ambient: tightened {CONFIG_PATH} permissions "
                f"({oct(mode_bits)[2:]} -> 600)",
                file=sys.stderr,
            )
        with open(CONFIG_PATH, encoding="utf-8") as fh:
            for line in fh:
                line = line.strip()
                if line and not line.startswith("#") and "=" in line:
                    key, _, val = line.partition("=")
                    conf[key.strip()] = val.strip()
    except FileNotFoundError:
        pass
    except UnicodeDecodeError:
        # Disk corruption / wrong-encoding edit must degrade, not crash to the
        # [internal] shield (QA sweep: verified repro on non-UTF8 bytes).
        print(
            f"ambient: {CONFIG_PATH} is corrupt (not valid UTF-8) — ignoring it. "
            "Re-run: ambient setup",
            file=sys.stderr,
        )
        return {}
    except OSError as err:
        print(f"ambient: cannot read {CONFIG_PATH}: {err}", file=sys.stderr)
    return conf


def secret_backend():
    """Which OS secret store is usable (C1): macOS Keychain, Linux libsecret
    (secret-tool), or None → the 0600 env-file fallback. Never fails closed like
    the old Mac-only path that silently dropped everyone else to plaintext."""
    if sys.platform == "darwin" and shutil.which("security"):
        return "keychain"
    if sys.platform.startswith("linux") and shutil.which("secret-tool"):
        return "secret-tool"
    return None


def keychain_available():
    return secret_backend() is not None


def keychain_read():
    """Fetch the key from the OS secret store. None when absent/unavailable."""
    b = secret_backend()
    try:
        if b == "keychain":
            proc = subprocess.run(
                ["security", "find-generic-password", "-s", KEYCHAIN_SERVICE,
                 "-a", KEYCHAIN_ACCOUNT, "-w"],
                capture_output=True, text=True, timeout=10)
        elif b == "secret-tool":
            proc = subprocess.run(
                ["secret-tool", "lookup", "service", KEYCHAIN_SERVICE,
                 "account", KEYCHAIN_ACCOUNT],
                capture_output=True, text=True, timeout=10)
        else:
            return None
    except (OSError, subprocess.TimeoutExpired):
        return None
    key = proc.stdout.strip()
    return key if proc.returncode == 0 and key else None


def keychain_write(key):
    """Store the key in the OS secret store, passing the secret over STDIN so it
    never appears in any process's argv. Returns True on success."""
    b = secret_backend()
    if "\n" in key:  # a newline would break the security -i command stream
        return False
    try:
        if b == "keychain":
            if '"' in key or "\\" in key:
                return False
            cmd = (f'add-generic-password -U -s "{KEYCHAIN_SERVICE}" '
                   f'-a "{KEYCHAIN_ACCOUNT}" -l "Ambient API key" -w "{key}"\n')
            proc = subprocess.run(["security", "-i"], input=cmd,
                                  capture_output=True, text=True, timeout=15)
        elif b == "secret-tool":
            proc = subprocess.run(
                ["secret-tool", "store", "--label=Ambient API key",
                 "service", KEYCHAIN_SERVICE, "account", KEYCHAIN_ACCOUNT],
                input=key, capture_output=True, text=True, timeout=15)
        else:
            return False
    except (OSError, subprocess.TimeoutExpired):
        return False
    return proc.returncode == 0


def keychain_delete():
    """Remove the stored key from the OS secret store. Returns True when the
    key is gone (deleted or was absent) and False on a real failure — a locked
    Keychain must not let `setup --remove` claim success while the key still
    resolves (Codex W2/3 MED)."""
    b = secret_backend()
    try:
        if b == "keychain":
            proc = subprocess.run(
                ["security", "delete-generic-password", "-s", KEYCHAIN_SERVICE,
                 "-a", KEYCHAIN_ACCOUNT], capture_output=True, text=True, timeout=10)
            # 0 = deleted; 44 (errSecItemNotFound) = nothing stored — both fine.
            return proc.returncode in (0, 44)
        if b == "secret-tool":
            proc = subprocess.run(
                ["secret-tool", "clear", "service", KEYCHAIN_SERVICE,
                 "account", KEYCHAIN_ACCOUNT], capture_output=True, text=True, timeout=10)
            return proc.returncode == 0
        return True  # no OS store in play — nothing to delete
    except (OSError, subprocess.TimeoutExpired):
        return False


def resolve_key_and_backend(conf):
    """Key lookup order: env var > macOS Keychain > config file.
    An explicit AMBIENT_KEY_BACKEND=file skips the Keychain so `setup --file`
    can't be shadowed by a stale Keychain entry."""
    if os.environ.get("AMBIENT_API_KEY"):
        return os.environ["AMBIENT_API_KEY"], "env"
    if conf.get("AMBIENT_KEY_BACKEND") != "file":
        kc = keychain_read()
        if kc:
            return kc, (secret_backend() or "keychain")
    if conf.get("AMBIENT_API_KEY"):
        return conf["AMBIENT_API_KEY"], "file"
    return None, None


def resolve_api_url(conf):
    from_env = os.environ.get("AMBIENT_API_URL")
    api_url = (from_env or conf.get("AMBIENT_API_URL") or DEFAULT_API_URL).rstrip("/")
    parts = urllib.parse.urlsplit(api_url)
    if parts.scheme.lower() != "https" and os.environ.get("AMBIENT_ALLOW_INSECURE") != "1":
        _fail_exit(
            None, _argv_command(), "config",
            f"refusing non-HTTPS endpoint {api_url} — the key would travel "
            "unencrypted. Use https:// (or set AMBIENT_ALLOW_INSECURE=1 for local dev)."
        )
    # HOST PINNING: the API key rides in the Authorization header of every call,
    # so AMBIENT_API_URL is key-equivalent — an injected env var or a tampered
    # config line pointing anywhere else is a one-call key exfil. Only Ambient
    # hosts are trusted implicitly; anything else needs an explicit, recorded
    # trust decision (ambient trust-url), and an ENV-sourced override needs a
    # second env var so a single injected variable is never sufficient.
    host = (parts.hostname or "").lower()
    if host == "ambient.xyz" or host.endswith(".ambient.xyz") \
            or os.environ.get("AMBIENT_ALLOW_INSECURE") == "1":
        return api_url
    if conf.get("AMBIENT_TRUSTED_URL") == api_url and (
            not from_env or os.environ.get("AMBIENT_ALLOW_URL") == "1"):
        return api_url
    _fail_exit(
        None, _argv_command(), "config",
        f"refusing to send your API key to non-Ambient endpoint "
        f"'{host or api_url}'. If this is deliberate (a self-hosted gateway), "
        "record the trust decision first: ambient trust-url <url>"
    )


def cmd_trust_url(args):
    """Record an explicit trust decision for a non-Ambient endpoint. The key
    is sent to whatever host AMBIENT_API_URL names, so this is key-equivalent
    and demands a typed confirmation on a real terminal."""
    url = args.url.rstrip("/")
    parts = urllib.parse.urlsplit(url)
    host = (parts.hostname or "").lower()
    if parts.scheme.lower() != "https" or not host:
        sys.exit("ambient: trust-url needs a full https:// URL")
    if not sys.stdin.isatty():
        sys.exit("ambient: trust-url is interactive-only (a typed confirmation "
                 "proves a human made this decision)")
    print(
        f"Your Ambient API key will be sent in the Authorization header to\n"
        f"  {host}\non EVERY future call. Only do this for a gateway you run "
        "or fully trust."
    )
    try:
        typed = input(f"Type the hostname ({host}) to confirm: ").strip().lower()
    except (EOFError, KeyboardInterrupt):
        sys.exit("\nambient: cancelled")
    if typed != host:
        sys.exit("ambient: hostname mismatch — nothing saved")
    save_config_values({"AMBIENT_TRUSTED_URL": url, "AMBIENT_API_URL": url})
    print(f"Trusted endpoint saved: {url}\nRevert any time: ambient trust-url --reset")


def cmd_trust_url_reset():
    save_config_values({"AMBIENT_TRUSTED_URL": None, "AMBIENT_API_URL": None})
    print(f"Endpoint trust cleared — back to {DEFAULT_API_URL}")


def load_config():
    """Read key/url/defaults, letting env vars win, preferring Keychain storage.
    FIRST USE on a real terminal onboards inline (asks for the key, verifies,
    shows the welcome panel, then continues the original command) instead of
    erroring; non-interactive callers get a stable category + dedicated exit
    code and never hang."""
    conf = read_config_file()
    api_key, _ = resolve_key_and_backend(conf)
    api_url = resolve_api_url(conf)
    if api_key:
        return api_key, api_url, conf
    # stdout.isatty matters too: `ambient ask --json > out.json` on a first
    # run must NOT interleave the setup preamble/welcome panel into the
    # captured file (Codex W2/3 HIGH) — a redirected first run gets exit 3.
    interactive = (
        sys.stdin.isatty() and sys.stderr.isatty() and sys.stdout.isatty()
        and os.environ.get("AMBIENT_NO_ONBOARD") != "1"
        and not os.environ.get("CI")
    )
    if interactive:
        print(
            "ambient: first run — no API key is configured yet. Setting one "
            "up takes about a minute.\n",
            file=sys.stderr,
        )
        cmd_setup(argparse.Namespace(
            key_stdin=False, force=False, file=False, remove=False))
        conf = read_config_file()
        api_key, _ = resolve_key_and_backend(conf)
        if api_key:
            print("\nambient: setup complete — continuing with your original "
                  "command.\n", file=sys.stderr)
            return api_key, resolve_api_url(conf), conf
    print(
        "ambient [setup]: no API key configured.\n"
        "  Interactive:      ambient setup\n"
        "  Non-interactive:  export AMBIENT_API_KEY=<key>   "
        "(or: ambient setup --key-stdin)\n"
        f"  Get a key:        {KEY_CONSOLE_URL}  →  API Keys",
        file=sys.stderr,
    )
    sys.exit(EXIT_UNCONFIGURED)


def redact(text, api_key):
    """Make model-derived text safe to print: strip the API key (endpoints
    echoing auth back must never land it in terminal output or transcripts)
    AND neutralize terminal-escape injection from untrusted miner output.
    Keys shorter than 8 chars are not redacted: substring collisions would
    mangle ordinary text (real keys are far longer)."""
    if not text:
        return text
    if api_key and len(api_key) >= 8:
        text = text.replace(api_key, "[AMBIENT_API_KEY]")
    if os.environ.get("AMBIENT_NO_SANITIZE") != "1":
        text = CTRL_RE.sub("", ANSI_RE.sub("", text))
    return text


def _stderr_is_tty():
    """True when stderr can take in-place \\r rewrites + escapes (B5)."""
    try:
        return sys.stderr.isatty() and os.environ.get("TERM", "") not in ("", "dumb")
    except Exception:  # noqa: BLE001
        return False


def _use_color(stream):
    """Color only when it can't hurt: real TTY, TERM not dumb, NO_COLOR unset
    (https://no-color.org). Per-stream so `ambient models | grep` gets clean
    bytes while stderr stays colored."""
    if os.environ.get("NO_COLOR") is not None \
            or os.environ.get("AMBIENT_NO_COLOR"):
        return False
    if os.environ.get("TERM", "") in ("", "dumb"):
        return False
    try:
        return stream.isatty()
    except Exception:  # noqa: BLE001
        return False


def paint(s, code, stream=None):
    """Minimal ANSI wrap (bold=1 dim=2 red=31 green=32 yellow=33) — NEVER used
    on --json/--raw output paths."""
    stream = stream if stream is not None else sys.stdout
    return f"\033[{code}m{s}\033[0m" if _use_color(stream) else s


@contextlib.contextmanager
def _config_lock(conf_dir):
    """Cross-platform exclusive lock for config writes (B1). POSIX uses flock;
    where fcntl is absent (Windows) it spins on an O_EXCL lock file and breaks a
    stale (>30s) lock so a crashed writer can't wedge the config forever."""
    lock_path = os.path.join(conf_dir, ".env.lock")
    if fcntl is not None:
        try:
            fd = os.open(lock_path, os.O_WRONLY | os.O_CREAT, 0o600)
        except OSError as err:
            sys.exit(f"ambient: cannot open config lock: {err}")
        try:
            fcntl.flock(fd, fcntl.LOCK_EX)
            yield
        finally:
            fcntl.flock(fd, fcntl.LOCK_UN)
            os.close(fd)
        return
    fd, waited = None, 0.0
    while fd is None:
        try:
            fd = os.open(lock_path, os.O_CREAT | os.O_EXCL | os.O_WRONLY, 0o600)
            os.write(fd, str(os.getpid()).encode())  # ownership token
        except FileExistsError:
            try:
                if time.time() - os.path.getmtime(lock_path) > 30:
                    os.unlink(lock_path)  # break a stale lock (crashed writer)
                    continue
            except OSError:
                pass
            if waited >= 10.0:
                # NEVER enter the critical section unlocked — that loses updates
                # or corrupts the key (Codex A+B HIGH). Fail loudly instead.
                sys.exit(
                    "ambient: config is locked by another ambient process "
                    "(waited 10s). Retry in a moment."
                )
            time.sleep(0.1)
            waited += 0.1
    try:
        yield
    finally:
        os.close(fd)
        try:
            os.unlink(lock_path)
        except OSError:
            pass


def _private_dir(path):
    """Create/heal a directory as owner-only. Cache entries quote the user's
    proprietary code and usage records their activity — the 0600 discipline of
    the env file applies to everything under ~/.config/ambient (security sweep:
    cache/usage were world-readable)."""
    try:
        os.makedirs(path, mode=0o700, exist_ok=True)
        if os.stat(path).st_mode & 0o077:
            os.chmod(path, 0o700)
    except OSError:
        pass


def save_config_values(updates):
    """Atomically + concurrency-safely rewrite the env file (0600): replace
    managed keys once, drop duplicate managed-key lines, preserve the rest. A
    lock file serializes the read-modify-write-rename so two ambient processes
    (multiple sessions) can't lose updates or leave a torn file; the temp file
    has a unique name so concurrent writers never share one inode.
    `updates` may be a CALLABLE taking the freshly-parsed config dict and
    returning the updates dict — list-merge writers (curation) must compute
    their merge INSIDE the lock or two terminals lose each other's entries
    (Codex W2/3 MED)."""
    conf_dir = os.path.dirname(CONFIG_PATH)
    try:
        os.makedirs(conf_dir, mode=0o700, exist_ok=True)
        if os.stat(conf_dir).st_mode & 0o077:
            os.chmod(conf_dir, 0o700)
    except OSError as err:
        sys.exit(f"ambient: cannot create {conf_dir}: {err}")
    with _config_lock(conf_dir):
        # Read fresh INSIDE the lock so we never compute from a stale snapshot.
        lines = []
        try:
            with open(CONFIG_PATH, encoding="utf-8") as fh:
                lines = fh.read().splitlines()
        except FileNotFoundError:
            pass
        if callable(updates):
            conf_now = {}
            for line in lines:
                stripped = line.strip()
                if stripped and not stripped.startswith("#") and "=" in stripped:
                    k, _, v = stripped.partition("=")
                    conf_now[k.strip()] = v.strip()
            updates = updates(conf_now)
        remaining = dict(updates)
        replaced = set()
        new_lines = []
        for line in lines:
            stripped = line.strip()
            key = stripped.partition("=")[0].strip() if "=" in stripped else None
            if key in remaining:
                val = remaining.pop(key)
                replaced.add(key)
                if val is not None:  # None means: delete this key entirely
                    new_lines.append(f"{key}={val}")
            elif key in replaced or key in updates:
                continue  # duplicate managed-key line — drop it
            else:
                new_lines.append(line)
        for key, val in remaining.items():
            if val is not None:
                new_lines.append(f"{key}={val}")
        tmp_fd, tmp_path = tempfile.mkstemp(dir=conf_dir, prefix=".env.")
        try:
            if hasattr(os, "fchmod"):  # POSIX-only
                os.fchmod(tmp_fd, 0o600)
            with os.fdopen(tmp_fd, "w", encoding="utf-8") as fh:
                fh.write("\n".join(new_lines) + "\n")
                fh.flush()
                os.fsync(fh.fileno())
            os.replace(tmp_path, CONFIG_PATH)
        except OSError as err:
            try:
                os.unlink(tmp_path)
            except OSError:
                pass
            sys.exit(f"ambient: failed to write {CONFIG_PATH}: {err}")
        os.chmod(CONFIG_PATH, 0o600)


# Founder-verified guidance shown wherever models are chosen; a founder-set
# note for the same id (ambient curate note) overrides, and an explicitly
# cleared note stays cleared. Local config only — nothing fetched or sent.
DEFAULT_MODEL_NOTES = {
    "z-ai/glm-5.2": "network capacity ramping up — selectable, improving",
}


def _split_csv(raw):
    return [x.strip() for x in (raw or "").split(",") if x.strip()]


def curation(conf):
    """Founder model-curation state from env/config: (allow, hide, show,
    notes). allow/hide are lists of ids or fnmatch globs; show is a list of
    EXACT ids that override everything (so `curate show qwen/foo` can surface
    one model out of a hidden glob — Codex W2/3 MED: without it, a glob hide
    was un-overridable); notes maps id -> label. Curation affects SURFACING
    and AUTOMATIC selection only — explicit -m/`use <id>` always works (model
    choice is SACRED). Parses defensively: junk config can never crash."""
    allow = _split_csv(os.environ.get("AMBIENT_MODELS_ALLOW")
                       or conf.get("AMBIENT_MODELS_ALLOW"))
    hide = _split_csv(os.environ.get("AMBIENT_MODELS_HIDE")
                      or conf.get("AMBIENT_MODELS_HIDE"))
    show = _split_csv(os.environ.get("AMBIENT_MODELS_SHOW")
                      or conf.get("AMBIENT_MODELS_SHOW"))
    notes = dict(DEFAULT_MODEL_NOTES)
    raw_notes = conf.get("AMBIENT_MODEL_NOTES")
    if raw_notes:
        try:
            parsed = json.loads(raw_notes)
            if isinstance(parsed, dict):
                for k, v in parsed.items():
                    if isinstance(k, str) and isinstance(v, str):
                        notes[k] = v  # "" = founder cleared a default note
        except json.JSONDecodeError:
            print("ambient: AMBIENT_MODEL_NOTES in config is malformed — "
                  "ignoring it (reset: ambient curate reset)", file=sys.stderr)
    return allow, hide, show, notes


def is_hidden(model_id, allow, hide, show=()):
    """True when curation removes this model from menus/automatic selection.
    Precedence: an exact SHOW entry always surfaces; then ALLOW (when
    non-empty) filters; HIDE applies within the result."""
    if model_id in show:
        return False
    if allow and not any(fnmatch.fnmatchcase(model_id, g) for g in allow):
        return True
    return any(fnmatch.fnmatchcase(model_id, g) for g in hide)


def note_if_hidden(model_id, conf, source="-m"):
    """One stderr line when an explicitly chosen model is curated out —
    explicit choice always wins, but silently ignoring the founder's curation
    would look like a bug."""
    allow, hide, show, _ = curation(conf)
    if is_hidden(model_id, allow, hide, show):
        print(
            f"ambient: note — '{model_id}' is hidden by your model curation; "
            f"using it anyway (explicit {source} always wins). Surface it "
            f"with: ambient curate show {model_id}",
            file=sys.stderr,
        )


def build_banner():
    """The bare-`ambient` command showcase, with a live status footer built
    from purely local reads (zero network) so a configured user and a fresh
    install each see the right next step."""
    conf = read_config_file()
    key, backend = resolve_key_and_backend(conf)
    ns = argparse.Namespace(model=None)
    if key:
        status = (f"status: key configured ({backend}) · delegate "
                  f"{(conf.get('AMBIENT_DELEGATE') or 'off').lower()} · "
                  f"model {resolve_model(ns, conf, 'chat')}")
    else:
        status = (f"status: no API key yet — run: ambient setup   "
                  f"(keys at {KEY_CONSOLE_URL})")
    return f"""ambient {__version__} — a second pair of eyes from the Ambient decentralized
inference network (ambient.xyz): open-source models, paid per token.

Get started
  ambient setup            store + verify your API key (one time)
  ambient models           see which models are live right now
  ambient use              pick your sticky default model

Do work
  ambient ask "question"   one-shot answer; big docs: cat doc.txt | ambient ask "sum" -
  ambient audit FILE...    adversarial code review; diffs: git diff | ambient audit
  ambient code "task"      generate code (-f app.py attaches context)
  ambient build "task"     plan + generate a whole set of files (never executes)
  ambient agent            interactive agentic terminal on Ambient (opencode)

Keep it healthy
  ambient doctor           pinpoint key / funds / busy-model / network trouble
  ambient usage            local spend summary (--days N)
  ambient mode on|off      delegate mode for Claude Code sessions

{status}
more:   ambient -h · ambient audit -h · /ambient inside Claude Code"""


def print_welcome_panel(models, where, probe_detail, conf, funds_issue=False):
    """Post-verification command showcase — the moment a stranger decides the
    tool is worth keeping. Called from setup success and first-use onboarding."""
    ready = len(ready_model_ids(models))
    ns = argparse.Namespace(model=None)
    chat_model = resolve_model(ns, conf, "chat")
    net = (f"Network:   {len(models)} models, {ready} live right now "
           "(miners come and go — `ambient models`)")
    if not ready:
        net += ("\n           none live this minute — your key still verified; "
                "retry `ambient models` soon")
    print(f"Key verified — {probe_detail}.")
    print(f"Stored in: {where}")
    print(net)
    print("\nWelcome to Ambient — a second pair of eyes, ~10-40x cheaper than "
          "frontier models.\n")
    if funds_issue:
        print(f"  NOTE: your account is OUT OF FUNDS — completions will fail until\n"
              f"  you top up at {KEY_CONSOLE_URL}, then run: ambient doctor\n")
    else:
        print("  Try it now (30 seconds):\n"
              '    ambient ask "Reply with exactly: AMBIENT-OK"\n')
    print("""  Everyday:
    git diff | ambient audit              second-opinion review of your changes
    ambient audit src/*.py --focus security   audit files (any size — auto-split)
    ambient ask "question"                one-shot Q&A (pipe docs: cat doc | ambient ask "…" -)
    ambient code "write a ..."            code generation
    ambient build "make a ..." --dir out  plan + generate a set of files (never executes)

  Manage:
    ambient models         what's live (READY) right now
    ambient use            pick your sticky default model
    ambient usage          local spend estimate
    ambient doctor         one-command diagnosis when anything fails
    ambient link           put `ambient` on your PATH
    ambient setup --force  rotate/replace your key · --remove deletes it

  In Claude Code:  /ambient opens the control panel · /ambient on = delegate mode
""")
    print(f"Default model: {chat_model} — change any time: ambient use")


def key_paste_problem(key):
    """Local sanity check of a pasted key BEFORE any network call. Malformed
    pastes (smart quotes, embedded whitespace, shell fragments) must produce a
    human message — not a UnicodeEncodeError [internal] crash in urllib header
    encoding, and never a late, misleading 'Keychain write failed' (the
    keychain writer rejects quotes/backslashes). Returns None when plausible."""
    if not key:
        return "That was empty — paste the key value."
    if re.search(r"\s", key):
        return ("That does not look like an API key (it contains spaces or "
                "line breaks). Paste just the key value.")
    if any(ord(c) < 0x21 or ord(c) > 0x7E for c in key):
        return ("The paste contains characters that cannot appear in an "
                "Ambient key (smart quotes / unicode). Re-copy it from "
                f"{KEY_CONSOLE_URL}.")
    if len(key) < 16:
        return "That looks too short to be an Ambient key."
    if '"' in key or "\\" in key:
        return ("That does not look like a valid key (it contains quote or "
                "backslash characters). Re-copy it from the console.")
    return None


def resolve_model(args, conf, kind="chat"):
    """Resolution order: -m flag > env var > saved default > built-in."""
    env_key = "AMBIENT_CODE_MODEL" if kind == "code" else "AMBIENT_MODEL"
    fallback = DEFAULT_CODE_MODEL if kind == "code" else DEFAULT_MODEL
    return (
        getattr(args, "model", None)
        or os.environ.get(env_key)
        or conf.get(env_key)
        or fallback
    )


class NetworkError(Exception):
    """The API was unreachable (DNS, connection refused, timeout)."""


def api_request(api_url, api_key, path, payload=None, timeout=DEFAULT_TIMEOUT_S):
    """Single JSON request to the API. Returns (status_code, parsed_body).
    Raises NetworkError when the API cannot be reached at all."""
    url = f"{api_url}{path}"
    data = json.dumps(payload).encode("utf-8") if payload is not None else None
    req = urllib.request.Request(
        url,
        data=data,
        headers={
            "Authorization": f"Bearer {api_key}",
            "Content-Type": "application/json",
        },
        method="POST" if data else "GET",
    )
    # Only idempotent GETs auto-retry: a timed-out completion POST may have
    # been processed server-side, and a blind retry would double-spend.
    retryable = data is None
    last_err = NetworkError(f"cannot reach {url}")
    for attempt in (1, 2):
        try:
            with urllib.request.urlopen(req, timeout=timeout) as resp:
                return resp.status, json.loads(
                    resp.read().decode("utf-8", errors="replace"))
        except urllib.error.HTTPError as err:
            body = err.read().decode("utf-8", errors="replace")
            if err.code in (502, 503, 504) and attempt == 1 and retryable:
                print(f"ambient: HTTP {err.code}, retrying once...", file=sys.stderr)
                time.sleep(_retry_delay(2, err.headers))
                continue
            try:
                return err.code, json.loads(body)
            except json.JSONDecodeError:
                return err.code, {"error": {"message": body[:2000]}}
        except urllib.error.URLError as err:
            last_err = NetworkError(f"cannot reach {url} ({err.reason})")
        except (OSError, http.client.IncompleteRead) as err:
            # A dropped/incomplete read is a transient network fault, not a crash
            # (Ambient self-audit #4) — treat like URLError so it retries/wraps.
            last_err = NetworkError(f"read from {url} failed ({err})")
        except json.JSONDecodeError:
            # Garbled body: retryable GETs try again; otherwise report cleanly
            # instead of a hard sys.exit (Ambient self-audit #3).
            last_err = NetworkError(f"{url} returned malformed JSON")
        if attempt == 1 and retryable:
            print("ambient: network blip, retrying once...", file=sys.stderr)
            time.sleep(_retry_delay(2))
        else:
            break
    raise last_err


def fetch_models(api_url, api_key):
    status, body = api_request(api_url, api_key, "/v1/models", timeout=30)
    if status != 200:
        sys.exit(
            "ambient: /v1/models failed "
            f"(HTTP {status}): {redact(error_message(body), api_key)}"
        )
    # Normalize ONCE at the choke point: every catalog consumer downstream may
    # assume dict entries with a string id (Codex W1 MED — a bare-string or
    # id-less entry crashed _dedupe_catalog/auth_probe). Field VALUES are still
    # coerced at use (_as_pos_int etc.).
    data = body.get("data")
    if not isinstance(data, list):
        return []
    return [m for m in data
            if isinstance(m, dict) and isinstance(m.get("id"), str) and m["id"]]


def _as_pos_int(v, default):
    """Coerce an untrusted catalog field to a positive int, else `default`.
    The catalog is network data from a decentralized API — one drifted field
    type (string context_length, bool, dict) must never crash every command
    (QA sweep: verified repro)."""
    try:
        if isinstance(v, bool):  # bool is an int subclass; True==1 is nonsense here
            return default
        n = int(v)
        return n if n > 0 else default
    except (TypeError, ValueError):
        return default


def ready_model_ids(models):
    return [m.get("id") for m in models
            if isinstance(m, dict) and m.get("is_ready") and m.get("id")]


def safe_catalog(api_url, api_key):
    """Fetch the model catalog, degrading to [] instead of exiting on failure."""
    try:
        return fetch_models(api_url, api_key)
    except (NetworkError, SystemExit):
        return []


# Above every price observed in the live catalog — used when pricing is
# unknown so the spend gate can NEVER fail open (arch sweep: cost_gate used to
# skip the ceiling exactly when the catalog was unreachable).
ASSUMED_MAX_INPUT_PRICE = 2.0    # $/Mtok
ASSUMED_MAX_OUTPUT_PRICE = 8.0   # $/Mtok


def model_pricing(catalog, model):
    """(input $/Mtok, output $/Mtok) from the catalog, or None if unpriced.
    Zero/absent/NaN pricing is UNPRICED, not free — treating it as $0 would
    disable the spend gate exactly when the catalog is degraded (Codex W1
    HIGH). Unpriced models fall to assumed worst-case pricing."""
    for m in catalog or []:
        if isinstance(m, dict) and m.get("id") == model:
            p = m.get("pricing")
            if not isinstance(p, dict):
                return None
            try:
                pin, pout = float(p.get("input")), float(p.get("output"))
            except (TypeError, ValueError):
                return None
            if not (pin >= 0 and pout >= 0 and (pin > 0 or pout > 0)):
                return None  # rejects NaN, negatives, and all-zero "pricing"
            return (pin, pout)
    return None


def estimate_cost(catalog, model, input_chars, n_calls, max_tokens):
    """(expected, bound, assumed) dollar estimates for a run. `bound` assumes
    every call emits its FULL max_tokens budget (the old, 10-30x-pessimistic
    figure that over-refused big legitimate jobs); `expected` uses a realistic
    per-call output. Unpriced model / missing catalog → worst-case ASSUMED
    prices with assumed=True, so the ceiling still applies."""
    price = model_pricing(catalog, model)
    assumed = price is None
    if assumed:
        price = (ASSUMED_MAX_INPUT_PRICE, ASSUMED_MAX_OUTPUT_PRICE)
    in_tok = input_chars / CHARS_PER_TOKEN
    # Input is billed roughly ONCE total (each chunk sends only its own slice),
    # plus ~30% for the synthesis pass re-sending the partial results.
    input_cost = in_tok * 1.3 * price[0]
    bound = (input_cost + n_calls * max_tokens * price[1]) / 1e6
    expected_out = min(max_tokens, ANSWER_TOKENS_RESERVE)
    expected = (input_cost + n_calls * expected_out * price[1]) / 1e6
    return expected, bound, assumed


def cost_gate(catalog, model, input_chars, n_calls, args, conf):
    """Show a cost estimate before a large spend; enforce a ceiling; confirm on
    a TTY. Makes runaway spend impossible to trigger accidentally — including
    when pricing is unknown (assumed worst-case pricing, never fail-open)."""
    expected, bound, assumed = estimate_cost(
        catalog, model, input_chars, n_calls, args.max_tokens)
    note = " — assumed worst-case pricing (model unpriced)" if assumed else ""
    in_tok = int(input_chars / CHARS_PER_TOKEN)
    print(
        f"ambient: estimated cost ~${expected:.2f} (hard bound ${bound:.2f}){note} "
        f"({in_tok:,} input tokens, up to {n_calls} call(s))",
        file=sys.stderr,
    )
    _gate_amount(expected, args, conf, bound=bound)


def _gate_amount(expected, args, conf, bound=None):
    """Ceiling + TTY confirmation on an expected dollar figure — shared by the
    single-model gate and the per-model-priced consensus gate. The ceiling
    binds the EXPECTED spend (the bound over-states 10-30x and would over-
    refuse legitimate jobs), but the worst-case bound gets its own guard at
    3x the ceiling so the configured limit can never be blown past silently
    (Codex W1 HIGH)."""
    raw = (os.environ.get("AMBIENT_MAX_SPEND")
           or conf.get("AMBIENT_MAX_SPEND") or "5")
    try:
        ceiling = float(raw)
    except ValueError:
        ceiling = 5.0
    if expected > ceiling and not getattr(args, "allow_cost", False):
        _fail_exit(
            args, _argv_command(), "cost",
            f"estimated ~${expected:.2f} exceeds the ${ceiling:.2f} spend "
            "ceiling — pass --allow-cost, or raise AMBIENT_MAX_SPEND, to proceed."
        )
    if bound is not None and bound > ceiling * 3 \
            and not getattr(args, "allow_cost", False):
        _fail_exit(
            args, _argv_command(), "cost",
            f"the WORST-CASE spend for this run (${bound:.2f}) exceeds "
            f"3x your ${ceiling:.2f} ceiling — pass --allow-cost, or raise "
            "AMBIENT_MAX_SPEND, to proceed."
        )
    if (expected > 0.50 and sys.stdin.isatty()
            and not getattr(args, "yes", False)):
        # Prompt on STDERR, not stdout: `ambient audit --json > out.json` from an
        # interactive shell must not write "Proceed?" into the captured JSON.
        sys.stderr.write(f"Proceed with an estimated ~${expected:.2f}? [y/N] ")
        sys.stderr.flush()
        try:
            ans = input().strip().lower()
        except (EOFError, KeyboardInterrupt):
            ans = ""
        if ans not in ("y", "yes"):
            _fail_exit(args, _argv_command(), "cancelled", "cancelled")


def pick_fallback_model(catalog, current, min_context=0, conf=None):
    """Choose a READY replacement that can actually do chat work — text output,
    not an embedding/vision-only model — so opt-in fallback never silently
    switches to a model that would produce nonsense. Requires context_length >=
    min_context so the alt can hold the chunk that was already sized for the
    original model (Codex fix: a non-reasoner's huge chunk must not land on a
    small-window model). Curation-aware: never auto-switch INTO a model the
    founder curated out while any visible candidate exists, prefer the user's
    other configured lane default, then biggest context, then cheapest output.
    Returns None if none fit."""
    conf = conf if conf is not None else {}
    allow, hide, show, _notes = curation(conf)
    ns = argparse.Namespace(model=None)
    lane_defaults = {resolve_model(ns, conf, "chat"),
                     resolve_model(ns, conf, "code")}
    candidates = []
    skipped_hidden = 0
    for m in catalog:
        if not isinstance(m, dict) or not m.get("is_ready") \
                or not m.get("id") or m.get("id") == current:
            continue
        out = m.get("output_modalities") or ["text"]
        if not isinstance(out, list) or "text" not in out:
            continue
        ctx = _as_pos_int(m.get("context_length"), 0)
        if ctx < min_context:
            continue
        mid = m["id"]
        hidden = is_hidden(mid, allow, hide, show)
        price = model_pricing(catalog, mid)
        out_price = price[1] if price else ASSUMED_MAX_OUTPUT_PRICE
        candidates.append(
            (1 if hidden else 0, 0 if mid in lane_defaults else 1,
             -ctx, out_price, mid))
        skipped_hidden += 1 if hidden else 0
    if not candidates:
        return None
    candidates.sort()
    best = candidates[0]
    if best[0] == 1:  # only curated-out models remain — don't auto-switch
        print(
            f"ambient: fallback — {skipped_hidden} READY model(s) skipped "
            "because your curation hides them",
            file=sys.stderr,
        )
        return None
    return best[4]


ModelProfile = collections.namedtuple(
    "ModelProfile",
    "model is_reasoning context_length max_output_length "
    "output_budget single_shot_chars chunk_chars escalation_ceiling features",
)


def response_format_for(profile, schema):
    """Capability-gated structured-output request for a model (A4): strict
    json_schema when supported, else json_object, else None (prompt-only).
    Sending response_format to a model that lacks it can 400 — so gate."""
    feats = profile.features or []
    if "structured_outputs" in feats:
        return {"type": "json_schema",
                "json_schema": {"name": "ambient_findings", "strict": True,
                                "schema": schema}}
    if "json_mode" in feats:
        return {"type": "json_object"}
    return None


def _reasoning_output_budget(input_chars):
    """Tokens needed to REASON over `input_chars` of dense code AND still emit a
    real answer: reasoning_tokens + a fixed answer reserve, times a safety factor."""
    reasoning_tokens = input_chars * REASONING_EXPANSION / CHARS_PER_TOKEN
    return int((reasoning_tokens + ANSWER_TOKENS_RESERVE) * OUTPUT_SAFETY)


def single_shot_max_chars():
    """Cost-knob cap on how large a single-shot reasoning call may get (A1)."""
    raw = os.environ.get("AMBIENT_SINGLE_SHOT_MAX_CHARS")
    if raw:
        try:
            return max(REASONING_SINGLE_SHOT_CHARS, int(raw))
        except ValueError:
            pass
    return SINGLE_SHOT_MAX_CHARS_DEFAULT


def _reasoning_single_shot_target(ctx, max_out):
    """Largest input a reasoning model can take in ONE pass and still fit both
    its output cap and its context window. Bounded by the cost knob."""
    # Output constraint: _reasoning_output_budget(single) <= max_out
    by_output = ((max_out / OUTPUT_SAFETY - ANSWER_TOKENS_RESERVE)
                 * CHARS_PER_TOKEN / REASONING_EXPANSION)
    # Context constraint: input_tok + output_budget(single) + overhead <= ctx.
    # input_tok = single/CPT; output ≈ (single*EXP/CPT + RESERVE)*SAFETY.
    denom = (1 + REASONING_EXPANSION * OUTPUT_SAFETY) / CHARS_PER_TOKEN
    by_ctx = (ctx - ANSWER_TOKENS_RESERVE * OUTPUT_SAFETY - 2500) / denom
    target = min(by_output, by_ctx, single_shot_max_chars())
    return int(max(MIN_REASONING_CHUNK, target))


def model_profile(catalog, model):
    """Derive per-model tuning from /v1/models metadata (PURE — pass an already-
    fetched catalog). Reasoning models get a GENEROUS output budget so reasoning
    AND answer both fit, plus SMALL chunks so reasoning-per-chunk stays bounded;
    non-reasoning models get a modest budget and LARGE (context-sized) chunks.
    An unknown/offline model falls back to conservative REASONING defaults — the
    safer failure mode (over-budget, under-chunk)."""
    meta = next((m for m in (catalog or [])
                 if isinstance(m, dict) and m.get("id") == model), None)
    if meta is None:
        ctx, max_out, feats = FALLBACK_CONTEXT, FALLBACK_MAX_OUTPUT, ["reasoning"]
    else:
        # Coerce untrusted catalog types — a string "202752" or junk must
        # degrade to the fallback, never TypeError every command (QA sweep).
        # Only substitute the fallback when the field is absent/invalid — a
        # real but small cap (e.g. 1024) is respected, not inflated past the
        # API limit (Codex round-3 LOW).
        ctx = _as_pos_int(meta.get("context_length"), FALLBACK_CONTEXT)
        max_out = _as_pos_int(meta.get("max_output_length"), FALLBACK_MAX_OUTPUT)
        raw_feats = meta.get("supported_features")
        feats = [f for f in raw_feats if isinstance(f, str)] \
            if isinstance(raw_feats, list) else []
    ctx = max(ctx, 4000)  # keep the math sane on absurd metadata
    # The literal catalog signal: only a MISSING entry assumes reasoning; a
    # present entry without the flag (qwen3-coder/next) is a real non-reasoner.
    is_reasoning = "reasoning" in feats
    ceiling = min(max_out, MAX_AUTO_BUDGET_TOKENS)  # real cap AND cost guard

    if is_reasoning:
        # A1: size single-shot to the model's REAL window, not a flat 32k.
        single = _reasoning_single_shot_target(ctx, max_out)
        out = _reasoning_output_budget(single)
        if out > max_out:
            # Hard output cap (e.g. gemma-4-31b = 16384) can't hold
            # reasoning+answer for the target single-shot. INVERT
            # _reasoning_output_budget INCLUDING OUTPUT_SAFETY so the shrunk
            # input's derived budget actually fits the cap (Codex fix): solve
            # out = (reasoning_tok + reserve) * safety = max_out.
            out = max_out
            reasoning_tok = max(256, max_out / OUTPUT_SAFETY - ANSWER_TOKENS_RESERVE)
            single = max(MIN_REASONING_CHUNK,
                         int(reasoning_tok * CHARS_PER_TOKEN / REASONING_EXPANSION))
        chunk = int(single * REASONING_CHUNK_FACTOR)
    else:
        # Non-reasoning: answers directly. Size input off the context window with a
        # 15% margin, but CLAMP output+input to stay within context even for a
        # degenerate tiny-context model where max_output ≈ context (Codex fix).
        out = min(NONREASONING_OUTPUT_BUDGET, max_out, max(MIN_OUTPUT_TOKENS, ctx // 2))
        input_tokens = int(ctx * NONREASONING_CONTEXT_MARGIN) - out
        input_tokens = max(1000, min(input_tokens, ctx - out - 1000))
        single = int(input_tokens * CHARS_PER_TOKEN)
        chunk = int(single * REASONING_CHUNK_FACTOR)
    # REASONING INVARIANT (Codex round-3 MED): after all caps/floors, guarantee
    # the derived budget actually holds reasoning over `single` + the answer.
    # A small output cap (e.g. 8000) with the MIN_REASONING_CHUNK floor could
    # otherwise leave _reasoning_output_budget(single) > out. Shrink until it
    # fits (or hit a hard floor — a truly tiny-cap model just can't audit well).
    if is_reasoning:
        while single > 500 and _reasoning_output_budget(single) > out:
            single = int(single * 0.85)
        chunk = min(chunk, single)
    # FINAL context-fit clamp (Codex): guarantee single-shot input + output fit
    # the context window with overhead, for ANY model (incl. hypothetical tiny-
    # context reasoners). Shrink the input if needed; if even a floor input
    # won't fit, also trim the output budget so a call can still complete.
    # 2500-token overhead = system prompt + chat framing + a real safety margin
    # (not a knife's edge), so input+output never lands within a token of context.
    overhead_tok = 2500
    max_input_tok = ctx - out - overhead_tok
    if max_input_tok < 1000:
        # Give input room by trimming output — but NEVER above the model's real
        # output cap (fuzz-caught: a tiny max_out could be exceeded here).
        out = min(max_out, max(256, ctx - 1000 - overhead_tok))
        max_input_tok = ctx - out - overhead_tok
    single_tok = -(-single // CHARS_PER_TOKEN)  # ceil, conservative
    if single_tok > max_input_tok:
        single = max(1000, int(max_input_tok * CHARS_PER_TOKEN))
        single_tok = -(-single // CHARS_PER_TOKEN)
    # The escalation ceiling must also respect remaining context, not just the
    # model's output cap, so a budget bump can't push input+output past context.
    ceiling = min(ceiling, int(ctx - single_tok - overhead_tok))
    ceiling = max(ceiling, out)  # never below the starting budget
    # A chunk must never exceed the single-shot budget, and never drop below the
    # floor (keeps map-reduce chunks strictly smaller than single).
    chunk = max(MIN_REASONING_CHUNK, min(chunk, single))
    chunk = min(chunk, single)  # floor may have pushed it above single on tiny models
    return ModelProfile(model, is_reasoning, ctx, max_out,
                        out, single, chunk, ceiling, list(feats))


def apply_output_budget(args, profile, input_chars=None):
    """Resolve args.max_tokens from the profile unless the user set it
    explicitly, and stash the escalation ceiling for complete(). Runs before
    cost_gate in every command, so estimates reflect the real budget. When
    `input_chars` is given, RIGHT-SIZE a reasoning model's budget to the actual
    input (A1) — so a small prompt gets a sane ceiling, not the worst-case one."""
    args.escalation_ceiling = profile.escalation_ceiling
    if getattr(args, "max_tokens", None) is None:  # auto — the common path
        if input_chars is not None and profile.is_reasoning:
            want = _reasoning_output_budget(input_chars)
            # Floor gives room to think+answer, but must never exceed the
            # profile's already context-safe budget (Codex A+B MED).
            floor = min(8192, profile.output_budget)
            args.max_tokens = max(floor, min(want, profile.output_budget))
        else:
            args.max_tokens = profile.output_budget
        args._auto_budget = True  # let --fallback re-derive vs. respect a user value
        return
    args._auto_budget = False
    # explicit --max-tokens: respect it, but keep it sane for THIS model — clamp
    # to BOTH the output cap AND what leaves room for the input in context, so a
    # big --max-tokens on a big-context model can't overflow (Codex round-3 HIGH).
    single_tok = int(profile.single_shot_chars / CHARS_PER_TOKEN)
    context_safe = profile.context_length - single_tok - 2500
    # The floor must never exceed the model's real output cap (fuzz-caught: a
    # 500-token-cap model must not be forced up to the 2048 floor).
    floor = min(MIN_OUTPUT_TOKENS, profile.max_output_length)
    args.max_tokens = max(floor,
                          min(args.max_tokens, profile.max_output_length,
                              max(1, context_safe)))
    if profile.is_reasoning and args.max_tokens < profile.output_budget:
        print(
            f"ambient: --max-tokens {args.max_tokens} is below the "
            f"~{profile.output_budget} a reasoning model needs to think AND "
            f"answer over a {profile.single_shot_chars:,}-char input — it may "
            "stop mid-reasoning (the auto-escalation guard will try to recover).",
            file=sys.stderr,
        )


def error_message(body):
    err = body.get("error") if isinstance(body, dict) else None
    if isinstance(err, dict):
        return err.get("message", json.dumps(err)[:500])
    return json.dumps(body)[:500]


FUNDS_WORDS = (
    "credit", "account balance", "low balance", "insufficient funds",
    "insufficient balance", "out of funds", "quota", "billing", "payment",
)


def classify_error(status, body, api_key):
    """Map an API failure to (category, user-facing diagnosis) so users can tell
    a dead key from an empty account from a busy model from a real outage.
    Categories: key | funds | model | rate | service | unknown."""
    msg = redact(error_message(body), api_key)
    lower = msg.lower()
    # Order matters: 5xx first (a 503 mentioning "billing service" is an outage,
    # not a funds problem); explicit funds wording next (a 403 "insufficient
    # credits" is a funds problem, not a bad key); auth after that.
    if status >= 500:
        return "service", (
            f"Ambient service problem (HTTP {status}: {msg}). Nothing is wrong with "
            "your key or account — retry shortly."
        )
    if status == 402 or any(w in lower for w in FUNDS_WORDS):
        return "funds", (
            f"Your Ambient account looks out of funds or over quota (HTTP {status}: "
            f"{msg}). Top up your account — the service itself is fine."
        )
    if status in (401, 403) or "authentication_error" in lower:
        return "key", (
            f"Ambient rejected your API key (HTTP {status}). The key may be revoked, "
            "expired, or mistyped — this is NOT an Ambient outage. "
            "Fix: ambient setup --force"
        )
    if status == 429 and "no workers" in lower:
        return "model", (
            "No miners are serving that model right now (HTTP 429). Your key and "
            "account are fine — pick a READY model (ambient models) or retry later."
        )
    if status == 429:
        return "rate", f"Rate limited (HTTP 429: {msg}). Wait a moment and retry."
    if status == 400:
        ctx_words = ("context", "context_length", "maximum context", "too long",
                     "reduce the length")
        budget_words = ("maximum tokens", "max_tokens", "token limit")
        if any(w in lower for w in ctx_words):
            return "context", (
                f"input exceeds the model's context window (HTTP {status}: {msg})."
            )
        if any(w in lower for w in budget_words):
            # A too-large max_tokens is NOT a context overflow: splitting the
            # input resends the same doomed budget and every chunk fails the
            # same way (resilience sweep LOW). Handled by halving the budget.
            return "budget", (
                f"the requested output budget exceeds this model's limit "
                f"(HTTP {status}: {msg})."
            )
    return "unknown", f"HTTP {status}: {msg}"


def auth_probe(api_url, api_key, models):
    """Verify a key with a minimal real completion (the models endpoint is
    unauthenticated, so it proves nothing about the key). Returns
    (ok, category, detail). A 429 'no workers' still proves auth passed."""
    ready = ready_model_ids(models)
    probe_model = ready[0] if ready else (models[0]["id"] if models else DEFAULT_MODEL)
    payload = {
        "model": probe_model,
        "messages": [{"role": "user", "content": "ping"}],
        "max_tokens": 16,
    }
    status, body = api_request(
        api_url, api_key, "/v1/chat/completions", payload, timeout=60
    )
    if status == 200:
        return True, "ok", f"live completion on {probe_model} succeeded"
    category, detail = classify_error(status, body, api_key)
    if category == "model":
        # "No workers" is only ever returned after auth succeeds.
        return True, category, (
            "authentication passed (probe model has no live workers, which is "
            "only reported post-auth)"
        )
    if category in ("rate", "service"):
        # Indeterminate: a gateway limiter or outage can fire before auth is
        # proven — refuse to certify the key on this evidence.
        return False, category, (
            f"could not verify the key ({detail}) — retry in a minute"
        )
    return False, category, detail


SECRET_PATTERNS = [
    re.compile(r"(?i)(?:api[_-]?key|secret|passwd|password|token)['\"]?\s*[:=]\s*['\"]?[A-Za-z0-9_.\-]{16,}"),
    re.compile(r"AKIA[0-9A-Z]{16}"),
    re.compile(r"-----BEGIN [A-Z ]*PRIVATE KEY-----"),
    re.compile(r"(?i)bearer\s+[A-Za-z0-9_.\-]{20,}"),
    re.compile(r"(?:github_pat|gh[pousr])_[A-Za-z0-9_]{20,}"),
    re.compile(r"sk-[A-Za-z0-9_\-]{20,}"),
    re.compile(r"xox[baprs]-[A-Za-z0-9\-]{10,}"),
    # Unlabeled high-value creds the label pattern above misses. Both are
    # tightly anchored (fixed prefix + separators) so they stay linear on long
    # lines and carry a low false-positive rate.
    re.compile(r"AIza[0-9A-Za-z_\-]{35}"),  # Google API key
    re.compile(r"eyJ[A-Za-z0-9_\-]{10,}\.eyJ[A-Za-z0-9_\-]{10,}"
               r"\.[A-Za-z0-9_\-]{6,}"),    # JWT (header.payload.signature)
]
# Kept OUT of SECRET_PATTERNS: this pattern backtracks quadratically on long
# lowercase-alnum runs (measured 129s on a 400k-char line — an effective hang
# on minified/hex blobs, resilience sweep HIGH). _line_has_secret gates it on
# the literal '://' and scans only a bounded window around each occurrence.
CREDS_IN_URL_RE = re.compile(r"[a-z][a-z0-9+.\-]*://[^/\s:@]+:[^@\s]{6,}@")
# Credential-named files refused regardless of content (security sweep: the
# old check missed .envrc/.netrc/.npmrc/.pgpass/id_rsa/*.pem/credentials.json).
SECRET_NAMES_RE = re.compile(
    r"(^|\.)env(\.|$)|^\.envrc$|^\.netrc$|^\.npmrc$|^\.pgpass$"
    r"|^id_(rsa|ed25519|ecdsa|dsa)(\.pub)?$|^credentials(\.json)?$"
    r"|\.(pem|p12|pfx)$", re.I)


def _line_has_secret(line):
    if any(p.search(line) for p in SECRET_PATTERNS):
        return True
    if "://" not in line:
        return False
    # Overlapping fixed windows (4k window / 2k step): total work stays linear
    # in the line length with NO occurrence cap (Codex W1 MED: a cap let a
    # credential after 20 benign URLs through), and a cred URL spanning up to
    # ~2k chars can never straddle past both windows that contain it.
    step, win = 2048, 4096
    for start in range(0, len(line), step):
        seg = line[start:start + win]
        if "://" in seg and CREDS_IN_URL_RE.search(seg):
            return True
    return False


def refuse_if_secrets(labeled_chunks, allow):
    """Built-in tripwire: refuse to publish likely credentials to the network.
    Reports file:line LOCATIONS only — never the matching content.
    Credential-named files are refused by name regardless of content."""
    if allow:
        return
    hits = []
    for label, text in labeled_chunks:
        base = os.path.basename(label)
        if SECRET_NAMES_RE.search(base):
            hits.append(f"{label} (credential-named file — never send these)")
            continue
        for lineno, line in enumerate(text.splitlines(), 1):
            if _line_has_secret(line):
                hits.append(f"{label}:{lineno}")
    if hits:
        msg = (
            "refusing to send — content that looks like "
            f"credentials at: {', '.join(hits[:20])}. Redact those lines, or pass "
            "--allow-secrets if they are false positives (e.g. variable names)."
        )
        _fail_exit(None, _argv_command(), "secrets", msg,
                   prose=f"ambient [secrets]: {msg}")


USAGE_MAX_BYTES = 5_000_000  # cap the ledger; trim oldest lines past this


def _retry_delay(base, headers=None):
    """Backoff with random jitter, honoring a Retry-After header (clamped to 60s)
    when present (D3). Jitter breaks the lockstep that makes 3 fan-out workers
    re-hit the limiter together (thundering herd)."""
    hint = 0.0
    if headers is not None:
        ra = headers.get("Retry-After")
        if ra:
            try:
                hint = float(ra)
            except (TypeError, ValueError):
                hint = 0.0
    delay = min(max(float(base), hint), 60.0)
    return delay + random.uniform(0, 0.5 * delay)


CACHE_DIR = os.path.expanduser("~/.config/ambient/cache")
CACHE_MAX_FILES = 4000            # LRU-ish cap; oldest pruned past this
CACHE_TTL_DEFAULT = 7 * 86400     # a cached chunk older than this is ignored


def _cache_key(model, system, chunk, max_tokens, temperature, response_format=None):
    """Content address for one chunk call (D7). MUST include model + max_tokens
    (per-model budgets differ) AND response_format — a strict-schema model shares
    the same system prompt for prose vs --json, so omitting it would serve cached
    prose into the JSON reducer or vice-versa (Codex Wave D MED)."""
    h = hashlib.sha256()
    h.update(f"{model}\0{max_tokens}\0{temperature}\0".encode())
    h.update(json.dumps(response_format, sort_keys=True).encode())
    h.update(b"\0")
    h.update(system.encode("utf-8", "replace"))
    h.update(b"\0")
    h.update(chunk.encode("utf-8", "replace"))
    return h.hexdigest()


def _cache_get(key, ttl):
    path = os.path.join(CACHE_DIR, key + ".json")
    try:
        if ttl and time.time() - os.stat(path).st_mtime > ttl:
            return None
        with open(path, encoding="utf-8") as fh:
            return json.load(fh).get("text")
    except (OSError, json.JSONDecodeError):
        return None


def _cache_put(key, text):
    try:
        _private_dir(CACHE_DIR)
        entries = os.listdir(CACHE_DIR)
        if len(entries) > CACHE_MAX_FILES:  # prune oldest ~10%
            paths = sorted(
                (os.path.join(CACHE_DIR, e) for e in entries),
                key=lambda p: os.stat(p).st_mtime if os.path.exists(p) else 0)
            for p in paths[:len(paths) // 10 + 1]:
                try:
                    os.unlink(p)
                except OSError:
                    pass
        # mkstemp: unique name (two processes caching the same key can't tear
        # one shared tmp inode — QA sweep MED) and 0600 (entries quote the
        # user's code — owner-only like the env file).
        fd, tmp = tempfile.mkstemp(dir=CACHE_DIR, prefix=".tmp-")
        try:
            with os.fdopen(fd, "w", encoding="utf-8") as fh:
                json.dump({"text": text, "ts": int(time.time())}, fh)
            os.replace(tmp, os.path.join(CACHE_DIR, key + ".json"))
        except OSError:
            try:
                os.unlink(tmp)
            except OSError:
                pass
    except OSError:
        pass


_USAGE_LOCK = threading.Lock()  # serialize the read-rewrite trim across chunk workers


def log_usage(model, usage):
    """Best-effort local metering (Ambient has no balance endpoint). Caps the
    file so it can't grow without bound over a long-lived install. The trim is a
    read-modify-rewrite, so parallel chunk workers must not run it concurrently
    or they tear the ledger — the only spend signal we have (D4)."""
    try:
        record = {
            "ts": int(time.time()),
            "model": model,
            "in": usage.get("prompt_tokens", 0),
            "out": usage.get("completion_tokens", 0),
        }
        _private_dir(os.path.dirname(USAGE_PATH))
        with _USAGE_LOCK:
            try:
                if os.stat(USAGE_PATH).st_mode & 0o077:
                    os.chmod(USAGE_PATH, 0o600)  # heal a pre-hardening ledger
                if os.path.getsize(USAGE_PATH) > USAGE_MAX_BYTES:
                    with open(USAGE_PATH, encoding="utf-8") as fh:
                        kept = fh.readlines()[-20000:]  # keep the most recent
                    with open(USAGE_PATH, "w", encoding="utf-8") as fh:
                        fh.writelines(kept)
            except OSError:
                pass
            fd = os.open(USAGE_PATH, os.O_WRONLY | os.O_CREAT | os.O_APPEND, 0o600)
            with os.fdopen(fd, "a", encoding="utf-8") as fh:
                fh.write(json.dumps(record) + "\n")
    except OSError:
        pass


def usage_exit(msg):
    """Semantic usage errors share argparse's exit code (EX_USAGE=64) so an
    agentic caller can tell 'wrong invocation' from 'runtime failure'. Under
    --json the same error is ALSO emitted as a parseable envelope (exit 64)."""
    if _json_in_argv():
        emit_json_error("usage", "usage", msg, exit_code=EXIT_USAGE)
    print(f"ambient: {msg}", file=sys.stderr)
    sys.exit(EXIT_USAGE)


class ChatError(Exception):
    def __init__(self, category, diagnosis):
        super().__init__(diagnosis)
        self.category = category
        self.diagnosis = diagnosis


class StallError(Exception):
    """The stream went silent (or hit the hard wall) mid-generation."""

    def __init__(self, message, partial="", reasoning="", hard_wall=False):
        super().__init__(message)
        self.partial = partial
        self.reasoning = reasoning
        self.hard_wall = hard_wall  # true = time cap, not a data-flow silence


def stream_completion(api_url, api_key, payload, timeout, on_delta=None):
    """Streamed chat completion. Returns (status, result): on HTTP error the
    parsed error body; on success a dict with content/reasoning/usage/
    finish_reason. Liveness = data flow: any silence longer than `timeout`
    raises StallError carrying whatever was already generated."""
    url = f"{api_url}/v1/chat/completions"
    data = json.dumps(
        dict(payload, stream=True, stream_options={"include_usage": True})
    ).encode("utf-8")
    req = urllib.request.Request(
        url,
        data=data,
        headers={
            "Authorization": f"Bearer {api_key}",
            "Content-Type": "application/json",
            "Accept": "text/event-stream",
        },
        method="POST",
    )
    start = time.time()
    last_beat = start
    last_growth = start
    last_size = 0
    beat = {"open": False}  # is an in-place status line pending a close? (B5)

    def close_beat():
        if beat["open"]:
            sys.stderr.write("\n")
            sys.stderr.flush()
            beat["open"] = False

    content, reasoning, usage, finish = [], [], None, None
    try:
        resp = urllib.request.urlopen(req, timeout=timeout)
    except urllib.error.HTTPError as err:
        body = err.read().decode("utf-8", errors="replace")
        try:
            parsed = json.loads(body)
        except json.JSONDecodeError:
            parsed = {"error": {"message": body[:2000]}}
        # Preserve a server-requested cooldown so the fan-out can honor it (D3/
        # Codex Wave D LOW) instead of re-hitting the limiter on jitter alone.
        ra = err.headers.get("Retry-After") if err.headers else None
        if ra and isinstance(parsed, dict):
            parsed["_retry_after"] = ra
        return err.code, parsed
    except urllib.error.URLError as err:
        raise NetworkError(f"cannot reach {url} ({err.reason})") from err
    except TimeoutError as err:
        raise NetworkError(f"{url} timed out connecting after {timeout}s") from err
    except (OSError, http.client.IncompleteRead) as err:
        # urlopen can also raise a bare OSError out of getresponse() — a
        # RemoteDisconnected/ConnectionReset before the headers arrive, or (on
        # py<=3.9) a socket.timeout that is NOT TimeoutError. Categorize it as
        # a network fault instead of letting it surface as [internal].
        raise NetworkError(f"cannot reach {url} ({err})") from err
    with resp:
        ctype = resp.headers.get("Content-Type", "")
        if "text/event-stream" not in ctype:
            # Endpoint answered non-streamed anyway — parse it as one body.
            try:
                raw_body = resp.read()
            except (OSError, http.client.IncompleteRead) as err:
                # A reset/timeout mid-body is a transient network fault, not a
                # crash — mirror api_request's hardening (Ambient self-audit #4).
                raise NetworkError(
                    f"connection dropped reading response from {url} "
                    f"({err})") from err
            try:
                body = json.loads(raw_body.decode("utf-8", errors="replace"))
            except json.JSONDecodeError:
                return resp.status, {"error": {"message": "non-JSON response"}}
            return resp.status, body
        terminated = False  # saw [DONE] or a finish_reason
        data_lines = []  # accumulate multi-line `data:` fields of one SSE event

        def handle_event():
            """Process one complete SSE event (its joined data payload)."""
            nonlocal usage, finish, terminated
            if not data_lines:
                return
            payload_str = "\n".join(data_lines)
            data_lines.clear()
            if payload_str.strip() == "[DONE]":
                terminated = True
                return
            try:
                obj = json.loads(payload_str)
            except json.JSONDecodeError:
                return
            if obj.get("usage"):
                usage = obj["usage"]
            for ch in obj.get("choices") or []:
                delta = ch.get("delta") or {}
                if delta.get("content"):
                    content.append(delta["content"])
                    if on_delta is not None:  # D1: live stdout streaming
                        on_delta(delta["content"])
                # Providers differ: OpenAI-style uses "reasoning_content",
                # Kimi/others stream "reasoning". Capture BOTH — dropping either
                # loses the whole thinking trace of a reasoning model.
                if delta.get("reasoning_content"):
                    reasoning.append(delta["reasoning_content"])
                if delta.get("reasoning"):
                    reasoning.append(delta["reasoning"])
                if ch.get("finish_reason"):
                    finish = ch["finish_reason"]
                    terminated = True

        while True:
            try:
                raw = resp.readline()
            except TimeoutError:
                close_beat()
                raise StallError(
                    f"stream went silent for {timeout}s "
                    f"({sum(map(len, content))} chars received before the stall)",
                    "".join(content), "".join(reasoning),
                )
            except (OSError, http.client.IncompleteRead) as err:
                # Connection reset mid-stream = truncation, not a crash — route
                # the partial through the same retry/salvage ladder as EOF.
                close_beat()
                raise StallError(
                    f"connection dropped mid-stream ({err}); "
                    f"{sum(map(len, content))} chars received",
                    "".join(content), "".join(reasoning),
                )
            if not raw:
                # EOF. A clean stream ends with [DONE] or a finish_reason; a
                # connection that just drops mid-generation is TRUNCATION, not
                # success — route it through the stall/retry/salvage ladder.
                handle_event()  # flush any buffered final event
                if not terminated:
                    close_beat()
                    raise StallError(
                        "stream closed before completion "
                        f"({sum(map(len, content))} chars received, no end marker)",
                        "".join(content), "".join(reasoning),
                    )
                break
            now = time.time()
            if now - start > HARD_WALL_S:
                close_beat()
                raise StallError(
                    f"generation exceeded the {HARD_WALL_S // 60}-minute hard wall",
                    "".join(content), "".join(reasoning), hard_wall=True,
                )
            size = sum(map(len, content)) + sum(map(len, reasoning))
            if size > last_size:
                last_size, last_growth = size, now
            elif now - last_growth > NOPROGRESS_S:
                # Bytes keep arriving but nothing useful is being produced.
                close_beat()
                raise StallError(
                    f"no new content for {NOPROGRESS_S}s despite an open stream "
                    f"({size:,} chars so far) — worker appears wedged",
                    "".join(content), "".join(reasoning),
                )
            if now - last_beat >= HEARTBEAT_S:
                # Visible liveness so a long generation never LOOKS hung. On a
                # TTY, rewrite ONE line in place (no scroll spam); off-TTY (CI
                # logs) keep newline-per-beat so lines stay greppable (B5).
                got = sum(map(len, content)) or sum(map(len, reasoning))
                phase = "writing" if content else "thinking"
                msg = (f"ambient: …{phase} ({got:,} chars, "
                       f"{int(now - start)}s elapsed)")
                # In-place only on the main thread — parallel chunk workers would
                # clobber each other's \r, so they keep newline-per-beat.
                if _stderr_is_tty() and \
                        threading.current_thread() is threading.main_thread():
                    sys.stderr.write("\r\033[K" + msg)
                    sys.stderr.flush()
                    beat["open"] = True
                else:
                    print(msg, file=sys.stderr)
                last_beat = now
            line = raw.decode("utf-8", errors="replace").rstrip("\r\n")
            if line == "":
                handle_event()  # blank line = event boundary (SSE framing)
                if terminated:
                    break
                continue
            if line.startswith(":"):
                continue  # SSE comment/keep-alive
            if line.startswith("data:"):
                # Per spec, a leading single space after the colon is stripped.
                value = line[5:]
                data_lines.append(value[1:] if value.startswith(" ") else value)
    close_beat()  # close the in-place status line so later output starts fresh
    return 200, {
        "content": "".join(content),
        "reasoning": "".join(reasoning),
        "usage": usage,
        "finish_reason": finish,
    }


def complete(api_key, api_url, model, messages, args, _stall_retried=False,
             _budget_retried=False, _fallback_retried=False,
             _budget_shrunk=False, on_delta=None):
    """One completion. Returns (content, usage, body). Raises ChatError with a
    classified diagnosis, or NetworkError. Thread-safe (used by chunk fan-out).
    Degrades gracefully WITHOUT changing the user's chosen model: budget
    escalation -> labeled best-effort reasoning draft -> diagnosed error
    (callers may then split the work across the SAME model). The stall-retry,
    budget-escalation, and (opt-in) fallback guards are INDEPENDENT so one
    firing never disables another."""
    payload = {
        "model": model,
        "messages": messages,
        "max_tokens": args.max_tokens,
        "temperature": args.temperature,
    }
    rf = getattr(args, "response_format", None)  # A4: structured output when set
    if rf:
        payload["response_format"] = rf
    kw = dict(_stall_retried=_stall_retried, _budget_retried=_budget_retried,
              _fallback_retried=_fallback_retried, _budget_shrunk=_budget_shrunk)
    try:
        # Stream to stdout only on the FIRST attempt — a stall-retry/escalation
        # restart would double-print the tail (D1).
        status, body = stream_completion(
            api_url, api_key, payload, args.timeout,
            on_delta=(on_delta if not _stall_retried else None))
    except StallError as err:
        # A DATA-FLOW silence may be a flaky worker → retry once fresh. A HARD-WALL
        # hit means the generation is simply too long to finish → do NOT restart
        # from scratch (it would re-bill and re-hit the wall); salvage immediately.
        if not err.hard_wall and not _stall_retried:
            print(
                f"ambient: {err} — retrying once on a fresh worker (same model)",
                file=sys.stderr,
            )
            return complete(
                api_key, api_url, model, messages, args,
                **{**kw, "_stall_retried": True},
            )
        if len(err.partial) > 400:
            why = "hit the time wall" if err.hard_wall else "stalled"
            print(
                f"ambient: generation {why} — salvaging the partial output already "
                "generated (marked incomplete)",
                file=sys.stderr,
            )
            salvaged = (
                "[AMBIENT NOTE: the stream ended mid-generation; this output "
                "is PARTIAL — the tail is missing.]\n\n" + err.partial
            )
            return salvaged, {}, {"salvaged_partial": True}
        raise ChatError(
            "stall",
            f"'{model}' produced almost no output before stalling ({err}). The "
            "serving workers look unhealthy — retry shortly or check: ambient models",
        )
    if status != 200:
        category, diagnosis = classify_error(status, body, api_key)
        if category == "budget" and not _budget_shrunk \
                and args.max_tokens > MIN_OUTPUT_TOKENS:
            # The server rejected our output budget outright (offline-profile
            # guess above the model's real cap). Splitting the INPUT can't fix
            # that — every chunk would resend the same doomed max_tokens — so
            # self-heal by halving the budget once (resilience sweep LOW).
            smaller = argparse.Namespace(**vars(args))
            smaller.max_tokens = max(MIN_OUTPUT_TOKENS, args.max_tokens // 2)
            print(
                f"ambient: server rejected the {args.max_tokens}-token output "
                f"budget — retrying once at {smaller.max_tokens}",
                file=sys.stderr,
            )
            return complete(
                api_key, api_url, model, messages, smaller,
                **{**kw, "_budget_shrunk": True},
            )
        if category == "model":
            # Enriching the diagnosis / choosing a fallback must never itself
            # abort the call (esp. inside a map-reduce worker thread) if the
            # models endpoint is also unhealthy — degrade gracefully.
            try:
                catalog = fetch_models(api_url, api_key)
            except (NetworkError, SystemExit):
                catalog = []
            ready = ready_model_ids(catalog)
            fb_conf = read_config_file()
            fallback_on = getattr(args, "fallback", False) or (
                (os.environ.get("AMBIENT_FALLBACK")
                 or fb_conf.get("AMBIENT_FALLBACK", "")).lower()
                in ("1", "on", "true")
            )
            if fallback_on and not _fallback_retried:
                # The chunk was already sized for `model`; only fall back to a
                # model whose context can hold the input we're about to resend
                # PLUS its own output budget + overhead, so the switch can't
                # overflow context or induce a marathon (Codex round-3 HIGH).
                input_tok = int(sum(len(m.get("content", ""))
                                    for m in messages) / CHARS_PER_TOKEN)
                alt = pick_fallback_model(catalog, model, min_context=input_tok,
                                          conf=fb_conf)
                alt_profile = model_profile(catalog, alt) if alt else None
                if alt_profile:
                    alt_budget = (alt_profile.output_budget
                                  if getattr(args, "_auto_budget", False)
                                  else min(args.max_tokens,
                                           alt_profile.max_output_length))
                    if input_tok + alt_budget + 2500 > alt_profile.context_length:
                        alt = None  # can't hold input+output — don't switch
                if alt and alt_profile:
                    cur_p = model_pricing(catalog, model)
                    alt_p = model_pricing(catalog, alt)
                    delta = (f" (${alt_p[1]:.2f}/M out vs ${cur_p[1]:.2f}/M)"
                             if cur_p and alt_p else "")
                    print(
                        f"ambient: '{model}' has no workers — falling back to "
                        f"'{alt}'{delta} (--fallback)",
                        file=sys.stderr,
                    )
                    alt_args = argparse.Namespace(**vars(args))
                    if getattr(args, "_auto_budget", False):
                        alt_args.max_tokens = alt_profile.output_budget
                    else:
                        alt_args.max_tokens = min(alt_args.max_tokens,
                                                  alt_profile.max_output_length)
                    alt_args.escalation_ceiling = alt_profile.escalation_ceiling
                    # Re-gate structured output for the fallback model — sending a
                    # strict json_schema to a model that lacks it 400s (Codex MED).
                    if getattr(alt_args, "response_format", None):
                        afeats = alt_profile.features or []
                        if "structured_outputs" in afeats:
                            pass  # keep the strict schema
                        elif "json_mode" in afeats:
                            alt_args.response_format = {"type": "json_object"}
                        else:
                            alt_args.response_format = None
                    return complete(
                        api_key, api_url, alt, messages, alt_args,
                        **{**kw, "_fallback_retried": True},
                    )
            if ready:
                diagnosis += f" READY now: {', '.join(ready)}"
        err_obj = ChatError(category, diagnosis)
        # body may be a valid non-object JSON (str/list/number) on an error
        # response — guard before .get so it never AttributeErrors to [internal].
        if isinstance(body, dict) and body.get("_retry_after"):
            err_obj.retry_after = body["_retry_after"]
        raise err_obj
    if "content" in body and "choices" not in body:
        # Streamed result (normal path).
        content = body.get("content")
        reasoning_text = (body.get("reasoning") or "").strip()
        finish = body.get("finish_reason")
    else:
        # Classic JSON body (endpoint ignored streaming).
        try:
            choice = body["choices"][0]
            message = choice["message"]
        except (KeyError, IndexError, TypeError):
            raise ChatError(
                "unknown",
                "unexpected response shape: "
                f"{redact(json.dumps(body)[:800], api_key)}",
            )
        content = message.get("content")
        reasoning_text = (
            message.get("reasoning_content") or message.get("reasoning") or ""
        ).strip()
        finish = choice.get("finish_reason")
        # Surface finish_reason at the top level so every caller's truncation
        # check works on both the streamed and classic body shapes.
        body.setdefault("finish_reason", finish)
    usage = body.get("usage") or {}
    if not usage and isinstance(content, str):
        # Ambient's stream does not reliably send a usage object (probe finding),
        # so local metering was blind for most calls. Estimate tokens from char
        # counts (reasoning counts as output) — marked _estimated. Far better for
        # `ambient usage` than silently recording nothing.
        in_tok = int(sum(len(m.get("content", "")) for m in messages)
                     / CHARS_PER_TOKEN)
        out_tok = int((len(content) + len(reasoning_text)) / CHARS_PER_TOKEN)
        usage = {"prompt_tokens": in_tok, "completion_tokens": out_tok,
                 "_estimated": True}
    if usage:
        log_usage(model, usage)
    if not isinstance(content, str) or not content.strip():
        # All budget spent on reasoning, nothing emitted: escalate ONCE, bounded.
        # The ceiling is the MODEL's real max output (from its profile), not a
        # flat 65536 — and we now start from a well-sized budget, so bump gently.
        ceiling = getattr(args, "escalation_ceiling", MAX_AUTO_BUDGET_TOKENS)
        if not _budget_retried and args.max_tokens < ceiling:
            new_budget = min(max(args.max_tokens * 2, args.max_tokens + 16384),
                             ceiling)
            print(
                f"ambient: model spent all {args.max_tokens} tokens reasoning with "
                f"no final answer — retrying once with a {new_budget}-token budget "
                "(input is re-billed)",
                file=sys.stderr,
            )
            bigger = argparse.Namespace(**vars(args))
            bigger.max_tokens = new_budget
            return complete(
                api_key, api_url, model, messages, bigger,
                **{**kw, "_budget_retried": True},
            )
        reasoning = reasoning_text
        input_chars = sum(len(m.get("content", "")) for m in messages)
        if len(reasoning) > 200 and input_chars < 20_000:
            # Small input, so splitting can't help: the thinking exists even
            # though the answer doesn't — a labeled draft beats an empty hand.
            print(
                "ambient: no final answer — returning the model's reasoning as "
                "a labeled best-effort draft",
                file=sys.stderr,
            )
            draft = (
                "[AMBIENT NOTE: the model emitted reasoning but no final answer. "
                "This is a best-effort draft assembled from that reasoning — "
                "treat with extra skepticism.]\n\n" + reasoning
            )
            return draft, usage, {"salvaged_partial": True}
        raise ChatError(
            "empty",
            f"'{model}' produced no final content even after budget escalation "
            f"(finish_reason={finish}).",
        )
    if finish == "length":
        print(
            f"ambient: output hit the {args.max_tokens}-token cap and may be "
            "truncated — rerun with a larger --max-tokens if it ends abruptly",
            file=sys.stderr,
        )
    # Record which model ACTUALLY served this result: an opt-in --fallback
    # switch happens in a recursive frame, and a --json consumer must not be
    # told the content came from the model that had no workers (Codex final MED).
    if isinstance(body, dict):
        body.setdefault("_served_model", model)
    return content.strip(), usage, body


def chat(api_key, api_url, model, messages, args, kind="ask"):
    """Single-shot completion printed to stdout (CLI convenience wrapper).
    Live-streams to an interactive terminal (D1)."""
    want_json = getattr(args, "json", False)
    live_stream = sys.stdout.isatty() and not args.raw and not want_json
    streamed_parts = []

    def on_delta(piece):
        sys.stdout.write(redact(piece, api_key))
        sys.stdout.flush()
        streamed_parts.append(piece)

    try:
        content, usage, body = complete(
            api_key, api_url, model, messages, args,
            on_delta=(on_delta if live_stream else None))
    except ChatError as err:
        if streamed_parts:
            sys.stdout.write("\n")
            sys.stdout.flush()
        _fail(args, kind, err, api_key)
    if want_json:
        served = body.get("_served_model", model)
        emit_json(
            kind, model=served, api_key=api_key, content=content,
            partial=bool(body.get("salvaged_partial")),
            reason="output salvaged" if body.get("salvaged_partial") else None,
            usage=body.get("usage"), finish_reason=body.get("finish_reason"),
            extra=({"requested_model": model} if served != model else None),
            allow_partial=getattr(args, "allow_partial", False))
        return
    if args.raw:
        print(redact(json.dumps(body, indent=2), api_key))
        return
    clean_stream = bool(streamed_parts) and "".join(streamed_parts).strip() == content
    if not clean_stream and streamed_parts:
        sys.stdout.write("\n[ambient: stream restarted — full result below]\n")
        sys.stdout.flush()
    render_result(
        content,
        bool(body.get("salvaged_partial")) or body.get("finish_reason") == "length",
        "output was salvaged/truncated", args, api_key, usage, model,
        already_streamed=clean_stream,
    )


STDIN_WAIT_S = 10  # how long to wait for piped data before treating stdin as empty


def read_stdin_if_piped():
    if sys.stdin.isatty():
        return ""
    wait_s = float(STDIN_WAIT_S)
    raw_wait = os.environ.get("AMBIENT_STDIN_WAIT")
    if raw_wait:
        try:
            wait_s = max(0.1, float(raw_wait))
        except ValueError:
            pass
    # Guard against an IDE/CI wrapper that holds stdin open with NO data: wait
    # briefly for readability instead of blocking forever. A real pipe (git diff,
    # a file redirect) is readable immediately.
    try:
        ready, _, _ = select.select([sys.stdin], [], [], wait_s)
        if not ready:
            print(
                f"ambient: stdin produced no data within {wait_s:g}s — proceeding "
                "without it (slow pipe? set AMBIENT_STDIN_WAIT=<seconds>)",
                file=sys.stderr,
            )
            return ""
    except (OSError, ValueError):
        pass  # select unsupported here — fall through to a plain read
    # Read BYTES and decode lossily: `git diff` on latin-1 sources or log data
    # with stray bytes must degrade, not crash text-mode stdin.read() into the
    # [internal] shield (resilience sweep HIGH, verified repro). Mirrors
    # read_files' handling.
    buf = getattr(sys.stdin, "buffer", None)
    if buf is not None:
        raw = buf.read(ABS_MAX_CHARS * 4 + 1)  # bytes cap >= char cap for UTF-8
        if b"\x00" in raw[:8192]:
            print("ambient: stdin looks binary — decoding lossily (NUL bytes "
                  "stripped)", file=sys.stderr)
            raw = raw.replace(b"\x00", b"")
        data = raw.decode("utf-8", errors="replace")
    else:  # a test harness replaced stdin with a text stream
        try:
            data = sys.stdin.read(ABS_MAX_CHARS + 1)
        except UnicodeDecodeError:
            _fail_exit(None, _argv_command(), "input",
                       "stdin is not valid UTF-8 text")
    if len(data) > ABS_MAX_CHARS:
        _fail_exit(
            None, _argv_command(), "input",
            f"stdin exceeds {ABS_MAX_CHARS:,} chars (~$10+ of input tokens) "
            "— split the job (e.g. per-directory) as a cost sanity check."
        )
    return data


def warn_if_stdin_ignored(hint):
    """One stderr note when piped data exists but this invocation will not read
    it — the user pays for a wrong-context answer otherwise, and silence was
    the bug (resilience sweep MED). Zero-timeout peek; never blocks. EOF is
    'readable' with zero bytes (`< /dev/null` from any agent harness), so only
    warn when bytes are ACTUALLY waiting — a false note in front of --json
    output breaks machine consumers (live-battery finding)."""
    try:
        if sys.stdin.isatty():
            return
        ready, _, _ = select.select([sys.stdin], [], [], 0)
        if not ready:
            return
        if fcntl is None:
            return  # can't count bytes portably — stay silent over crying wolf
        import array
        import termios
        buf = array.array("i", [0])
        fcntl.ioctl(sys.stdin.fileno(), termios.FIONREAD, buf)
        if buf[0] > 0:
            print(
                f"ambient: note — data is waiting on stdin but was NOT read "
                f"({hint})",
                file=sys.stderr,
            )
    except (OSError, ValueError, ImportError, AttributeError):
        pass


def read_files(paths):
    """Returns [(path, content)] pairs. Oversized inputs are map-reduced later,
    not refused. Skips unreadable/non-regular/binary/empty files with a warning
    rather than aborting the batch or hanging on a device/FIFO."""
    chunks = []
    total = 0
    for path in paths:
        try:
            st = os.lstat(path)
        except OSError as err:
            print(f"ambient: skipping {path} ({err})", file=sys.stderr)
            continue
        if not stat.S_ISREG(st.st_mode):
            # A directory, FIFO, or device (/dev/zero would read forever).
            print(f"ambient: skipping {path} (not a regular file)", file=sys.stderr)
            continue
        try:
            with open(path, "rb") as fh:
                # Bounded read: a file that grows during read can't blow the cap.
                raw = fh.read(ABS_MAX_CHARS - total + 1)
        except OSError as err:
            print(f"ambient: skipping {path} ({err})", file=sys.stderr)
            continue
        if b"\x00" in raw[:8192]:
            print(f"ambient: skipping {path} (looks binary)", file=sys.stderr)
            continue
        text = raw.decode("utf-8", errors="replace")
        total += len(text)
        if total > ABS_MAX_CHARS:
            _fail_exit(
                None, _argv_command(), "input",
                f"input exceeds {ABS_MAX_CHARS:,} chars at {path} "
                "(~$10+ of input tokens) — split the job as a cost sanity check."
            )
        if not text.strip():
            print(f"ambient: skipping {path} (empty)", file=sys.stderr)
            continue
        chunks.append((path, text))
    return chunks


def files_block(chunks):
    return "\n\n".join(f"===== FILE: {p} =====\n{c}" for p, c in chunks)


def _chunk_ranges(chunk_text):
    """Extract 'path lines a-b' coverage labels from a packed chunk's block
    headers, so a failed chunk names exactly which file:lines went unreviewed
    (A8 coverage manifest)."""
    out = []
    for m in re.finditer(r"===== (.+?) =====", chunk_text or ""):
        out.append(m.group(1).strip())
    return out


def build_code_map(labeled, budget=4000):
    """A compact repo map — file list + top-level signatures — prepended to
    EVERY chunk so a caller in one chunk and its callee in another can still be
    cross-checked (A7). Budgeted so it can't push a chunk past context."""
    out = ["REPO MAP (signatures only — full bodies may live in another chunk):"]
    for label, text in labeled:
        path = label.split(" [")[0]
        sigs = []
        if path.endswith(".py"):
            raw = re.sub(r"^ *\d+\| ", "", text, flags=re.M)
            try:
                for n in ast.parse(raw).body:
                    if isinstance(n, (ast.FunctionDef, ast.AsyncFunctionDef)):
                        params = ", ".join(a.arg for a in n.args.args)
                        sigs.append(f"def {n.name}({params})")
                    elif isinstance(n, ast.ClassDef):
                        sigs.append(f"class {n.name}")
            except (SyntaxError, ValueError):
                pass
        out.append(f"  {path}: " + (", ".join(sigs) if sigs
                                    else f"{len(text):,} chars"))
    return "\n".join(out)[:budget]


def _py_break_lines(text):
    """1-based line numbers that start a TOP-LEVEL def/class in a (possibly
    gutter-prefixed) Python source — preferred chunk boundaries so a function is
    never cut mid-body (A6). Empty set on non-.py or parse failure → the caller
    falls back to the plain line split. Line count is preserved 1:1."""
    raw = re.sub(r"^ *\d+\| ", "", text, flags=re.M)  # strip any gutters
    try:
        tree = ast.parse(raw)
    except (SyntaxError, ValueError):
        return set()
    return {n.lineno for n in getattr(tree, "body", [])
            if hasattr(n, "lineno")}


def density_factor(text):
    """How much char-based sizing must SHRINK for token-dense text. All budgets
    assume CHARS_PER_TOKEN=3.2 (code/English); CJK runs ~1-1.5 chars/token, so
    a 120k-char Chinese doc is 2-3x the assumed tokens and would 400 on context
    at 'correct' char sizing (resilience sweep MED). Sampled, linear blend:
    pure-ASCII → 1.0, heavily-non-ASCII → ~2.6."""
    if not text:
        return 1.0
    sample = text[:200_000]
    non_ascii = sum(1 for ch in sample if ord(ch) > 127)
    return 1.0 + (non_ascii / len(sample)) * 1.6


def pack_chunks(labeled_chunks, chunk_chars=CHUNK_CHARS):
    """Pack (label, text) items into chunk strings <= chunk_chars. Whole items
    stay together; oversize items split on line boundaries — biased to land at
    top-level def/class boundaries for .py so a function is never cut mid-body
    (A6) — and any SINGLE line longer than the budget is hard-split into char
    ranges so no chunk can ever exceed the budget. Guarantees every chunk fits."""
    # A block is at minimum "===== <label> [line N chars X-Y] =====\n" + 1 char;
    # if the requested budget can't even hold a file's header, raise it to the
    # irreducible minimum so a chunk is still GUARANTEED to fit chunk_chars
    # (never a silent overflow). No-op for real budgets (≥14k) vs paths (<260).
    longest = max((len(lbl) for lbl, _ in labeled_chunks), default=0)
    chunk_chars = max(chunk_chars, longest + 200)
    pieces = []  # (label, segment), each segment fits after its block header
    for label, text in labeled_chunks:
        # Header is "===== <label> [lines a-b] =====\n" (or "[line N chars X-Y]"
        # for a hard-split minified line, whose offsets can be 8 digits). Reserve
        # the label + a generous 80 for that suffix so header+body <= chunk_chars.
        # The clamp above guarantees this stays positive; do NOT floor it higher
        # or a tiny budget would overflow (Codex A+B MED).
        body_budget = max(1, chunk_chars - len(label) - 80)
        if len(text) <= body_budget:
            pieces.append((label, text))
            continue
        breaks = _py_break_lines(text) if label.endswith(".py") or ".py " in label \
            else set()
        buf, buf_len, first = [], 0, 1
        lineno = 0
        for ln in text.splitlines(keepends=True):
            lineno += 1
            if len(ln) > body_budget:
                if buf:
                    pieces.append(
                        (f"{label} [lines {first}-{lineno - 1}]", "".join(buf)))
                    buf, buf_len = [], 0
                for j in range(0, len(ln), body_budget):
                    seg = ln[j:j + body_budget]
                    pieces.append(
                        (f"{label} [line {lineno} chars {j}-{j + len(seg)}]", seg))
                first = lineno + 1
                continue
            # Prefer to break at a top-level definition once we're past ~60% of
            # budget, so functions stay whole; hard-break at the budget as before.
            at_def_boundary = (lineno in breaks and buf_len >= body_budget * 0.6)
            if buf and (buf_len + len(ln) > body_budget or at_def_boundary):
                pieces.append((f"{label} [lines {first}-{lineno - 1}]", "".join(buf)))
                buf, buf_len, first = [], 0, lineno
            buf.append(ln)
            buf_len += len(ln)
        if buf:
            pieces.append((f"{label} [lines {first}-{lineno}]", "".join(buf)))
    chunks, cur, cur_len = [], [], 0
    for label, text in pieces:
        block = f"===== {label} =====\n{text}"
        if cur and cur_len + len(block) + 2 > chunk_chars:
            chunks.append("\n\n".join(cur))
            cur, cur_len = [], 0
        cur.append(block)
        cur_len += len(block) + 2
    if cur:
        chunks.append("\n\n".join(cur))
    return chunks


def _resolve_parallel(args):
    """Fan-out width: `--parallel` flag > AMBIENT_MAX_PARALLEL env > the
    MAX_PARALLEL_CHUNKS default. Clamped to 1-16 — be kind to miners; a
    typo'd '1000' must not stampede the network. A bad value falls back to
    the next source instead of crashing a paid run."""
    for raw in (getattr(args, "parallel", None),
                os.environ.get("AMBIENT_MAX_PARALLEL")):
        if raw is None or raw == "":
            continue
        try:
            return max(1, min(16, int(raw)))
        except (TypeError, ValueError):
            continue
    return MAX_PARALLEL_CHUNKS


def run_map_reduce(api_key, api_url, model, map_system, chunks, args,
                   synth_system, reduce_budget, reducer=None, code_map="",
                   gate=None, cancel_event=None):
    """Fan chunk calls out in parallel, then reduce with BUDGET-AWARE synthesis.
    Returns (final_text, partial, reason). Never discards paid-for work: failed
    or truncated chunks are counted as coverage gaps and surfaced; a synthesis
    failure falls back to the raw per-chunk reports rather than exiting.
    If `reducer(chunk_texts)` is given, it replaces the LLM synthesis with a
    deterministic Python merge (A5: structured findings dedup, no re-billed
    synthesis call). `gate` (a shared threading.Semaphore, consensus lane)
    caps TOTAL concurrent complete() calls ACROSS sibling pools — without it
    N models × N chunks each = width² simultaneous network calls (be kind to
    miners). A set `cancel_event` stops chunks from STARTING: once the caller
    is unwinding (fatal sibling error / Ctrl-C), no new work gets billed."""
    total = sum(map(len, chunks))
    width = min(_resolve_parallel(args), len(chunks))
    print(
        f"ambient: input {total:,} chars → {len(chunks)} chunks → parallel calls "
        f"(max {width} at once) + budget-aware synthesis "
        f"(~{total // 3:,} input tokens)",
        file=sys.stderr,
    )

    map_note = (map_system
                + (f"\n\n{code_map}" if code_map else "")
                + f"\n\n(You are seeing chunk {{i}} of {len(chunks)} of a larger "
                "input. File boundaries may be split across chunks — flag suspected "
                "split artifacts as such instead of guessing.)")

    use_cache = not getattr(args, "no_cache", False)
    cache_ttl = getattr(args, "cache_ttl", None) or CACHE_TTL_DEFAULT
    cache_hits = [0]

    def cancelled():
        return cancel_event is not None and cancel_event.is_set()

    def work(i):
        if cancelled():
            # The caller is unwinding — starting this chunk would bill work
            # whose result gets discarded anyway.
            raise ChatError("cancelled",
                            "fan-out cancelled before this chunk started")
        system = map_note.replace("{i}", str(i + 1))
        messages = [
            {"role": "system", "content": system},
            {"role": "user", "content": chunks[i]},
        ]
        # D7: content-addressed cache — a re-run after a Ctrl-C / failed synthesis
        # / PARTIAL exit re-bills only the MISSING chunks, not the whole fan-out.
        key = _cache_key(model, system, chunks[i], args.max_tokens,
                         args.temperature, getattr(args, "response_format", None))
        if use_cache:
            cached = _cache_get(key, cache_ttl)
            if cached is not None:
                cache_hits[0] += 1
                return cached, False
        # Ride out transient rate-limits during a fan-out instead of turning a
        # brief 429 burst into a permanent coverage gap. The gate (when shared
        # by a consensus caller) is held ONLY around the network call itself.
        hold = gate if gate is not None else contextlib.nullcontext()
        for attempt in range(3):
            try:
                with hold:
                    if cancelled():
                        raise ChatError(
                            "cancelled",
                            "fan-out cancelled while waiting for a slot")
                    text, _usage, body = complete(
                        api_key, api_url, model, messages, args)
                # A length-truncated chunk is INCOMPLETE coverage — flag it and
                # never cache it as a full result (Codex Wave D HIGH).
                partial = (bool(body.get("salvaged_partial"))
                           or body.get("finish_reason") == "length")
                # If the network fell back to a DIFFERENT model, do not cache its
                # answer under the requested model's key — a later run of the
                # requested model would be served the wrong model's result.
                served = body.get("_served_model", model)
                if use_cache and not partial and served == model:
                    _cache_put(key, text)
                return text, partial
            except ChatError as err:
                # A retry is new billed work too — don't start one mid-cancel.
                if err.category == "rate" and attempt < 2 and not cancelled():
                    # Honor a server Retry-After if present, else jittered backoff
                    # so parallel workers don't retry in lockstep.
                    ra = getattr(err, "retry_after", None)
                    hdrs = {"Retry-After": ra} if ra else None
                    time.sleep(_retry_delay(3 * (attempt + 1), hdrs))
                    continue
                raise

    results = [None] * len(chunks)  # (text, is_partial) or None on failure
    errors = []
    missed_ranges = []  # A8: exact file:line ranges left unreviewed
    pool = concurrent.futures.ThreadPoolExecutor(max_workers=width)
    try:
        futures = {pool.submit(work, i): i for i in range(len(chunks))}
        for fut in concurrent.futures.as_completed(futures):
            i = futures[fut]
            try:
                results[i] = fut.result()
            except Exception as err:  # noqa: BLE001 — one chunk must never
                # abort the fan-out; record it as a coverage gap and continue.
                cov = _chunk_ranges(chunks[i])
                missed_ranges.extend(cov)
                where = f" [{'; '.join(cov)}]" if cov else ""
                errors.append(f"chunk {i + 1}{where}: {type(err).__name__}: {err}")
    except KeyboardInterrupt:
        # Cancel QUEUED chunks so Ctrl-C feels instant instead of waiting on the
        # whole backlog (D4). in-flight calls still drain in finally.
        print("\nambient: cancelling…", file=sys.stderr)
        try:
            pool.shutdown(wait=False, cancel_futures=True)  # py3.9+
        except TypeError:
            pool.shutdown(wait=False)                       # py3.8
        raise
    finally:
        pool.shutdown(wait=True)
    if cache_hits[0]:
        print(f"ambient: {cache_hits[0]}/{len(chunks)} chunks served from cache "
              "(not re-billed)", file=sys.stderr)
    done = [(i, r[0]) for i, r in enumerate(results) if r]
    truncated = [i + 1 for i, r in enumerate(results) if r and r[1]]
    for i, r in enumerate(results):
        if r and r[1]:
            missed_ranges.extend(_chunk_ranges(chunks[i]))
    if not done:
        raise ChatError(
            "stall",
            f"all {len(chunks)} chunk calls failed — first: "
            f"{errors[0] if errors else 'unknown'}",
        )

    gap = ""
    if errors:
        gap += (
            f"\n\nCOVERAGE GAP: {len(errors)} chunk(s) FAILED (missing entirely): "
            f"{'; '.join(errors)}. State this gap at the TOP and do NOT issue a "
            "clean/SHIP verdict."
        )
    if truncated:
        gap += (
            f"\n\nCOVERAGE GAP: chunk(s) {truncated} were TRUNCATED (partial). "
            "Treat their coverage as incomplete and do NOT issue a clean verdict."
        )

    def merge(texts):
        body = "\n\n".join(
            f"----- PART {k + 1} -----\n{t}" for k, t in enumerate(texts))
        messages = [
            {"role": "system", "content": synth_system},
            {"role": "user", "content": body + gap},
        ]
        try:
            text, _u, resp_body = complete(api_key, api_url, model, messages,
                                           args)
            # The SYNTHESIS tier can truncate too: a length-cut or salvaged
            # merge is NOT a clean synthesis. Flag it exactly like a truncated
            # map chunk so the final verdict can never masquerade as complete.
            ok = not (resp_body.get("finish_reason") == "length"
                      or bool(resp_body.get("salvaged_partial")))
            return text, ok
        except (ChatError, NetworkError):
            # Never throw away paid work: fall back to the raw concatenation.
            return body, False

    texts = [r for _, r in done]
    # Deterministic Python reduce (structured mode): no LLM synthesis, no
    # re-billed merge call — just parse + dedupe the chunk findings.
    if reducer is not None:
        final = reducer(texts)
        partial = bool(errors or truncated)
        reasons = []
        if errors:
            reasons.append(f"{len(errors)} of {len(chunks)} chunks failed")
        if truncated:
            reasons.append(f"{len(truncated)} chunk(s) truncated")
        if missed_ranges:
            reasons.append("UNREVIEWED: " + "; ".join(dict.fromkeys(missed_ranges)))
        if partial:
            print(f"[ambient map-reduce: PARTIAL — {'; '.join(reasons)}]",
                  file=sys.stderr)
        return final, partial, "; ".join(reasons)
    synth_failed = False
    # The synthesis prompt is system + gap + per-part headers, not just the
    # parts — reserve that overhead so a merge call can't blow the context.
    overhead = len(synth_system) + len(gap) + 200 * max(1, len(texts))
    # No 20k floor: a small-window model (e.g. gemma, single≈17.6k) would then
    # get a merge budget above its own window → doomed, re-billed synthesis
    # calls (Ambient self-audit #1). Respect the model's real budget.
    effective_budget = max(1_000, reduce_budget - overhead)
    # Budget-aware hierarchical reduce: pack partials into groups that each fit
    # the reduce budget (by CHARS, not by count), collapsing tier by tier.
    while len(texts) > 1 and sum(len(t) for t in texts) > effective_budget:
        groups, cur, cur_len = [], [], 0
        for t in texts:
            if cur and cur_len + len(t) > effective_budget:
                groups.append(cur)
                cur, cur_len = [], 0
            cur.append(t)
            cur_len += len(t)
        if cur:
            groups.append(cur)
        if all(len(g) == 1 for g in groups):
            break  # can't reduce further (each partial already huge)
        new_texts = []
        for g in groups:
            if len(g) == 1:
                new_texts.append(g[0])
            else:
                merged, ok = merge(g)
                synth_failed = synth_failed or not ok
                new_texts.append(merged)
        texts = new_texts
    if len(texts) > 1:
        final, ok = merge(texts)
        synth_failed = synth_failed or not ok
    else:
        final = texts[0]

    partial = bool(errors or truncated or synth_failed)
    reasons = []
    if errors:
        reasons.append(f"{len(errors)} of {len(chunks)} chunks failed")
    if truncated:
        reasons.append(f"{len(truncated)} chunk(s) truncated")
    if synth_failed:
        reasons.append("synthesis was incomplete (truncated or fell back to "
                       "raw concatenation)")
    if missed_ranges:
        reasons.append("UNREVIEWED: " + "; ".join(dict.fromkeys(missed_ranges)))
    if partial:
        print(
            f"[ambient map-reduce: PARTIAL — {'; '.join(reasons)}]",
            file=sys.stderr,
        )
    return final, partial, "; ".join(reasons)


def render_result(text, partial, reason, args, api_key, usage=None, model=None,
                  already_streamed=False):
    """Single place that prints a result and sets the exit code. Partial/
    incomplete results get a loud header and a non-zero exit unless the caller
    passed --allow-partial, so a truncated audit can never masquerade as clean.
    `already_streamed` = the body was live-streamed to stdout (D1), so don't
    reprint it — just close the line, warn, and set the exit code."""
    if partial:
        header = (
            paint("⚠ PARTIAL / INCOMPLETE RESULT", "1;33")
            + f" — {reason}. This is NOT a clean pass; "
            "re-run (optionally with a larger --max-tokens/--timeout, or a bigger-"
            "context model) or pass --allow-partial to accept.\n\n"
        )
        if already_streamed:
            sys.stdout.write("\n")
            sys.stdout.flush()
            print(redact(header.strip(), api_key), file=sys.stderr)
        else:
            print(redact(header + text, api_key))
        if not getattr(args, "allow_partial", False):
            sys.exit(EXIT_PARTIAL)
        return
    if already_streamed:
        if not text.endswith("\n"):
            sys.stdout.write("\n")
            sys.stdout.flush()
    else:
        print(redact(text, api_key))
    if usage and model:
        print(
            f"\n[ambient {model} | in={usage.get('prompt_tokens')} "
            f"out={usage.get('completion_tokens')} tokens]",
            file=sys.stderr,
        )


def emit_json(kind, *, model, api_key="", content=None, findings=None,
              verdict=None, partial=False, reason=None, usage=None,
              finish_reason=None, extra=None, allow_partial=False,
              exit_now=True):
    """THE machine-readable sink (D2, unified): every --json surface — ask,
    code, audit, consensus, build, single-shot or map-reduce — emits this one
    shape, so an orchestrator never special-cases how a result was computed
    (arch sweep: three divergent envelopes). schema_version bumps on any
    breaking change. Returns the exit code; exits itself unless exit_now=False."""
    truncated = finish_reason == "length"
    partial = bool(partial or truncated)
    if truncated:
        reason = (reason + "; " if reason else "") + "output hit the token cap"
    code = EXIT_PARTIAL if (partial and not allow_partial) else 0
    env = {
        "schema_version": 1,
        "kind": kind,
        "status": "partial" if partial else "ok",
        "model": model,
        "partial": partial,
        "coverage_gap": reason or None,
        "finish_reason": finish_reason,
        "usage": usage,
        "exit_code": code,
    }
    if content is not None:
        env["content"] = content
    if findings is not None:
        env["findings"] = findings
        env["verdict"] = verdict
    if extra:
        env.update(extra)
    print(redact(json.dumps(env, indent=2), api_key))
    if code and exit_now:
        sys.exit(code)
    return code


def _json_mode(args):
    """True when the caller asked for the machine envelope: --json on
    ask/code/build, or audit's --format json (its --json is a const alias)."""
    return bool(getattr(args, "json", False)) \
        or getattr(args, "format", None) == "json"


def _json_in_argv():
    """Best-effort json-mode detection from sys.argv, for usage_exit (which runs
    before/without a parsed args object)."""
    argv = sys.argv[1:]
    if "--json" in argv or "--format=json" in argv:
        return True
    return any(a == "--format" and argv[i + 1] == "json"
               for i, a in enumerate(argv[:-1]))


def emit_json_error(kind, category, diagnosis, api_key="", exit_code=1):
    """Error twin of emit_json: an orchestrator that asked for --json must get
    a PARSEABLE failure on stdout ({"status": "error", …}), never a bare
    stderr line it has to scrape. Same schema_version; exits with exit_code
    (1 for a runtime failure, 64 for a usage error)."""
    env = {
        "schema_version": 1,
        "kind": kind,
        "status": "error",
        "category": category,
        "diagnosis": redact(str(diagnosis), api_key),
        "exit_code": exit_code,
    }
    # `ambient map --json` is a JSONL stream (one object per line) — its
    # terminal error envelope must stay ONE line like every item envelope,
    # or a line-by-line consumer breaks on the very failure it must parse.
    indent = None if kind == "map" else 2
    print(redact(json.dumps(env, indent=indent), api_key))
    sys.exit(exit_code)


def _fail(args, kind, err, api_key=""):
    """The one exit for a ChatError/NetworkError CAUGHT inside a task handler
    (chat/ask/audit/build): under --json the orchestrator gets the machine
    envelope — parseable, redacted, exit 1 — instead of an unredacted prose
    line it has to scrape; the prose path stays byte-identical for humans.
    Errors that ESCAPE to main() already get this split there."""
    category = getattr(err, "category", "network")
    diagnosis = getattr(err, "diagnosis", None) or str(err)
    if _json_mode(args):
        emit_json_error(kind, category, diagnosis, api_key)  # exits 1
    sys.exit(f"ambient [{category}]: {diagnosis}")


def _argv_command():
    """The task command named on the command line, for envelope `kind` at exit
    sites with no parsed args object (shared helpers, argparse itself).
    Restricted to the --json-capable commands so `kind` stays a closed
    vocabulary; anything else reports as 'usage'."""
    for tok in sys.argv[1:]:
        if not tok.startswith("-"):
            return tok if tok in ("ask", "code", "audit", "build", "map") \
                else "usage"
    return "usage"


def _fail_exit(args, kind, category, msg, exit_code=1, api_key="", prose=None):
    """The one exit for every OTHER failure reachable under a --json-capable
    command (input refusals, git preconditions, spend gates, distillation
    gaps) — the failure contract is TOTAL: a --json caller always gets the
    machine envelope, never a bare stderr line to scrape. `args=None` sniffs
    sys.argv for helpers that run before/without a parsed args object. The
    prose path prints exactly what every prior release printed (default
    'ambient: {msg}'; pass `prose` where the historical line differs).
    exit_code is honored on BOTH paths: runtime failures keep the historical
    sys.exit(<string>) convention (stderr + exit 1); anything else (e.g.
    EX_USAGE=64) prints the same prose to stderr, then exits with that code —
    a usage error must not report as a runtime failure just because the
    caller didn't ask for --json."""
    wants_json = _json_mode(args) if args is not None else _json_in_argv()
    if wants_json:
        emit_json_error(kind, category, msg, api_key, exit_code=exit_code)
    prose_line = prose if prose is not None else f"ambient: {msg}"
    if exit_code == 1:
        sys.exit(prose_line)
    print(prose_line, file=sys.stderr)
    sys.exit(exit_code)


def _humanize_ctx(n):
    try:
        n = int(n)
    except (TypeError, ValueError):
        return "?"
    return f"{n // 1000}K" if n >= 1000 else str(n)


def _model_badges(m):
    feats = m.get("supported_features") or []
    ins = m.get("input_modalities") or []
    badges = []
    if "reasoning" in feats:
        badges.append("reason")
    if "image" in ins or "video" in ins:
        badges.append("vision")
    if "tools" in feats:
        badges.append("tools")
    if "structured_outputs" in feats or "json_mode" in feats:
        badges.append("json")
    return ",".join(badges)


def format_model_line(m, chat_default, code_default, note=None, hidden=False):
    pricing = m.get("pricing") or {}
    flag = paint("READY", "32") if m.get("is_ready") else "  ·  "
    marks = []
    if m["id"] == chat_default:
        marks.append("*chat")
    if m["id"] == code_default:
        marks.append("*code")
    if hidden:
        marks.append("hidden")
    mark = f"  {','.join(marks)}" if marks else ""
    name = (m.get("name") or "").strip()
    try:
        pin = f"${float(pricing.get('input', 0)):>5.2f}"
        pout = f"${float(pricing.get('output', 0)):>6.2f}"
    except (TypeError, ValueError):
        pin, pout = "$   ?", "$    ?"
    badges = _model_badges(m)
    line = (
        f"{flag}  {m['id']:40} {_humanize_ctx(m.get('context_length')):>5}ctx  "
        f"{pin}/M in {pout}/M out  {badges:<20}{mark}"
        + (f"   {name}" if name and name.lower() not in m["id"].lower() else "")
    )
    if note:
        line += f"   · {note[:40]}"
    return line


def _dedupe_catalog(models):
    """Collapse near-duplicate GLM-5.1 aliases (same pricing/window, different
    ids) into the primary so the storefront isn't cluttered (B6)."""
    ALIAS_OF = {"zai-org/GLM-5.1-FP8": "ambient/large"}
    seen_alias = {m["id"] for m in models}
    out = []
    for m in models:
        primary = ALIAS_OF.get(m["id"])
        if primary and primary in seen_alias:
            continue  # drop the alias if its primary is also listed
        out.append(m)
    return out


def cmd_models(args, api_key, api_url, conf):
    models = [m for m in _dedupe_catalog(fetch_models(api_url, api_key))
              if isinstance(m, dict) and m.get("id")]
    models.sort(key=lambda m: (not m.get("is_ready"), m.get("id") or ""))
    chat_default = resolve_model(argparse.Namespace(model=None), conf, "chat")
    code_default = resolve_model(argparse.Namespace(model=None), conf, "code")
    configured = bool(resolve_key_and_backend(conf)[0])
    allow, hide, show, notes = curation(conf)
    hidden_ids = {m["id"] for m in models
                  if is_hidden(m["id"], allow, hide, show)}
    show_all = getattr(args, "all", False)
    if hidden_ids and len(hidden_ids) == len(models) and not show_all:
        print("ambient: your curation hides every model — showing all "
              "(fix: ambient curate reset)", file=sys.stderr)
        show_all = True
    visible = [m for m in models if show_all or m["id"] not in hidden_ids]
    if getattr(args, "json", False):
        out = [{
            "id": m["id"], "name": m.get("name"),
            "ready": bool(m.get("is_ready")),
            "context_length": m.get("context_length"),
            "max_output_length": m.get("max_output_length"),
            "pricing": m.get("pricing"),
            "features": m.get("supported_features") or [],
            "is_chat_default": m["id"] == chat_default,
            "is_code_default": m["id"] == code_default,
            "hidden": m["id"] in hidden_ids,
            "note": notes.get(m["id"]) or None,
        } for m in visible]
        print(json.dumps({"schema_version": 1, "configured": configured,
                          "models": out}, indent=2))
        return
    for m in visible:
        print(format_model_line(m, chat_default, code_default,
                                note=notes.get(m["id"]),
                                hidden=m["id"] in hidden_ids))
    print(
        f"\nDefaults: chat/audit={chat_default}  code={code_default}"
        "   (change with: ambient use)   badges: reason vision tools json",
        file=sys.stderr,
    )
    if hidden_ids and not show_all:
        print(
            f"+ {len(hidden_ids)} hidden by your curation — see everything: "
            "ambient models --all",
            file=sys.stderr,
        )
    if not configured:
        print(
            f"No API key configured — browsing only. Get one at "
            f"{KEY_CONSOLE_URL}, then run: ambient setup",
            file=sys.stderr,
        )


def cmd_use(args, api_key, api_url, conf):
    models = [m for m in fetch_models(api_url, api_key)
              if isinstance(m, dict) and m.get("id")]
    models.sort(key=lambda m: (not m.get("is_ready"), m.get("id") or ""))
    known_ids = [m["id"] for m in models]
    allow, hide, show, notes = curation(conf)
    chosen = args.model_id
    if not chosen:
        if not sys.stdin.isatty():
            sys.exit("ambient: no TTY for interactive picker; use: ambient use <model-id>")
        chat_default = resolve_model(argparse.Namespace(model=None), conf, "chat")
        code_default = resolve_model(argparse.Namespace(model=None), conf, "code")
        pick_from = [m for m in models
                     if getattr(args, "all", False)
                     or not is_hidden(m["id"], allow, hide, show)]
        if not pick_from:
            pick_from = models
        n_hidden = len(models) - len(pick_from)
        print("Pick a default model (READY = live on the network right now):\n")
        for i, m in enumerate(pick_from, 1):
            print(f"  {i:2}. {format_model_line(m, chat_default, code_default, note=notes.get(m['id']))}")
        if n_hidden:
            print(f"\n  (+{n_hidden} hidden by curation — "
                  "`ambient use --all` picks from everything)")
        try:
            raw = input("\nModel number: ").strip()
            idx = int(raw)
            if not 1 <= idx <= len(pick_from):
                raise ValueError
        except (ValueError, EOFError, KeyboardInterrupt):
            sys.exit("\nambient: cancelled (no valid selection)")
        chosen = pick_from[idx - 1]["id"]
    elif chosen not in known_ids:
        # Explicit user text, so a UNIQUE substring match resolves (still the
        # user's choice — never a guess between candidates). Otherwise suggest.
        subs = [i for i in known_ids if chosen.lower() in i.lower()]
        if len(subs) == 1:
            print(f"ambient: matched '{chosen}' → {subs[0]}", file=sys.stderr)
            chosen = subs[0]
        else:
            sugg = subs or difflib.get_close_matches(chosen, known_ids,
                                                     n=3, cutoff=0.4)
            hint = f" Did you mean: {', '.join(sugg[:3])}?" if sugg else ""
            sys.exit(f"ambient: unknown model '{chosen}'.{hint} "
                     "Run 'ambient models' for the list.")
    if is_hidden(chosen, allow, hide, show):
        print(
            f"note: '{chosen}' is hidden from the model menu — saving anyway "
            f"(surface it with: ambient curate show {chosen}).",
            file=sys.stderr,
        )
    picked = next((m for m in models if m["id"] == chosen), None)
    if picked and not picked.get("is_ready"):
        print(
            f"note: '{chosen}' has no live workers right now (429 until miners pick "
            "it up) — saving anyway.",
            file=sys.stderr,
        )
    if notes.get(chosen):
        print(f"note for {chosen}: {notes[chosen]}", file=sys.stderr)
    updates = {}
    if args.chat or not args.code:
        updates["AMBIENT_MODEL"] = chosen
    if args.code or not args.chat:
        updates["AMBIENT_CODE_MODEL"] = chosen
    save_config_values(updates)
    scope = " and ".join(
        s for s, on in (("chat/audit", "AMBIENT_MODEL" in updates),
                        ("code/agent", "AMBIENT_CODE_MODEL" in updates)) if on
    )
    print(f"Default for {scope} set to: {chosen}")


def cmd_curate(args):
    """Founder model-curation surface: pick which models the plugin shows.
    Works pre-key (the catalog endpoint is unauthenticated); all writes go
    through the atomic + locked config writer. Curation shapes menus and
    automatic selection only — explicit -m / `use <id>` always works."""
    conf = read_config_file()
    verb = args.verb or "status"
    ids = list(args.ids or [])

    def _catalog_ids():
        key, _ = resolve_key_and_backend(conf)
        cat = safe_catalog(resolve_api_url(conf), key or "none")
        return [m.get("id") for m in cat
                if isinstance(m, dict) and m.get("id")]

    def _warn_unknown(entries):
        known = _catalog_ids()
        if not known:
            return  # offline — skip the nicety
        for e in entries:
            if any(ch in e for ch in "*?[") or e in known:
                continue
            print(f"warning: '{e}' is not in today's catalog — saved anyway "
                  "(the catalog changes as miners come and go)", file=sys.stderr)

    def _print_status():
        conf2 = read_config_file()
        allow2, hide2, show2, notes2 = curation(conf2)
        print(f"curation: allow={','.join(allow2) if allow2 else '(everything)'}"
              f"  hide={','.join(hide2) if hide2 else '(nothing)'}"
              + (f"  show-overrides={','.join(show2)}" if show2 else ""))
        founder_notes = {k: v for k, v in notes2.items() if v}
        if founder_notes:
            print("notes:")
            for k, v in sorted(founder_notes.items()):
                print(f"  {k}: {v}")
        known = _catalog_ids()
        if known:
            vis = [i for i in known if not is_hidden(i, allow2, hide2, show2)]
            print(f"{len(vis)} surfaced / {len(known) - len(vis)} hidden "
                  f"of {len(known)} catalog models")

    if verb == "status":
        _print_status()
        return
    if verb == "reset":
        save_config_values({"AMBIENT_MODELS_ALLOW": None,
                            "AMBIENT_MODELS_HIDE": None,
                            "AMBIENT_MODELS_SHOW": None,
                            "AMBIENT_MODEL_NOTES": None})
        print("curation reset — every catalog model is surfaced again")
        return
    # Every merge below is computed INSIDE the config lock from the freshest
    # file state (save_config_values callable form) — two founder terminals
    # editing curation concurrently can't lose each other's entries.
    if verb == "note":
        if not ids:
            usage_exit('usage: ambient curate note <model-id> ["text"]')
        target, text = ids[0], " ".join(ids[1:]).replace("\n", " ")[:120]

        def _merge_note(fresh):
            try:
                stored = json.loads(fresh.get("AMBIENT_MODEL_NOTES") or "{}")
                if not isinstance(stored, dict):
                    stored = {}
            except json.JSONDecodeError:
                stored = {}
            stored[target] = text  # "" clears (and suppresses a built-in note)
            return {"AMBIENT_MODEL_NOTES": json.dumps(stored)}

        save_config_values(_merge_note)
        print(f"note for {target}: {text or '(cleared)'}")
        return
    if not ids:
        usage_exit(f'usage: ambient curate {verb} <model-id-or-glob> ...')
    ns = argparse.Namespace(model=None)
    defaults = {resolve_model(ns, conf, "chat"), resolve_model(ns, conf, "code")}
    if verb == "hide":
        _warn_unknown(ids)

        def _merge_hide(fresh):
            hide_f = _split_csv(fresh.get("AMBIENT_MODELS_HIDE"))
            show_f = _split_csv(fresh.get("AMBIENT_MODELS_SHOW"))
            return {
                "AMBIENT_MODELS_HIDE":
                    ",".join(dict.fromkeys(hide_f + ids)),
                "AMBIENT_MODELS_SHOW":
                    ",".join(s for s in show_f if s not in ids) or None,
            }

        save_config_values(_merge_hide)
        for e in ids:
            if e in defaults:
                print(f"note: '{e}' is a current lane default — it keeps "
                      "working; pick a new default with: ambient use",
                      file=sys.stderr)
        print(f"hidden: {', '.join(ids)}")
    elif verb == "show":

        def _merge_show(fresh):
            allow_f = _split_csv(fresh.get("AMBIENT_MODELS_ALLOW"))
            hide_f = [h for h in _split_csv(fresh.get("AMBIENT_MODELS_HIDE"))
                      if h not in ids]
            show_f = _split_csv(fresh.get("AMBIENT_MODELS_SHOW"))
            # Exact entries leave HIDE; anything STILL hidden (a glob, or
            # strict-allow mode) gets an explicit show-override.
            still = [i for i in ids if is_hidden(i, allow_f, hide_f, show_f)]
            return {
                "AMBIENT_MODELS_HIDE": ",".join(hide_f) or None,
                "AMBIENT_MODELS_SHOW":
                    ",".join(dict.fromkeys(show_f + still)) or None,
            }

        save_config_values(_merge_show)
        print(f"surfaced: {', '.join(ids)}")
    elif verb == "only":
        _warn_unknown(ids)
        save_config_values({"AMBIENT_MODELS_ALLOW": ",".join(ids),
                            "AMBIENT_MODELS_HIDE": None,
                            "AMBIENT_MODELS_SHOW": None})
        print(f"menu restricted to: {', '.join(ids)} "
              "(new catalog models stay hidden until added — "
              "ambient curate reset undoes this)")
    _print_status()


def cmd_ask(args, api_key, api_url, conf):
    # '-' in the prompt args means "also read stdin" (e.g. cat big.txt |
    # ambient ask "summarize" -). Otherwise stdin is only read when no prompt
    # was given — a wrapper holding stdin open (backgrounded shells, cron)
    # must never block us.
    words = [w for w in args.prompt if w != "-"]
    want_stdin = "-" in args.prompt or not words
    question = " ".join(words).strip()
    doc = read_stdin_if_piped().strip() if want_stdin else ""
    if not want_stdin:
        warn_if_stdin_ignored("add '-' to the prompt to include piped data")
    if not question and not doc:
        usage_exit("nothing to ask (pass a prompt or pipe stdin)")
    scan = [("prompt", question)] + ([("stdin", doc)] if doc else [])
    refuse_if_secrets(scan, getattr(args, "allow_secrets", False))
    model = resolve_model(args, conf, "chat")
    if getattr(args, "model", None):
        note_if_hidden(args.model, conf)
    catalog = safe_catalog(api_url, api_key)
    profile = model_profile(catalog, model)
    input_size = len(question) + (len(doc) if doc else 0)
    sizing = (input_size if input_size <= profile.single_shot_chars
              else profile.chunk_chars)
    apply_output_budget(args, profile, sizing)
    single, chunk = profile.single_shot_chars, profile.chunk_chars
    want_json = getattr(args, "json", False)

    def split_over_doc():
        q = question or "Summarize the essential content."
        base = args.system or "You are a careful, precise analyst."
        # Token-dense text (CJK ~1-1.5 chars/token vs code ~3.2) must get
        # proportionally smaller chunks or every chunk 400s on context.
        chunk_eff = max(MIN_REASONING_CHUNK,
                        int(chunk / density_factor(doc)))
        packed = pack_chunks([("input", doc)], chunk_eff)
        cost_gate(catalog, model, len(doc), len(packed) * 2, args, conf)
        final, partial, reason = run_map_reduce(
            api_key, api_url, model,
            f"{base}\nQUESTION: {q}\nFrom the given chunk, extract everything "
            "relevant and give a partial answer based on THIS chunk alone.",
            packed, args,
            f"You are merging partial answers to: {q}\nCombine into one final, "
            "coherent, non-repetitive answer; resolve conflicts explicitly.",
            single,
        )
        if want_json:  # keep --json machine-readable even on the map-reduce path
            emit_json("ask", model=model, api_key=api_key, content=final,
                      partial=partial, reason=reason or None,
                      allow_partial=getattr(args, "allow_partial", False))
            return
        render_result(final, partial, reason, args, api_key)

    if not doc and len(question) > single:
        # No-refusal invariant: a giant argv prompt (ambient ask "$(cat big.md)")
        # flows into the same split machinery as piped input instead of dying
        # on a context 400 after billing the attempt (arch sweep HIGH).
        doc, question = question, (
            "Answer the request contained in the document (any instructions "
            "are embedded within it).")
    eff_total = int((len(question) + len(doc)) * density_factor(doc or question))
    if doc and eff_total > single:
        split_over_doc()
        return
    prompt = f"{question}\n\n{doc}".strip() if doc else question
    messages = []
    if args.system:
        messages.append({"role": "system", "content": args.system})
    messages.append({"role": "user", "content": prompt})
    # D1: live-stream the answer to stdout on an interactive terminal (not --raw,
    # not --json). Reasoning shows as heartbeats first, then the answer streams.
    live_stream = sys.stdout.isatty() and not args.raw and not want_json
    streamed_parts = []

    def on_delta(piece):
        sys.stdout.write(redact(piece, api_key))
        sys.stdout.flush()
        streamed_parts.append(piece)

    try:
        content, usage, body = complete(
            api_key, api_url, model, messages, args,
            on_delta=(on_delta if live_stream else None))
    except ChatError as err:
        if streamed_parts:
            sys.stdout.write("\n")
            sys.stdout.flush()
        if err.category in ("empty", "context") and len(prompt) > 20_000:
            if not doc:  # token-dense argv prompt that overflowed anyway
                doc, question = prompt, (
                    "Answer the request contained in the document (any "
                    "instructions are embedded within it).")
            print(
                f"ambient: '{model}' couldn't finish in one pass — splitting the "
                "document for the same model",
                file=sys.stderr,
            )
            split_over_doc()
            return
        _fail(args, "ask", err, api_key)
    if want_json:
        served = body.get("_served_model", model)
        emit_json(
            "ask", model=served, api_key=api_key, content=content,
            partial=bool(body.get("salvaged_partial")),
            reason="output salvaged" if body.get("salvaged_partial") else None,
            usage=body.get("usage"), finish_reason=body.get("finish_reason"),
            extra=({"requested_model": model} if served != model else None),
            allow_partial=getattr(args, "allow_partial", False))
        return
    if args.raw:
        print(redact(json.dumps(body, indent=2), api_key))
        return
    # Only treat it as streamed if what we streamed IS the final content — a
    # stall-retry/escalation restart yields fresh content and must be reprinted.
    clean_stream = bool(streamed_parts) and "".join(streamed_parts).strip() == content
    if not clean_stream and streamed_parts:
        sys.stdout.write("\n[ambient: stream restarted — full result below]\n")
        sys.stdout.flush()
    render_result(
        content,
        bool(body.get("salvaged_partial")) or body.get("finish_reason") == "length",
        "output was salvaged/truncated", args, api_key, usage, model,
        already_streamed=clean_stream,
    )


# --------------------------------------------------------------------------
# `ambient map` — the bulk per-item inference lane (v3 Phase 2). ONE prompt
# applied INDEPENDENTLY to MANY items: each file/stdin-line is its own
# complete() call (NOT map-reduce — no synthesis pass), streamed out as it
# finishes, resumable via the content-addressed cache, all behind ONE
# up-front batch cost gate. map only READS items and PRINTS results — it
# never writes files and never executes model output.

MAP_OVERSIZE_MSG = ("input too large for map — use ambient audit for large "
                    "files (map is one single-shot call per item)")


def _read_map_item(path):
    """(text, error) for ONE file item. Mirrors read_files' safety checks
    (regular file, binary, size) but reports PER-ITEM instead of skipping or
    aborting — map's unit of failure is the item, never the batch."""
    if os.path.isdir(path):
        return None, ("is a directory — map takes one FILE per item; glob "
                      f"its files instead (e.g. {path}/*.py)")
    try:
        st = os.lstat(path)
    except OSError as err:
        return None, f"unreadable ({err})"
    if not stat.S_ISREG(st.st_mode):
        return None, "not a regular file"
    try:
        with open(path, "rb") as fh:
            raw = fh.read(ABS_MAX_CHARS + 1)
    except OSError as err:
        return None, f"unreadable ({err})"
    if b"\x00" in raw[:8192]:
        return None, "looks binary — map sends text items only"
    if len(raw) > ABS_MAX_CHARS:
        # NEVER ship a silently truncated item — even if a model's window
        # somehow exceeded the ceiling, a half-read answered authoritatively
        # is worse than a per-item refusal.
        return None, (f"file exceeds the {ABS_MAX_CHARS:,}-char ceiling — "
                      "too large for map; run ambient audit on it instead")
    text = raw.decode("utf-8", errors="replace")
    if not text.strip():
        return None, "empty file"
    return text, None


def _map_gather_items(args):
    """The per-item work list: [(id, text, pre_error)] by the documented
    precedence — positional paths first (each FILE is one item), else stdin
    (one item per non-empty line; --jsonl parses each line as a JSON object
    with an \"input\" field and optional \"id\")."""
    items = []
    if args.paths:
        warn_if_stdin_ignored("map reads stdin only when no paths are given")
        # Cumulative cap while gathering (same overall ceiling read_files
        # enforces): dozens of multi-MB files must not be held in memory
        # simultaneously — items past the cap get a clean per-item error
        # and are never read.
        total, capped = 0, False
        cap_msg = (f"batch input cap reached ({ABS_MAX_CHARS:,} chars "
                   "total) — item skipped to bound memory; split the map "
                   "into smaller runs")
        for path in args.paths:
            if capped:
                items.append((path, None, cap_msg))
                continue
            text, err = _read_map_item(path)
            if err is None:
                total += len(text)
                if total > ABS_MAX_CHARS:
                    capped = True
                    items.append((path, None, cap_msg))
                    continue
            items.append((path, text, err))
        return items
    data = read_stdin_if_piped()
    idx = 0
    for line in data.splitlines():
        if not line.strip():
            continue
        idx += 1
        if not getattr(args, "jsonl", False):
            items.append((idx, line, None))
            continue
        try:
            obj = json.loads(line)
        except json.JSONDecodeError as err:
            items.append((idx, None, f"invalid JSONL line ({err})"))
            continue
        if not isinstance(obj, dict):
            items.append((idx, None, "JSONL line is not a JSON object"))
            continue
        item_id = obj.get("id", idx)
        text = obj.get("input")
        if not isinstance(text, str) or not text.strip():
            items.append((item_id, None,
                          'JSONL item needs a non-empty string "input" field'))
            continue
        items.append((item_id, text, None))
    return items


def _emit_map_result(args, api_key, item_id, *, content=None, partial=False,
                     cached=False, category=None, diagnosis=None):
    """Stream ONE per-item result the moment it completes. Items finish out
    of order, so the id always rides along. Under --json each result is ONE
    LINE — a self-contained map envelope (JSONL), redacted like every other
    surface. Returns the item's exit code (0 ok / 1 error / 2 partial)."""
    if content is None:
        status, code = "error", 1
    elif partial:
        status, code = "partial", EXIT_PARTIAL
    else:
        status, code = "ok", 0
    if _json_mode(args):
        env = {"schema_version": 1, "kind": "map", "status": status,
               "id": item_id, "content": content, "exit_code": code}
        if category is not None:
            env["category"] = category
        if diagnosis is not None:
            env["diagnosis"] = diagnosis
        if cached:
            env["cached"] = True
        print(redact(json.dumps(env), api_key), flush=True)
        return code
    if status == "error":
        print(redact(f"===== ITEM {item_id} — FAILED [{category}]: "
                     f"{diagnosis}", api_key), flush=True)
        return code
    note = " — PARTIAL (truncated)" if partial else (
        " (cached)" if cached else "")
    print(redact(f"===== ITEM {item_id}{note} =====\n{content}\n", api_key),
          flush=True)
    return code


def cmd_map(args, api_key, api_url, conf):
    prompt = (args.prompt or "").strip()
    if not prompt:
        _fail_exit(args, "map", "usage",
                   'map needs a per-item instruction: ambient map "<prompt>" '
                   "[FILES...] (or pipe one item per line on stdin)",
                   exit_code=EXIT_USAGE, api_key=api_key)
    items = _map_gather_items(args)
    if not items:
        _fail_exit(args, "map", "usage",
                   "no items to map — pass file paths (one item per file) or "
                   "pipe one item per line on stdin (--jsonl for JSON objects "
                   'with an "input" field)',
                   exit_code=EXIT_USAGE, api_key=api_key)
    refuse_if_secrets(
        [("prompt", prompt)] + [(str(i), t) for i, t, e in items if e is None],
        getattr(args, "allow_secrets", False))
    model = resolve_model(args, conf, "chat")
    if getattr(args, "model", None):
        note_if_hidden(args.model, conf)
    catalog = safe_catalog(api_url, api_key)
    profile = model_profile(catalog, model)
    single = profile.single_shot_chars

    # Partition: per-item pre-errors (directory/binary/oversized/bad JSONL)
    # never bill and never block the runnable siblings. An item past the
    # model's single-shot window is refused PER-ITEM — never silently
    # truncated (that would answer over half an input and look authoritative).
    runnable, pre_errors = [], []
    for item_id, text, err in items:
        if err is not None:
            pre_errors.append((item_id, "input", err))
            continue
        eff = int((len(prompt) + len(text)) * density_factor(text))
        if eff > single:
            pre_errors.append((item_id, "input", MAP_OVERSIZE_MSG))
            continue
        runnable.append((item_id, text, eff))
    fails = len(pre_errors)
    ok = cached_n = 0
    use_cache = not getattr(args, "no_cache", False)
    cache_ttl = getattr(args, "cache_ttl", None) or CACHE_TTL_DEFAULT
    cached_hits, to_run = [], []
    explicit_budget = getattr(args, "max_tokens", None) is not None
    if runnable and explicit_budget:
        # An explicit --max-tokens applies to EVERY item (and is part of
        # every key): clamp + warn ONCE on the shared args, then each item
        # copy inherits the resolved value.
        apply_output_budget(args, profile)
    if runnable:
        # Budget EACH ITEM INDEPENDENTLY from its OWN density-adjusted size
        # (A1 right-sizing, per item) on a private args copy — so its cache
        # key depends only on (model, prompt, item, its-own-budget, temp,
        # response_format) and is stable no matter what else joins the batch.
        # Sizing once to the batch max would re-key EVERY item when a larger
        # item is added, re-billing already-cached work; it also over-budgeted
        # small items. The per-item copy also keeps complete()'s budget
        # escalation from mutating a sibling's args mid-flight.
        # Cache is resolved BEFORE the gate (after the budget — the key
        # includes max_tokens): a resumed / fully-cached re-run makes zero
        # calls and must never be re-priced or refused by AMBIENT_MAX_SPEND.
        for item_id, text, eff in runnable:
            item_args = argparse.Namespace(**vars(args))
            if not explicit_budget:
                apply_output_budget(item_args, profile, eff)
            key = _cache_key(model, prompt, text, item_args.max_tokens,
                             args.temperature,
                             getattr(args, "response_format", None))
            hit = _cache_get(key, cache_ttl) if use_cache else None
            if hit is not None:
                cached_hits.append((item_id, hit))
            else:
                to_run.append((item_id, text, key, item_args))
    if to_run:
        total_chars = (sum(len(t) for _, t, _, _ in to_run)
                       + len(prompt) * len(to_run))
        print(f"ambient map: {len(items)} item(s), {len(to_run)} to run"
              + (f" ({len(cached_hits)} cached)" if cached_hits else "")
              + (f" ({fails} refused up front)" if fails else "")
              + f" — one {model} call per item", file=sys.stderr)
        # ONE batch cost gate BEFORE any network call: total input chars,
        # one call per CACHE MISS. Respects AMBIENT_MAX_SPEND /
        # --allow-cost / the 3x worst-case bound — a 500-item run must show
        # its full price up front, not discover it item by item. Budgets are
        # PER-ITEM now, so gate at the per-call MEAN budget on a private
        # copy: estimate_cost is linear in max_tokens, so the batch figure
        # equals the SUM of the per-item estimates.
        budgets = [ia.max_tokens for _, _, _, ia in to_run]
        gate_args = argparse.Namespace(**vars(args))
        gate_args.max_tokens = -(-sum(budgets) // len(budgets))  # ceil mean
        cost_gate(catalog, model, total_chars, len(to_run), gate_args, conf)
    for item_id, category, diagnosis in pre_errors:
        _emit_map_result(args, api_key, item_id,
                         category=category, diagnosis=diagnosis)
    # D7 resume: cache hits still emit their envelopes — for free.
    for item_id, hit in cached_hits:
        ok += 1
        cached_n += 1
        _emit_map_result(args, api_key, item_id, content=hit, cached=True)

    width = min(_resolve_parallel(args), max(1, len(to_run)))
    # Phase-1 shape: a shared gate around the network call + a cancel_event
    # flipped on the first fatal failure so no queued item starts billing
    # while the batch unwinds (re-checked after acquiring any gate slot).
    gate = threading.Semaphore(width)
    cancel_event = threading.Event()

    def work(item_id, text, key, item_args):
        if cancel_event.is_set():
            raise ChatError("cancelled",
                            "map cancelled before this item started")
        messages = [{"role": "system", "content": prompt},
                    {"role": "user", "content": text}]
        for attempt in range(3):
            try:
                with gate:
                    # Re-check after acquiring the slot: an item that raced
                    # in after an abort must bill NOTHING.
                    if cancel_event.is_set():
                        raise ChatError(
                            "cancelled",
                            "map cancelled while waiting for a slot")
                    try:
                        out, _u, body = complete(
                            api_key, api_url, model, messages, item_args)
                    except NetworkError:
                        # Fatal for every sibling — flip cancel BEFORE this
                        # gate slot is released, so a waiting retry worker
                        # that grabs the freed slot can't start a billed
                        # call before cancellation is visible (race-free).
                        cancel_event.set()
                        raise
                    except ChatError as err:
                        if err.category in ("key", "funds"):
                            cancel_event.set()  # same zero-race fail-fast
                        raise
                partial = (bool(body.get("salvaged_partial"))
                           or body.get("finish_reason") == "length")
                # Only a clean result from the REQUESTED model is cached —
                # a fallback model's answer under this key would poison a
                # later run (same rule as run_map_reduce).
                served = body.get("_served_model", model)
                if use_cache and not partial and served == model:
                    _cache_put(key, out)
                return out, partial
            except ChatError as err:
                if err.category == "rate" and attempt < 2 \
                        and not cancel_event.is_set():
                    ra = getattr(err, "retry_after", None)
                    time.sleep(_retry_delay(3 * (attempt + 1),
                                            {"Retry-After": ra} if ra
                                            else None))
                    continue
                raise

    pool = concurrent.futures.ThreadPoolExecutor(max_workers=width)
    aborted = False

    def _abort():
        nonlocal aborted
        aborted = True
        cancel_event.set()
        try:
            pool.shutdown(wait=False, cancel_futures=True)  # py3.9+
        except TypeError:
            pool.shutdown(wait=False)                       # py3.8

    try:
        futs = {pool.submit(work, i, t, k, ia): i for i, t, k, ia in to_run}
        for fut in concurrent.futures.as_completed(futs):
            item_id = futs[fut]
            try:
                text, partial = fut.result()
            except (ChatError, NetworkError) as err:
                if isinstance(err, NetworkError) \
                        or getattr(err, "category", "") in ("key", "funds"):
                    # Every sibling is doomed identically — cancel the queue,
                    # stop billing, and surface the REAL problem now. main()
                    # renders it as the --json error envelope / prose, exit 1.
                    _abort()
                    raise
                fails += 1
                _emit_map_result(
                    args, api_key, item_id,
                    category=getattr(err, "category", "network"),
                    diagnosis=getattr(err, "diagnosis", None) or str(err))
                continue
            except Exception as err:  # noqa: BLE001 — one item must never
                # abort the batch; record it as a failed item and keep going.
                fails += 1
                _emit_map_result(args, api_key, item_id, category="internal",
                                 diagnosis=f"{type(err).__name__}: {err}")
                continue
            if partial:
                fails += 1
            else:
                ok += 1
            _emit_map_result(args, api_key, item_id, content=text,
                             partial=partial)
    except KeyboardInterrupt:
        print("\nambient: cancelling map…", file=sys.stderr)
        _abort()
        # A real Ctrl-C must end the PROCESS now: the pool's worker threads
        # are non-daemon, so re-raising would leave the interpreter joining
        # the in-flight complete() at exit — stalling exit-130 for up to
        # --timeout. os._exit skips interpreter teardown (no buffered-stream
        # flushing), so flush BOTH streams first — no emitted envelope or
        # diagnostic may be lost. Normal (non-interrupt) exits are untouched.
        sys.stdout.flush()
        sys.stderr.flush()
        os._exit(130)
    finally:
        # After an abort the queue is already cancelled — a second BLOCKING
        # shutdown would sit there draining in-flight calls, turning Ctrl-C
        # exit-130 from prompt into minutes.
        if not aborted:
            pool.shutdown(wait=True)
    print(f"ambient map: {ok} ok / {fails} failed / {cached_n} cached "
          f"(of {len(items)} item(s))", file=sys.stderr)
    if fails and not getattr(args, "allow_partial", False):
        sys.exit(EXIT_PARTIAL)


AUDIT_FINDINGS_SCHEMA = {
    "type": "object",
    "additionalProperties": False,
    "properties": {
        "findings": {
            "type": "array",
            "items": {
                "type": "object",
                "additionalProperties": False,
                "properties": {
                    "severity": {"type": "string",
                                 "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW"]},
                    "confidence": {"type": "string", "enum": ["HIGH", "LOW"]},
                    "file": {"type": "string"},
                    "line": {"type": "integer"},
                    "title": {"type": "string"},
                    "defect": {"type": "string"},
                    "scenario": {"type": "string"},
                    "fix": {"type": "string"},
                },
                "required": ["severity", "confidence", "file", "line", "title",
                             "defect", "scenario", "fix"],
            },
        },
        "verdict": {"type": "string",
                    "enum": ["SHIP", "FIX FIRST", "NEEDS WORK"]},
    },
    "required": ["findings", "verdict"],
}

# Appended to the system prompt on the json_object / prompt-only paths (models
# without strict json_schema need the shape spelled out).
AUDIT_JSON_INSTRUCTION = (
    "\n\nOUTPUT FORMAT: return ONLY a JSON object (no prose, no markdown fences) "
    'matching: {"findings":[{"severity":"CRITICAL|HIGH|MEDIUM|LOW",'
    '"confidence":"HIGH|LOW","file":str,"line":int,"title":str,"defect":str,'
    '"scenario":str,"fix":str}],"verdict":"SHIP|FIX FIRST|NEEDS WORK"}. '
    "Empty findings + verdict SHIP if the code is sound."
)


AUDIT_SYNTH_PROMPT = """You are merging partial audit reports produced from chunks
of ONE codebase. Combine them into a single report: dedupe identical findings (same
file:line + same defect) keeping the highest severity and richest scenario, keep the
most severe first, preserve each finding's SEVERITY, confidence, and exact file:line
(the numbers come from absolute gutters — keep them verbatim), and drop findings that
are clearly artifacts of a file being split across chunks unless corroborated. Do not
invent findings not present in the inputs. End with ONE overall verdict
(SHIP / FIX FIRST / NEEDS WORK). If a coverage-gap note is present, state it plainly
at the TOP and do not issue a clean/SHIP verdict."""


def extract_json(text):
    """Best-effort JSON object extraction from a model reply (A5): strips ```json
    fences and prose, finds the outermost balanced {...}, parses. Reasoning models
    leak fences even in structured mode, so this must be tolerant. Returns a dict
    or None (caller degrades to wrapping the raw text)."""
    if not text:
        return None
    t = text.strip()
    # direct parse first
    try:
        obj = json.loads(t)
        return obj if isinstance(obj, dict) else None
    except json.JSONDecodeError:
        pass
    # strip a fenced block if present
    fence = re.search(r"```(?:json)?\s*(.*?)```", t, re.S)
    if fence:
        try:
            obj = json.loads(fence.group(1).strip())
            return obj if isinstance(obj, dict) else None
        except json.JSONDecodeError:
            pass
    dec = json.JSONDecoder()
    first = t.find("{")
    if first == -1:
        return None
    # 1) The OUTERMOST object (the whole structured reply usually starts here).
    frag = t[first:]
    try:
        obj, _end = dec.raw_decode(frag)
        if isinstance(obj, dict):
            return obj
    except json.JSONDecodeError:
        pass
    # 2) REPAIR a cleanly-truncated outer object — model closed the array but
    # dropped the final "verdict"/brace, or the stream was cut on a token
    # boundary: append the missing closers. Only when NOT truncated mid-string
    # (even quotes) and the deficit is small. Surfaced by the stress battery:
    # strict json_schema is not always honored by the backend.
    if frag.count('"') % 2 == 0:
        need_br = frag.count("[") - frag.count("]")
        need_ob = frag.count("{") - frag.count("}")
        if 0 <= need_br <= 5 and 1 <= need_ob <= 5:
            try:
                obj = json.loads(frag + "]" * need_br + "}" * need_ob)
                if isinstance(obj, dict):
                    # A repaired object is missing its TAIL (trailing findings
                    # and/or the verdict). Mark it so no caller can present a
                    # repaired audit as a clean pass (resilience sweep HIGH:
                    # truncated audit could previously SHIP).
                    obj["_repaired"] = True
                    return obj
            except json.JSONDecodeError:
                pass
    # 3) Prose with a valid object LATER (a non-JSON '{...}' before the real one,
    # Codex A+B LOW) — scan subsequent '{' positions.
    idx = first + 1
    while True:
        start = t.find("{", idx)
        if start == -1:
            return None
        try:
            obj, _end = dec.raw_decode(t[start:])
            if isinstance(obj, dict):
                return obj
        except json.JSONDecodeError:
            pass
        idx = start + 1


SEVERITY_ORDER = {"CRITICAL": 0, "HIGH": 1, "MEDIUM": 2, "LOW": 3}


def _finding_sig(f):
    """(file-basename, line, title words) — the identity used to match the
    same bug reported by different chunks/models."""
    path = os.path.basename(str(f.get("file", ""))).lower()
    try:
        line = int(f.get("line") or 0)
    except (TypeError, ValueError):
        line = 0
    words = re.sub(r"\W+", " ", str(f.get("title", ""))).lower().split()
    return path, line, tuple(words[:4])


def _titles_match(a, b):
    """Same bug if the shorter title is a word-prefix of the longer, compared
    over at most 4 significant words: 'SQL injection' matches 'SQL injection
    here', but 'missing null check' does not match 'missing rate limit'."""
    n = min(len(a), len(b), 4)
    if n == 0:
        return not a and not b
    return a[:n] == b[:n]


def dedupe_findings(findings):
    """Deterministically dedupe findings across chunks (A5): same file, title
    prefix, and line within ±3 = the same bug. True proximity (not //3 buckets,
    which missed duplicates straddling a bucket edge and false-merged neighbors
    — resilience sweep LOW). Keep the highest severity + longest scenario."""
    kept = []  # [(sig, finding)]
    for f in findings:
        if not isinstance(f, dict):
            continue
        path, line, title = _finding_sig(f)
        slot = None
        for entry in kept:
            (kp, kl, kt), _ = entry
            if kp == path and _titles_match(kt, title) and abs(kl - line) <= 3:
                slot = entry
                break
        if slot is None:
            kept.append(((path, line, title), f))
            continue
        prev = slot[1]
        best = prev
        if SEVERITY_ORDER.get(f.get("severity"), 9) < \
                SEVERITY_ORDER.get(prev.get("severity"), 9):
            best = f
        if len(str(f.get("scenario", ""))) > len(str(best.get("scenario", ""))):
            best = {**best, "scenario": f.get("scenario")}
        kept[kept.index(slot)] = (slot[0], best)
    result = [f for _, f in kept]
    result.sort(key=lambda f: SEVERITY_ORDER.get(f.get("severity"), 9))
    return result


def _verdict_from(findings, partial):
    sevs = {f.get("severity") for f in findings if isinstance(f, dict)}
    if partial:
        return "NEEDS WORK"
    if "CRITICAL" in sevs or "HIGH" in sevs:
        return "FIX FIRST"
    if "MEDIUM" in sevs or "LOW" in sevs:
        return "NEEDS WORK"
    return "SHIP"


def findings_reducer(texts):
    """Structured reduce (A5): parse each chunk's JSON findings, dedupe in
    Python, recompute the verdict — no re-billed LLM synthesis call. A chunk
    whose output won't parse is a COVERAGE GAP, not a clean pass (Codex A+B
    HIGH): it forces a non-SHIP verdict rather than silently dropping to
    {"findings":[], "SHIP"}."""
    collected = []
    parse_fail = 0
    repaired = 0
    for t in texts:
        obj = extract_json(t)
        if obj and isinstance(obj.get("findings"), list):
            collected.extend(obj["findings"])
            if obj.get("_repaired"):
                repaired += 1  # tail findings may be missing from this chunk
        else:
            parse_fail += 1
    merged = dedupe_findings(collected)
    verdict = ("NEEDS WORK" if (parse_fail or repaired)
               else _verdict_from(merged, False))
    return json.dumps({"findings": merged, "verdict": verdict,
                       "_unparsed_chunks": parse_fail,
                       "_repaired_chunks": repaired})


def render_findings(raw, fmt, api_key, partial=False, reason="", model=None):
    """Render structured audit findings as JSON or a clean report. Degrades to
    printing the raw text if it can't be parsed (never drops the output).
    Returns the EFFECTIVE partial flag — render_findings can discover coverage
    gaps its caller didn't know about (unparseable/repaired chunks), and the
    caller's exit code must reflect them."""
    obj = extract_json(raw) if isinstance(raw, str) else raw
    if not obj or not isinstance(obj.get("findings"), list):
        text = raw if isinstance(raw, str) else json.dumps(raw)
        if fmt == "json":
            # --json must ALWAYS emit valid JSON — a consumer can't parse raw
            # model text (surfaced by the stress battery). Wrap it in an error
            # envelope with a non-clean verdict.
            emit_json("audit", model=model, api_key=api_key,
                      findings=[], verdict="NEEDS WORK", partial=True,
                      reason="model output was not valid parseable JSON",
                      extra={"coverage_complete": False,
                             "raw": redact(text, api_key)[:4000]},
                      exit_now=False)
        else:
            print(redact(text, api_key))
        return True
    findings = obj["findings"]
    # Normalize a "file:line" leaked into the file field (gutter artifact).
    for f in findings:
        if isinstance(f, dict):
            m = re.match(r"^(.*?):(\d+)$", str(f.get("file", "")))
            if m:
                f["file"] = m.group(1)
                f.setdefault("line", int(m.group(2)))
    # Unparseable/repaired chunks (from the reducer) are coverage gaps → partial.
    if obj.get("_unparsed_chunks"):
        partial = True
        reason = (reason + "; " if reason else "") + \
            f"{obj['_unparsed_chunks']} chunk(s) returned unparseable output"
    if obj.get("_repaired_chunks") or obj.get("_repaired"):
        partial = True
        reason = (reason + "; " if reason else "") + \
            ("model output was truncated mid-findings and repaired — trailing "
             "findings may be missing")
    verdict = obj.get("verdict") or _verdict_from(findings, partial)
    if partial and verdict == "SHIP":  # a partial audit can never be a clean pass
        verdict = "NEEDS WORK"
    if fmt == "json":
        emit_json("audit", model=model, api_key=api_key,
                  findings=findings, verdict=verdict, partial=partial,
                  reason=reason or None,
                  extra={"coverage_complete": not partial},
                  exit_now=False)
        return partial
    # report format
    if partial:
        print(paint(f"⚠ PARTIAL COVERAGE — {reason}", "1;33") + "\n")
    if not findings:
        print("No defects found.")
    SEV_COLOR = {"CRITICAL": "1;31", "HIGH": "31", "MEDIUM": "33", "LOW": "2"}
    for f in findings:
        if not isinstance(f, dict):
            continue
        sev = str(f.get("severity", "?"))
        head = (f"[{paint(sev, SEV_COLOR.get(sev, '0'))}/{f.get('confidence', '?')}] "
                f"{f.get('file', '?')}:{f.get('line', '?')} — {f.get('title', '')}")
        print(redact(head, api_key))
        if f.get("scenario"):
            print(redact(f"    {f['scenario']}", api_key))
        if f.get("fix"):
            print(redact(f"    fix: {f['fix']}", api_key))
        print()
    # The verdict string is MODEL OUTPUT — normalize it to the closed set so a
    # poisoned reply can't smuggle terminal escapes or fake banner text through
    # the one line users trust most (Codex W1 HIGH).
    if verdict not in ("SHIP", "FIX FIRST", "NEEDS WORK"):
        verdict = _verdict_from(findings, partial)
    print(redact(f"Verdict: {verdict}", api_key))
    return partial


def with_line_gutters(labeled):
    """Prefix each line with its absolute 1-based number ('  42| code') so a
    reviewer can cite EXACT lines even after a file is split across chunks —
    without this the model reports chunk-relative numbers that are silently
    wrong on any map-reduced audit (A2)."""
    out = []
    for label, text in labeled:
        lines = text.split("\n")
        width = max(2, len(str(len(lines))))
        out.append((label,
                    "\n".join(f"{i:>{width}}| {ln}"
                              for i, ln in enumerate(lines, 1))))
    return out


def git_diff_inputs(staged, ref):
    """Build audit inputs from a git diff PLUS the full current content of each
    changed file (D5) — a diff-only audit misses bugs that depend on unchanged
    code. Returns (labeled, diff_text) or exits cleanly outside a repo."""
    def git(*a):
        return subprocess.run(["git", *a], capture_output=True, text=True, timeout=30)
    inside = git("rev-parse", "--is-inside-work-tree")
    if inside.returncode != 0 or inside.stdout.strip() != "true":
        _fail_exit(None, "audit", "usage",
                   "--staged/--diff must run inside a git repository.",
                   exit_code=EXIT_USAGE)
    diff_args = (["diff", "--cached"] if staged else ["diff", ref])
    name_args = diff_args + ["--name-only"]
    proc = git(*diff_args)
    if proc.returncode != 0:
        # A bad ref must not masquerade as "no changes" (Codex final LOW).
        _fail_exit(None, "audit", "input",
                   f"git diff failed: {proc.stderr.strip()[:300]}")
    diff = proc.stdout
    if not diff.strip():
        _fail_exit(None, "audit", "usage", "no changes to audit (empty diff).",
                   exit_code=EXIT_USAGE)
    labeled = [("DIFF (git)", diff)]
    for path in git(*name_args).stdout.splitlines():
        path = path.strip()
        if path and os.path.isfile(path):
            labeled.extend(with_line_gutters(read_files([path])))
    return labeled


def run_one_audit(model, catalog, labeled, sys_prompt, args, api_key, api_url,
                  conf, gate=None, cancel_event=None):
    """Structured audit on ONE model → (findings, ok) (D8 consensus helper). ok
    is False when the model errored, was unready, or returned unparseable/partial
    output — so consensus can't present a FAILURE as 'no defects' (Codex Wave D
    HIGH). Each model gets its OWN profile/budget. `gate`/`cancel_event` flow
    through to run_map_reduce so the consensus lane's shared cap and fail-fast
    reach every model's inner fan-out."""
    if cancel_event is not None and cancel_event.is_set():
        # Consensus is unwinding (fatal sibling / Ctrl-C): a queued model can
        # race past cancel_futures into a pool worker — bill it NOTHING.
        return [], False
    profile = model_profile(catalog, model)
    single, chunk = profile.single_shot_chars, profile.chunk_chars
    total = sum(len(t) for _, t in labeled)
    a = argparse.Namespace(**vars(args))
    apply_output_budget(a, profile, total if total <= single else chunk)
    rf = response_format_for(profile, AUDIT_FINDINGS_SCHEMA)
    a.response_format = rf
    sp = sys_prompt + (AUDIT_JSON_INSTRUCTION
                       if (rf is None or rf.get("type") == "json_object") else "")
    if total <= single:
        messages = [{"role": "system", "content": sp},
                    {"role": "user", "content": files_block(labeled)}]
        if cancel_event is not None and cancel_event.is_set():
            return [], False  # a sibling raced past cancel_futures — bill nothing
        try:
            # Hold the shared consensus gate around the single-shot call too, so
            # the global concurrency cap is ABSOLUTE (mixed single-shot + chunked
            # consensus sets can't exceed the resolved width).
            with (gate if gate is not None else contextlib.nullcontext()):
                if cancel_event is not None and cancel_event.is_set():
                    return [], False  # cancelled while waiting for a gate slot
                content, _u, _b = complete(api_key, api_url, model, messages, a)
            obj = extract_json(content)
            if obj is None or not isinstance(obj.get("findings"), list):
                return [], False  # unparseable ≠ clean
            # A cap-truncated or salvaged reply parsed fine but is missing its
            # tail — consensus must not count it as full coverage (Codex W1 MED).
            ok = (not obj.get("_repaired")
                  and _b.get("finish_reason") != "length"
                  and not _b.get("salvaged_partial"))
            return obj["findings"], ok
        except ChatError as err:
            if err.category in ("key", "funds"):
                # Every subsequent call is doomed identically — falling through
                # to a full map-reduce would burn 2×N failing paid attempts
                # before reporting the real problem (resilience sweep LOW).
                raise
            pass  # fall through to a split across the same model
    chunk_chars = min(chunk if total > single else max(total // 3 + 1000, 20_000),
                      single)
    packed = pack_chunks(labeled, chunk_chars)
    try:
        final, partial, _r = run_map_reduce(
            api_key, api_url, model, sp, packed, a, AUDIT_SYNTH_PROMPT, single,
            reducer=findings_reducer, code_map=build_code_map(labeled),
            gate=gate, cancel_event=cancel_event)
    except ChatError as err:
        if err.category in ("key", "funds"):
            raise
        return [], False
    obj = extract_json(final)
    if obj is None or not isinstance(obj.get("findings"), list):
        return [], False
    ok = (not partial and not obj.get("_unparsed_chunks")
          and not obj.get("_repaired_chunks"))
    return obj["findings"], ok


def cmd_audit(args, api_key, api_url, conf):
    labeled = []
    if getattr(args, "staged", False) or getattr(args, "diff", None) is not None:
        labeled = git_diff_inputs(args.staged, getattr(args, "diff", None) or "HEAD")
        warn_if_stdin_ignored("--staged/--diff builds its own inputs from git")
    elif args.paths:
        # Gutter file inputs with absolute line numbers for exact citations.
        labeled.extend(with_line_gutters(read_files(args.paths)))
        warn_if_stdin_ignored("stdin is only read when no file paths are passed")
    else:
        # stdin only when no paths given (see cmd_ask: avoids blocking on
        # wrapper-held stdin). A diff is NOT guttered — its @@ hunks carry the
        # real new-file line numbers, which we tell the model to cite.
        piped = read_stdin_if_piped().strip()
        if piped:
            labeled.append(("DIFF / CODE (stdin)", piped))
    if args.focus:
        labeled.append(("focus", args.focus))
    refuse_if_secrets(labeled, args.allow_secrets)
    if args.focus:
        labeled.pop()
    if not labeled:
        _fail_exit(
            args, "audit", "usage",
            "nothing to audit. Pass file paths and/or pipe a diff:\n"
            "  git diff | ambient audit\n  ambient audit src/foo.py src/bar.py",
            exit_code=EXIT_USAGE, api_key=api_key,
        )
    focus = f"\nAudit focus: {args.focus}" if args.focus else ""
    model = resolve_model(args, conf, "chat")
    if getattr(args, "model", None):
        note_if_hidden(args.model, conf)
    catalog = safe_catalog(api_url, api_key)
    profile = model_profile(catalog, model)
    single, chunk = profile.single_shot_chars, profile.chunk_chars
    total = sum(len(text) for _, text in labeled)
    # Token-dense input (CJK etc.) holds more tokens per char than the 3.2
    # assumption — inflate the effective size so sizing decisions stay safe.
    dens = density_factor("".join(t for _, t in labeled[:8])[:200_000])
    eff_total = int(total * dens)
    # Remember whether --max-tokens came from the USER before the next line
    # resolves it for the DEFAULT model — consensus workers must not mistake
    # that derived number for an explicit choice and inherit it (R4).
    explicit_max_tokens = getattr(args, "max_tokens", None) is not None
    # Right-size the output budget to the actual work (A1): whole input if it
    # fits single-shot, else a chunk's worth.
    apply_output_budget(args, profile, total if eff_total <= single else chunk)

    if getattr(args, "dry_run", False):
        # D6: preview using the SAME sizing functions, then exit without a call.
        one_pass = eff_total <= single
        n_chunks = 1 if one_pass else len(pack_chunks(labeled, min(chunk, single)))
        n_calls = 1 if one_pass else n_chunks * 2  # + synthesis, mirrors cost_gate
        expected, bound, assumed = estimate_cost(
            catalog, model, total, n_calls, args.max_tokens)
        print("ambient audit plan (dry run — nothing sent):")
        print(f"  model:        {model} ({'reasoning' if profile.is_reasoning else 'direct'})")
        print(f"  input:        {total:,} chars across {len(labeled)} labeled item(s)")
        print(f"  output budget: {args.max_tokens:,} tokens/call")
        print(f"  strategy:     {'single-shot (one pass)' if one_pass else f'map-reduce → {n_chunks} chunks, up to {min(_resolve_parallel(args), n_chunks)} parallel + synthesis'}")
        print(f"  format:       {args.format}")
        print(f"  est. cost:    ~${expected:.2f} (hard bound ${bound:.2f})"
              + (" — assumed pricing" if assumed else ""))
        return

    if getattr(args, "consensus", None):
        # D8: run the same audit on several models; rank findings corroborated by
        # 2+ models first. Usually only ~2 models are READY at once — be honest.
        models = [m.strip() for m in args.consensus.split(",") if m.strip()]
        if len(models) < 2:
            usage_exit("--consensus needs at least two models (comma-separated).")
        cat_ids = [m.get("id") for m in catalog
                   if isinstance(m, dict) and m.get("id")]
        if cat_ids:
            # Pre-validate BEFORE any spend: a typo'd second model must not be
            # discovered after the first model's full paid audit (model sweep).
            unknown = [m for m in models if m not in cat_ids]
            if unknown:
                hints = []
                for u in unknown:
                    close = difflib.get_close_matches(u, cat_ids, n=1, cutoff=0.4)
                    hints.append(f"'{u}'"
                                 + (f" (did you mean: {close[0]}?)" if close else ""))
                cmsg = ("unknown consensus model(s): " + ", ".join(hints)
                        + " — nothing was run or billed.")
                if _json_mode(args):
                    emit_json_error("consensus", "usage", cmsg, api_key)
                sys.exit(f"ambient: {cmsg}")
        for m in models:
            note_if_hidden(m, conf, source="--consensus")
        # Price each model at its OWN rate with its OWN chunk count and budget
        # — the old models[0]-priced single-chunk-count estimate was ~30x off
        # on mixed pairs (Codex W2/3 HIGH: a small-window second model runs
        # many more calls than the default model's chunking suggests).
        parts, expected_sum, bound_sum = [], 0.0, 0.0
        for m in models:
            prof_m = model_profile(catalog, m)
            if total <= prof_m.single_shot_chars:
                n_calls_m = 1
            else:
                n_calls_m = max(1, len(pack_chunks(
                    labeled, min(prof_m.chunk_chars,
                                 prof_m.single_shot_chars))) * 2)
            exp_m, bnd_m, _a = estimate_cost(catalog, m, total, n_calls_m,
                                             prof_m.output_budget)
            expected_sum += exp_m
            bound_sum += bnd_m
            parts.append(f"{m.split('/')[-1]} ~${exp_m:.2f}")
        print(f"ambient: consensus estimated ~${expected_sum:.2f} "
              f"({' + '.join(parts)})", file=sys.stderr)
        # Pass the summed worst-case bound so the 3x-ceiling guard fires for
        # consensus too (a multi-model fan-out at large --max-tokens can be far
        # over the ceiling even when the 'expected' figure is under it).
        _gate_amount(expected_sum, args, conf, bound=bound_sum)
        agg = []
        failed = []
        # R4: each model derives its OWN profile budget — args.max_tokens was
        # resolved for the DEFAULT model above, and inheriting that number
        # would mis-budget every other model in the set. An explicit
        # --max-tokens from the user still applies to all of them.
        worker_args = args
        if not explicit_max_tokens:
            worker_args = argparse.Namespace(**vars(args))
            worker_args.max_tokens = None
        # R1: ONE shared gate caps TOTAL concurrent network calls across every
        # model's inner fan-out at the resolved width — without it N models ×
        # N chunks each = width² simultaneous calls (be kind to miners).
        gate = threading.Semaphore(_resolve_parallel(args))
        # R2: flipped on the first fatal error / Ctrl-C so every sibling's
        # map-reduce stops STARTING chunks — billing must not continue while
        # the consensus unwinds.
        cancel_event = threading.Event()
        # Fan the per-model audits out concurrently (each run_one_audit builds
        # its own isolated Namespace and pool, so nothing is shared-mutable);
        # aggregation below still walks the CALLER's model order, so ranking
        # and corroboration stay deterministic regardless of finish order.
        results_by_model = [None] * len(models)
        worker_errs = [None] * len(models)

        def _one_consensus_audit(m):
            print(f"ambient: consensus — auditing with {m}…", file=sys.stderr)
            return run_one_audit(m, catalog, labeled,
                                 AUDIT_SYSTEM_PROMPT + focus,
                                 worker_args, api_key, api_url, conf,
                                 gate=gate, cancel_event=cancel_event)

        cpool = concurrent.futures.ThreadPoolExecutor(
            max_workers=min(_resolve_parallel(args), len(models)))

        def _abort_consensus():
            cancel_event.set()
            try:
                cpool.shutdown(wait=False, cancel_futures=True)  # py3.9+
            except TypeError:
                cpool.shutdown(wait=False)                       # py3.8

        # The executor is managed EXPLICITLY: a `with` block would re-raise
        # only after ALL futures finish, so a fatal error or Ctrl-C would sit
        # waiting on every in-flight model while billing continued.
        try:
            futs = {cpool.submit(_one_consensus_audit, m): i
                    for i, m in enumerate(models)}
            for fut in concurrent.futures.as_completed(futs):
                i = futs[fut]
                try:
                    results_by_model[i] = fut.result()
                except ChatError as err:
                    if err.category in ("key", "funds"):
                        # Every sibling is doomed identically — cancel queued
                        # models, stop in-flight chunk starts, and surface the
                        # real problem NOW (the old sequential fail-fast).
                        _abort_consensus()
                        raise
                    worker_errs[i] = err
                except NetworkError:
                    # The API is unreachable for everyone — abort like the old
                    # sequential lane instead of draining N doomed models.
                    _abort_consensus()
                    raise
                except Exception as err:  # noqa: BLE001 — re-raised below in
                    # model order, preserving the sequential lane's semantics.
                    worker_errs[i] = err
        except KeyboardInterrupt:
            print("\nambient: cancelling consensus…", file=sys.stderr)
            _abort_consensus()
            raise
        cpool.shutdown(wait=True)
        first_err = next((e for e in worker_errs if e is not None), None)
        if first_err is not None:
            raise first_err
        for m, (findings, ok) in zip(models, results_by_model):
            if not ok:
                failed.append(m)
            for f in findings:
                if not isinstance(f, dict):
                    continue
                mm = re.match(r"^(.*?):(\d+)$", str(f.get("file", "")))
                if mm:
                    f["file"], f["line"] = mm.group(1), int(mm.group(2))
                path, line, title = _finding_sig(f)
                slot = None
                for s in agg:
                    sp, sl, st = s["sig"]
                    if sp == path and _titles_match(st, title) \
                            and abs(sl - line) <= 3:
                        slot = s
                        break
                if slot is None:
                    agg.append({"sig": (path, line, title), "f": f, "models": {m}})
                    continue
                slot["models"].add(m)
                if SEVERITY_ORDER.get(f.get("severity"), 9) < \
                        SEVERITY_ORDER.get(slot["f"].get("severity"), 9):
                    slot["f"] = f
        ranked = sorted(agg,
                        key=lambda s: (-len(s["models"]),
                                       SEVERITY_ORDER.get(s["f"].get("severity"), 9)))
        partial = bool(failed)
        if args.format == "json":
            # The agentic contract holds on consensus too (arch sweep HIGH:
            # --consensus --json used to print prose and exit 0 on 1-of-2).
            out_findings = [
                {**s["f"], "corroboration": {"models": sorted(s["models"]),
                                             "count": len(s["models"])}}
                for s in ranked
            ]
            emit_json(
                "consensus", model=",".join(models), api_key=api_key,
                findings=out_findings,
                verdict=_verdict_from([s["f"] for s in ranked], partial),
                partial=partial,
                reason=(f"{len(failed)}/{len(models)} model(s) returned no "
                        f"usable audit: {', '.join(failed)}" if failed else None),
                extra={"failed_models": failed},
                allow_partial=getattr(args, "allow_partial", False))
            return
        print(f"Consensus audit across {len(models)} models "
              f"({', '.join(models)}) — corroborated findings first:\n")
        if failed:
            print(f"⚠ {len(failed)}/{len(models)} model(s) did NOT return a usable "
                  f"audit ({', '.join(failed)}) — coverage is INCOMPLETE, not a "
                  "clean pass.\n", file=sys.stderr)
        if not ranked:
            if len(failed) == len(models):
                print("No usable audit from any model (all failed/unready) — this "
                      "is NOT a clean result. Retry or check `ambient models`.")
                sys.exit(EXIT_PARTIAL)
            print("No defects found by the models that responded.")
        for s in ranked:
            f = s["f"]
            tag = f"[{len(s['models'])}/{len(models)} models]"
            print(redact(f"{tag} [{f.get('severity', '?')}] "
                         f"{f.get('file', '?')}:{f.get('line', '?')} — "
                         f"{f.get('title', '')}", api_key))
            if f.get("scenario"):
                print(redact(f"    {f['scenario']}", api_key))
        if partial and not getattr(args, "allow_partial", False):
            # Some models failed: a 1-of-2 audit is NOT a clean pass (arch
            # sweep HIGH) — exit like every other partial surface.
            sys.exit(EXIT_PARTIAL)
        return

    # A4: structured findings output (--json/--format report). Gate the request
    # on the model's real capability; append the shape when it lacks strict schema.
    structured = args.format in ("json", "report")
    sys_prompt = AUDIT_SYSTEM_PROMPT + focus
    reducer = None
    if structured:
        rf = response_format_for(profile, AUDIT_FINDINGS_SCHEMA)
        args.response_format = rf
        if rf is None or rf.get("type") == "json_object":
            sys_prompt += AUDIT_JSON_INSTRUCTION
        reducer = findings_reducer

    def emit_single(content, body):
        truncated = (bool(body.get("salvaged_partial"))
                     or body.get("finish_reason") == "length")
        if structured:
            eff = render_findings(
                content, args.format, api_key, truncated,
                "output salvaged/truncated (hit token cap)" if truncated else "",
                model=model)
            if eff and not getattr(args, "allow_partial", False):
                sys.exit(EXIT_PARTIAL)
        else:
            render_result(content, truncated,
                          "output was salvaged/truncated", args, api_key,
                          None, model)

    if eff_total <= single:
        # A large single pass is still real spend — gate it like the map path
        # instead of skipping the estimate entirely (resilience sweep MED).
        if total > 150_000:
            cost_gate(catalog, model, total, 1, args, conf)
        messages = [
            {"role": "system", "content": sys_prompt},
            {"role": "user", "content": files_block(labeled)},
        ]
        try:
            content, _usage, body = complete(api_key, api_url, model, messages, args)
            emit_single(content, body)
            return
        except ChatError as err:
            if err.category not in ("empty", "context"):
                _fail(args, "audit", err, api_key)
            print(
                f"ambient: '{model}' couldn't finish the whole input in one pass "
                "— splitting into smaller pieces for the same model",
                file=sys.stderr,
            )
    # Recovery chunk size: never exceed the single-shot budget (a 20k floor
    # would top a 16k-output reasoner's ~17.6k single — Codex fix), and shrink
    # for token-dense input so chunks can't 400 on context.
    chunk_chars = min(chunk if eff_total > single else max(total // 3 + 1000, 20_000),
                      single)
    chunk_chars = max(MIN_REASONING_CHUNK, int(chunk_chars / dens))
    packed = pack_chunks(labeled, chunk_chars)
    cost_gate(catalog, model, total, len(packed) * 2, args, conf)
    final, partial, reason = run_map_reduce(
        api_key, api_url, model, sys_prompt,
        packed, args, AUDIT_SYNTH_PROMPT, single, reducer=reducer,
        code_map=build_code_map(labeled),
    )
    if structured:
        eff = render_findings(final, args.format, api_key, partial, reason,
                              model=model)
        if eff and not getattr(args, "allow_partial", False):
            sys.exit(EXIT_PARTIAL)
    else:
        render_result(final, partial, reason, args, api_key)


def cmd_code(args, api_key, api_url, conf):
    task = " ".join(args.task).strip()
    if not task:
        usage_exit('describe the task: '
                   'ambient code "write a rate limiter" -f context.py')
    warn_if_stdin_ignored("`code` does not read stdin — pass context with -f FILE")
    refuse_if_secrets([("task", task)], args.allow_secrets)
    model = resolve_model(args, conf, "code")
    if getattr(args, "model", None):
        note_if_hidden(args.model, conf)
    catalog = safe_catalog(api_url, api_key)
    # cmd_code previously used raw model_budget with NO reasoning cap, so its
    # default reasoner (kimi-k2.7-code) marathoned on large -f context. The
    # profile fixes that: reasoning-awareness is intrinsic.
    profile = model_profile(catalog, model)
    single, chunk = profile.single_shot_chars, profile.chunk_chars
    if len(task) > single:
        # No-refusal invariant covers the task string too (arch sweep HIGH):
        # distill an oversized brief down to what generation needs.
        print(
            "ambient: task brief exceeds this model's window — distilling it first",
            file=sys.stderr,
        )
        apply_output_budget(args, profile, chunk)
        packed = pack_chunks([("task", task)],
                             max(MIN_REASONING_CHUNK,
                                 int(chunk / density_factor(task))))
        cost_gate(catalog, model, len(task), len(packed) * 2 + 1, args, conf)
        task, t_partial, t_reason = run_map_reduce(
            api_key, api_url, model,
            "From the given chunk of a long task brief, extract every "
            "requirement, constraint, and verbatim detail needed to do the work.",
            packed, args,
            "Merge these extracts into one concise, complete task brief, "
            "preserving verbatim requirements and constraints.",
            single,
        )
        if t_partial and not getattr(args, "allow_partial", False):
            _fail_exit(
                args, "code", "partial",
                f"task-brief distillation was incomplete ({t_reason}) — "
                "re-run, shorten the brief, or pass --allow-partial.",
                api_key=api_key,
            )
        if getattr(args, "_auto_budget", False):
            args.max_tokens = None  # re-derive below for the generation pass
    # Size the budget for the final generation input (task + context, capped at
    # single since oversized context is distilled below to <= single). A1.
    ctx_len = 0
    for p in (args.context or []):
        try:
            ctx_len += os.path.getsize(p)
        except OSError:
            pass
    apply_output_budget(args, profile, min(len(task) + ctx_len, single))
    context = ""
    if args.context:
        chunks = read_files(args.context)
        refuse_if_secrets(chunks, args.allow_secrets)
        context = files_block(chunks)
        if len(context) > single:
            # Distill oversized context down to what the task needs, then code.
            print(
                "ambient: context exceeds this model's window — distilling it first",
                file=sys.stderr,
            )
            packed = pack_chunks(chunks,
                                 max(MIN_REASONING_CHUNK,
                                     int(chunk / density_factor(context))))
            # +1 call for the final generation pass after distillation.
            cost_gate(catalog, model, len(context), len(packed) * 2 + 1, args, conf)
            context, partial, reason = run_map_reduce(
                api_key, api_url, model,
                f"TASK: {task}\nFrom the given chunk of context files, extract "
                "verbatim every part (signatures, types, conventions, key logic) "
                "a senior engineer would need to do the task. Be selective.",
                packed, args,
                f"TASK: {task}\nMerge these context extracts into one concise, "
                "non-redundant context brief preserving verbatim signatures/types.",
                single,
            )
            if partial and not getattr(args, "allow_partial", False):
                _fail_exit(
                    args, "code", "partial",
                    f"context distillation was incomplete ({reason}) — "
                    "the generated code could miss cross-file details. Re-run, "
                    "narrow the context, or pass --allow-partial to proceed anyway.",
                    api_key=api_key,
                )
            room = max(1000, single - len(task) - 500)
            if len(context) > room:
                # A partial distillation can fall back to raw concatenation far
                # above `single`; proceeding would 400 the paid-for generation
                # call (resilience sweep LOW). Clamp with an honest marker.
                context = context[:room] + "\n[ambient: context truncated to fit]"
    user_content = task if not context else f"{task}\n\nContext files:\n\n{context}"
    messages = [
        {
            "role": "system",
            "content": (
                "You are a senior software engineer. Produce complete, correct, "
                "production-quality code. Include brief usage notes. No placeholders."
            ),
        },
        {"role": "user", "content": user_content},
    ]
    chat(api_key, api_url, model, messages, args, kind="code")


BUILD_PLAN_SCHEMA = {
    "type": "object",
    "additionalProperties": False,
    "properties": {
        "plan": {
            "type": "array",
            "items": {
                "type": "object",
                "additionalProperties": False,
                "properties": {
                    "path": {"type": "string"},
                    "purpose": {"type": "string"},
                    "est_lines": {"type": "integer"},
                },
                "required": ["path", "purpose", "est_lines"],
            },
        },
        "notes": {"type": "string"},
        "advisory_steps": {"type": "array", "items": {"type": "string"}},
    },
    "required": ["plan", "notes", "advisory_steps"],
}

BUILD_FILES_SCHEMA = {
    "type": "object",
    "additionalProperties": False,
    "properties": {
        "files": {
            "type": "array",
            "items": {
                "type": "object",
                "additionalProperties": False,
                "properties": {
                    "path": {"type": "string"},
                    "content": {"type": "string"},
                },
                "required": ["path", "content"],
            },
        },
    },
    "required": ["files"],
}

BUILD_PLAN_PROMPT = """You are a senior software engineer planning a build.
Given a task (and optional context), design the complete set of files to create.
Output ONLY a JSON object matching the requested schema. Path rules: RELATIVE,
forward slashes, no '..' segments, no leading '/', never under .git, no
credential-style files (.env, id_rsa, *.pem, credentials.json). Keep the set
minimal but COMPLETE — a working result, not a sketch. est_lines = your honest
line-count estimate per file. advisory_steps = commands the USER may want to run
afterwards (install deps, run tests) — informational text only, they will NOT be
executed. notes = 1-3 sentences on the design."""

BUILD_JSON_INSTRUCTION_PLAN = (
    "\n\nOUTPUT FORMAT: return ONLY a JSON object (no prose, no markdown fences) "
    'matching: {"plan":[{"path":str,"purpose":str,"est_lines":int}],'
    '"notes":str,"advisory_steps":[str]}'
)

BUILD_GEN_PROMPT = """You are a senior software engineer generating COMPLETE files
for a planned build. Output ONLY a JSON object matching the requested schema.
Produce the FULL content of every requested file — production quality, no
placeholders, no TODOs, imports correct across files. Use exactly the requested
relative paths. Do not add commentary outside the JSON."""

BUILD_JSON_INSTRUCTION_FILES = (
    "\n\nOUTPUT FORMAT: return ONLY a JSON object (no prose, no markdown fences) "
    'matching: {"files":[{"path":str,"content":str}]}'
)


def safe_relpath(path, root):
    """Path-traversal firewall for manifest writes (security sweep P0). Model
    output is UNTRUSTED: any path it names must resolve to a plain relative
    location strictly inside `root`, or be rejected VERBATIM with a reason —
    never 'fixed' (fixing invites smuggling). Blocks the zip-slip family:
    absolute paths, drive/UNC prefixes, .. segments, ~ references, .git
    internals, credential-named files, control characters, and symlinked
    ancestors/destinations that physically escape the root. Returns the
    normalized relative path or raises ValueError."""
    if not isinstance(path, str) or not path.strip():
        raise ValueError("empty path")
    p = path.strip().replace("\\", "/")
    if any(ord(c) < 0x20 or ord(c) == 0x7F for c in p):
        raise ValueError("control characters in path")
    if len(p) > 1024:
        raise ValueError("path too long")
    # Explicit leading-slash check: Windows py3.13 changed ntpath.isabs to
    # False for drive-relative "/x" paths — a leading slash always signals
    # absolute intent and is rejected on every platform (Windows CI finding).
    if p.startswith("/") or os.path.isabs(p) or re.match(r"^[A-Za-z]:", p):
        raise ValueError("absolute/drive path")
    parts = [seg for seg in p.split("/") if seg not in ("", ".")]
    if not parts:
        raise ValueError("empty path")
    for seg in parts:
        # Alias-fold BEFORE comparing: Windows strips trailing dots/spaces and
        # default macOS filesystems are case-insensitive, so '.Git ' would hit
        # the real .git while dodging an exact match (Codex W4/5 MED).
        folded = seg.rstrip(". ").lower()
        if seg == ".." or folded == "..":
            raise ValueError("parent-directory escape")
        if seg.startswith("~"):
            raise ValueError("home-directory reference")
        if folded == ".git":
            raise ValueError(".git internals are off-limits")
        if folded.startswith(".ambient-build"):
            raise ValueError("reserved ambient-build name")
        if not folded:
            raise ValueError("empty path segment")
    if SECRET_NAMES_RE.search(parts[-1]):
        raise ValueError("credential-named file")
    root_real = os.path.realpath(root)
    dest = os.path.join(root_real, *parts)
    # A symlinked EXISTING ancestor can point outside while the lexical path
    # stays inside — realpath resolves what exists and keeps the rest lexical.
    parent_real = os.path.realpath(os.path.dirname(dest))
    if parent_real != root_real and \
            not parent_real.startswith(root_real + os.sep):
        raise ValueError("resolves outside the target directory (symlink escape)")
    if os.path.islink(dest):
        raise ValueError("destination is an existing symlink")
    return "/".join(parts)


def _build_state_path(root):
    return os.path.join(root, ".ambient-build.json")


def _save_build_state(root, state):
    """Atomic 0600 resume-state write; best-effort (a state failure must never
    kill a run whose results are already in memory)."""
    try:
        os.makedirs(root, exist_ok=True)
        fd, tmp = tempfile.mkstemp(dir=root, prefix=".ambient-build-")
        with os.fdopen(fd, "w", encoding="utf-8") as fh:
            json.dump(state, fh)
        os.replace(tmp, _build_state_path(root))
        os.chmod(_build_state_path(root), 0o600)
    except OSError as err:
        print(f"ambient: could not save build resume-state ({err})",
              file=sys.stderr)


def _load_build_state(root, task_sha):
    """Resume state is UNTRUSTED data (any process could have written it):
    every path re-fires through the firewall and every record's hash is
    re-verified, or the state is discarded — a poisoned state file must not
    become a --dir escape on the next --apply (Codex W4/5 HIGH)."""
    try:
        with open(_build_state_path(root), encoding="utf-8") as fh:
            st = json.load(fh)
    except (OSError, json.JSONDecodeError):
        return None
    if not (isinstance(st, dict) and st.get("version") == 1
            and st.get("task_sha") == task_sha
            and isinstance(st.get("plan"), list)
            and isinstance(st.get("done"), dict)):
        return None
    try:
        plan = []
        for item in st["plan"][:512]:
            if not isinstance(item, dict):
                return None
            item = dict(item)
            item["path"] = safe_relpath(str(item.get("path", "")), root)
            plan.append(item)
        done = {}
        for k, rec in st["done"].items():
            rel = safe_relpath(str(k), root)
            if not (isinstance(rec, dict)
                    and isinstance(rec.get("content"), str)):
                return None
            digest = hashlib.sha256(rec["content"].encode()).hexdigest()
            if rec.get("sha256") != digest:
                return None  # tampered or torn — start fresh
            done[rel] = {"content": rec["content"], "sha256": digest}
    except ValueError:
        print("ambient: previous build state contained unsafe paths — "
              "ignoring it and starting fresh", file=sys.stderr)
        return None
    st["plan"], st["done"] = plan, done
    if not isinstance(st.get("failed"), list):
        st["failed"] = []
    return st


def cmd_build(args, api_key, api_url, conf):
    """Native agentic build (Codex-parity lane): plan → generate → emit a FILE
    MANIFEST. Writes happen ONLY inside --dir, only with --apply (+ --yes when
    headless), through the safe_relpath firewall. NOTHING is ever executed —
    advisory_steps are printed as text. Truncation requeues files in smaller
    batches; state in .ambient-build.json makes any interrupted run resumable
    without re-billing finished files."""
    task = " ".join(args.task).strip()
    if not task:
        usage_exit('describe what to build: '
                   'ambient build "a flask todo API with tests" --dir out')
    warn_if_stdin_ignored("`build` does not read stdin — pass context with -f FILE")
    refuse_if_secrets([("task", task)], args.allow_secrets)
    root = os.path.abspath(os.path.expanduser(args.dir or "."))
    headless = not sys.stdin.isatty()
    if args.apply and headless:
        if not args.dir:
            usage_exit("headless --apply requires an explicit --dir "
                       "(refusing to write into an implicit working directory)")
        if not args.yes:
            usage_exit("headless --apply also requires --yes "
                       "(explicit consent to write files)")
    model = resolve_model(args, conf, "code")
    if getattr(args, "model", None):
        note_if_hidden(args.model, conf)
    catalog = safe_catalog(api_url, api_key)
    profile = model_profile(catalog, model)
    single = profile.single_shot_chars
    # Generation wants the full budget: reasoning + several complete files.
    apply_output_budget(args, profile, single)

    context = ""
    # Digest of the RAW (pre-distillation) context so that editing any -f file
    # invalidates the resume cache (task_sha) instead of serving a stale plan.
    raw_context_sha = ""
    needs_distill = False
    packed = None
    if args.context:
        chunks = read_files(args.context)
        refuse_if_secrets(chunks, args.allow_secrets)
        context = files_block(chunks)
        raw_context_sha = hashlib.sha256(context.encode()).hexdigest()
        needs_distill = len(context) > single // 2
        if needs_distill:
            # Offline (no egress) — computed once so the dry-run estimate below
            # and the live distillation both use the REAL packed-chunk count.
            packed = pack_chunks(chunks,
                                 max(MIN_REASONING_CHUNK,
                                     int(profile.chunk_chars
                                         / density_factor(context))))

    # DRY RUN spends nothing and egresses nothing — decide + return BEFORE the
    # context-distillation map-reduce, which makes billed calls and sends file
    # contents to the network. A flag that says "nothing sent" must send nothing.
    if getattr(args, "dry_run", False):
        # A live run distills first: len(packed)*2+1 extra calls (offline count).
        n_calls = max(2, args.max_files // 4 + 2) + (
            len(packed) * 2 + 1 if needs_distill else 0)
        expected, bound, assumed = estimate_cost(
            catalog, model, len(task) + len(context), n_calls, args.max_tokens)
        print("ambient build plan (dry run — nothing sent):")
        print(f"  model:         {model} "
              f"({'reasoning' if profile.is_reasoning else 'direct'})")
        print(f"  task:          {len(task):,} chars"
              + (f" + context {len(context):,} chars" if context else ""))
        if needs_distill:
            print("  note:          context exceeds half the window — a live "
                  "run distills it first (extra billed calls)")
        print(f"  output budget: {args.max_tokens:,} tokens/call")
        print(f"  target dir:    {root} "
              f"({'writes ON (--apply)' if args.apply else 'manifest only'})")
        print(f"  caps:          ≤{args.max_files} files, "
              f"≤{args.max_file_bytes:,} bytes/file")
        print(f"  est. cost:     ~${expected:.2f} (hard bound ${bound:.2f})"
              + (" — assumed pricing" if assumed else ""))
        return

    # LIVE path only: distill an oversized context now that dry-run is ruled out.
    if needs_distill:
        print("ambient: context exceeds half this model's window — "
              "distilling it first", file=sys.stderr)
        # `packed` was computed offline above (reused here — no recompute).
        cost_gate(catalog, model, len(context), len(packed) * 2 + 1,
                  args, conf)
        context, c_partial, c_reason = run_map_reduce(
            api_key, api_url, model,
            f"TASK: {task}\nFrom the given chunk of context files, extract "
            "verbatim every part (signatures, types, conventions, key "
            "logic) needed to build the task. Be selective.",
            packed, args,
            f"TASK: {task}\nMerge these context extracts into one concise "
            "brief preserving verbatim signatures/types.",
            single,
        )
        if c_partial and not getattr(args, "allow_partial", False):
            _fail_exit(args, "build", "partial",
                       f"context distillation was incomplete ({c_reason}) — "
                       "re-run, narrow -f, or pass --allow-partial.",
                       api_key=api_key)
        context = context[:max(1000, single // 2)]

    task_sha = hashlib.sha256(
        (f"{task}\0{model}\0{','.join(sorted(args.context or []))}"
         f"\0{raw_context_sha}").encode()
    ).hexdigest()
    state = None if args.no_resume else _load_build_state(root, task_sha)
    if state:
        print(f"ambient: previous run found for this exact task — resuming "
              f"({len(state['done'])} file(s) already generated; "
              "--no-resume starts fresh)", file=sys.stderr)

    def _ns_with(rf, system_extra=""):
        a = argparse.Namespace(**vars(args))
        a.response_format = rf
        return a, system_extra

    # ---- PHASE 1: PLAN (one cheap call) ------------------------------------
    if state is None:
        rf = response_format_for(profile, BUILD_PLAN_SCHEMA)
        pa, extra = _ns_with(
            rf, "" if (rf and rf.get("type") == "json_schema")
            else BUILD_JSON_INSTRUCTION_PLAN)
        user = f"TASK: {task}"
        if context:
            user += f"\n\nContext files:\n\n{context}"
        # Gate the (cheap) planning call too so AMBIENT_MAX_SPEND is a true
        # ceiling across BOTH phases, not just generation.
        cost_gate(catalog, model, len(task) + len(context), 1, args, conf)
        obj = None
        for attempt in (1, 2):
            try:
                content, _u, _b = complete(
                    api_key, api_url, model,
                    [{"role": "system", "content": BUILD_PLAN_PROMPT + extra},
                     {"role": "user", "content": user}], pa)
            except ChatError as err:
                _fail(args, "build",
                      ChatError(err.category,
                                f"planning failed — {err.diagnosis}"),
                      api_key)
            obj = extract_json(content)
            if obj and isinstance(obj.get("plan"), list) and obj["plan"]:
                break
            if attempt == 1:
                print("ambient: plan reply wasn't valid JSON — asking once "
                      "more", file=sys.stderr)
                user += ("\n\nREMINDER: return ONLY the JSON object, no prose, "
                         "no fences.")
        if not obj or not isinstance(obj.get("plan"), list) or not obj["plan"]:
            pmsg = ("the model did not produce a usable build plan "
                    "— try rephrasing the task or another model (-m)")
            if _json_mode(args):
                emit_json_error("build", "model", pmsg, api_key)
            sys.exit(f"ambient: {pmsg}")
        plan, bad = [], []
        for item in obj["plan"][:args.max_files]:
            if not isinstance(item, dict) or not item.get("path"):
                continue
            try:
                item["path"] = safe_relpath(str(item["path"]), root)
                plan.append(item)
            except ValueError as why:
                bad.append({"path": str(item.get("path")), "reason": f"unsafe path: {why}"})
        if len(obj["plan"]) > args.max_files:
            print(f"ambient: plan capped at {args.max_files} files "
                  f"(model proposed {len(obj['plan'])}; raise with "
                  "--max-files)", file=sys.stderr)
        if not plan:
            rmsg = ("every planned path was rejected as unsafe — not "
                    "proceeding. (This usually means a poisoned or confused "
                    "reply; try again.)")
            if _json_mode(args):
                emit_json_error("build", "model", rmsg, api_key)
            sys.exit(f"ambient: {rmsg}")
        state = {"version": 1, "task_sha": task_sha, "plan": plan,
                 "notes": str(obj.get("notes", ""))[:2000],
                 "advisory_steps": [str(s)[:300] for s in
                                    (obj.get("advisory_steps") or [])[:20]],
                 "done": {}, "failed": bad}
        _save_build_state(root, state)

    plan = state["plan"]
    plan_paths = {p["path"] for p in plan}   # the reviewed plan is a CONTRACT
    advisory = state.get("advisory_steps") or []
    if getattr(args, "plan_only", False):
        if args.json:
            po_failed = state.get("failed") or []
            emit_json("build", model=model, api_key=api_key,
                      partial=bool(po_failed),
                      reason=(f"{len(po_failed)} planned path(s) rejected: "
                              + "; ".join(f"{f['path']} ({f['reason']})"
                                          for f in po_failed[:10])
                              if po_failed else None),
                      allow_partial=getattr(args, "allow_partial", False),
                      extra={"root": root, "plan": plan,
                             "notes": state.get("notes", ""),
                             "advisory_steps": advisory,
                             "failed": po_failed,
                             "written": False})
            return
        print(f"Build plan for: {task}\n")
        for item in plan:
            print(f"  {item['path']:44} ~{item.get('est_lines', '?')} lines  "
                  f"{item.get('purpose', '')}")
        if state.get("notes"):
            print(f"\n{state['notes']}")
        print("\nGenerate with the same command minus --plan-only "
              "(the plan is cached — planning is not re-billed).")
        return

    # ---- PHASE 2: GENERATE (batched, truncation-safe) ----------------------
    done = dict(state["done"])   # path -> {"content":…, "sha256":…}
    failed = [f for f in (state.get("failed") or [])
              if str(f.get("reason", "")).startswith("unsafe path")]
    # Paths the model returned that are NOT in the approved plan: never written,
    # surfaced as a warning, but NOT counted as a failure — a chatty extra file
    # must not turn a fully-delivered plan into a partial/exit-2 result.
    dropped = []
    todo = [p for p in plan if p["path"] not in done]
    est = {p["path"]: max(200, _as_pos_int(p.get("est_lines"), 50) * 40)
           for p in todo}
    # Answer-share heuristic: the output budget covers reasoning + JSON quoting
    # overhead; keep batches well under it so truncation is the exception.
    batch_budget = max(4000, int(args.max_tokens * CHARS_PER_TOKEN * 0.35))
    batches, cur, cur_sz = [], [], 0
    for p in todo:
        if cur and cur_sz + est[p["path"]] > batch_budget:
            batches.append(cur)
            cur, cur_sz = [], 0
        cur.append(p)
        cur_sz += est[p["path"]]
    if cur:
        batches.append(cur)
    plan_overview = "\n".join(
        f"  {p['path']} — {p.get('purpose', '')}" for p in plan)
    # Bounded retry tree: splits + per-file retries can multiply calls far past
    # len(batches), so the gate must price the CAP, and the loop must enforce
    # it — a model that keeps omitting files can't drive unbounded spend
    # (Codex W4/5 HIGH).
    max_gen_calls = 3 * max(1, len(todo)) + 4
    gen_calls = 0
    if batches:
        prompt_chars = len(task) + len(context) + len(plan_overview) + 2000
        expected, _b1, assumed = estimate_cost(
            catalog, model, prompt_chars * len(batches),
            len(batches) + 2, args.max_tokens)
        _e2, bound, _a2 = estimate_cost(
            catalog, model, prompt_chars * max_gen_calls,
            max_gen_calls, args.max_tokens)
        print(f"ambient: build estimated ~${expected:.2f} "
              f"(hard bound ${bound:.2f} at the retry cap)"
              + (" — assumed worst-case pricing" if assumed else ""),
              file=sys.stderr)
        _gate_amount(expected, args, conf, bound=bound)
    rf_files = response_format_for(profile, BUILD_FILES_SCHEMA)
    gen_extra = ("" if (rf_files and rf_files.get("type") == "json_schema")
                 else BUILD_JSON_INSTRUCTION_FILES)
    attempts = {}
    queue = list(batches)
    while queue:
        batch = queue.pop(0)
        if gen_calls >= max_gen_calls:
            for p in batch:
                if p["path"] not in done:
                    failed.append({"path": p["path"],
                                   "reason": "generation call budget exhausted "
                                             "(bounded spend) — re-run to "
                                             "resume where this stopped"})
            continue
        want = [p["path"] for p in batch]
        already = "\n".join(f"  {k}" for k in done) or "  (none yet)"
        user = (f"TASK: {task}\n\nFULL PLAN (for cross-file consistency):\n"
                f"{plan_overview}\n\nALREADY GENERATED (do not repeat):\n"
                f"{already}\n\nGENERATE NOW — complete content for exactly "
                "these files:\n"
                + "\n".join(f"  {p['path']} — {p.get('purpose', '')}"
                            for p in batch))
        if context:
            user += f"\n\nContext:\n{context}"
        ga, _x = _ns_with(rf_files)
        gen_calls += 1
        try:
            content, _u, body = complete(
                api_key, api_url, model,
                [{"role": "system", "content": BUILD_GEN_PROMPT + gen_extra},
                 {"role": "user", "content": user}], ga)
        except ChatError as err:
            if len(batch) > 1:
                mid = len(batch) // 2
                queue.insert(0, batch[mid:])
                queue.insert(0, batch[:mid])
                print(f"ambient: batch of {len(batch)} failed "
                      f"([{err.category}]) — retrying as two smaller batches",
                      file=sys.stderr)
                continue
            failed.append({"path": want[0],
                           "reason": f"[{err.category}] {err.diagnosis}"[:300]})
            continue
        obj = extract_json(content)
        truncated = (body.get("finish_reason") == "length"
                     or bool(body.get("salvaged_partial"))
                     or not obj or bool(obj.get("_repaired")))
        got = {}
        if obj and isinstance(obj.get("files"), list):
            for f in obj["files"]:
                if not isinstance(f, dict) or not isinstance(f.get("content"), str):
                    continue
                try:
                    rel = safe_relpath(str(f.get("path", "")), root)
                except ValueError as why:
                    failed.append({"path": str(f.get("path")),
                                   "reason": f"unsafe path: {why}"})
                    continue
                if rel not in plan_paths:
                    # The reviewed plan is the contract: refuse any path the
                    # user never approved (guards --plan-only review, the
                    # --max-files cap, and prompt-injected extra files). Record
                    # it as a DROP (surfaced) — not a failure — so delivering
                    # every approved file still yields status ok.
                    if rel not in dropped:
                        dropped.append(rel)
                    continue
                if len(f["content"].encode()) > args.max_file_bytes:
                    failed.append({"path": rel,
                                   "reason": f"file exceeds --max-file-bytes "
                                             f"({args.max_file_bytes:,})"})
                    continue
                got[rel] = f["content"]
        if truncated and got:
            # The LAST file in a cut stream may itself be cut — trust only the
            # ones before it; the rest requeue whole (unit of atomicity = file).
            emitted_order = [r for r in got]
            got.pop(emitted_order[-1], None)
        for rel, body_text in got.items():
            done[rel] = {"content": body_text,
                         "sha256": hashlib.sha256(body_text.encode()).hexdigest()}
        state["done"] = done
        state["failed"] = failed
        _save_build_state(root, state)
        missing = [p for p in batch
                   if p["path"] not in done
                   and p["path"] not in {f["path"] for f in failed}]
        if missing:
            if len(batch) > 1:
                mid = max(1, len(missing) // 2)
                for half in (missing[mid:], missing[:mid]):
                    if half:
                        queue.insert(0, half)
                print(f"ambient: {len(missing)} file(s) missing/cut from that "
                      "reply — regenerating in smaller batches "
                      "(input re-billed)", file=sys.stderr)
            else:
                path0 = missing[0]["path"]
                attempts[path0] = attempts.get(path0, 0) + 1
                if attempts[path0] < 2:
                    queue.insert(0, missing)
                    print(f"ambient: {path0} came back incomplete — one more "
                          "attempt", file=sys.stderr)
                else:
                    failed.append({"path": path0,
                                   "reason": "output exceeded one response "
                                             "even alone — split this file "
                                             "into smaller modules"})
    state["failed"] = failed
    _save_build_state(root, state)

    # ---- EMIT + optional APPLY ---------------------------------------------
    partial = bool(failed)
    total_bytes = sum(len(v["content"].encode()) for v in done.values())
    written = False
    actions = {}
    if args.apply and done:
        proceed = True
        if not headless and not args.yes:
            try:
                ans = input(f"Write {len(done)} file(s) ({total_bytes:,} bytes) "
                            f"into {root}? [y/N] ").strip().lower()
            except (EOFError, KeyboardInterrupt):
                ans = ""
            proceed = ans in ("y", "yes")
        if proceed:
            bak_dir = os.path.join(root, ".ambient-build.bak",
                                   time.strftime("%Y%m%d-%H%M%S"))
            for rel, rec in sorted(done.items()):
                dest = os.path.join(root, *rel.split("/"))
                # Re-validate the parent BEFORE any lexists/backup touches the
                # path — a parent swapped to a symlink after generation could
                # otherwise make the --force backup drag an OUTSIDE file into
                # .ambient-build.bak (Codex final HIGH, reproduced).
                root_real0 = os.path.realpath(root)
                parent_real0 = os.path.realpath(os.path.dirname(dest))
                if parent_real0 != root_real0 and \
                        not parent_real0.startswith(root_real0 + os.sep):
                    actions[rel] = "write-failed"
                    failed.append({"path": rel,
                                   "reason": "parent escaped the target "
                                             "directory before write"})
                    partial = True
                    continue
                action = "create"
                if os.path.lexists(dest):
                    # Idempotent re-run: an existing file whose content already
                    # matches is an "unchanged" no-op, NOT a partial result —
                    # so re-running a finished build exits 0, not 2.
                    if os.path.isfile(dest) and not os.path.islink(dest):
                        try:
                            # newline="" so CRLF/CR content round-trips byte-
                            # faithfully — universal-newline translation would
                            # otherwise defeat the sha compare and a completed
                            # CRLF build would never read back as "unchanged".
                            with open(dest, encoding="utf-8",
                                      errors="replace", newline="") as fh:
                                cur = fh.read()
                        except OSError:
                            cur = None
                        if cur is not None and hashlib.sha256(
                                cur.encode()).hexdigest() == rec["sha256"]:
                            actions[rel] = "unchanged"
                            continue
                    if not args.force:
                        actions[rel] = "skip-exists"
                        partial = True
                        continue
                    action = "overwrite"
                    try:
                        bpath = os.path.join(bak_dir, *rel.split("/"))
                        os.makedirs(os.path.dirname(bpath), exist_ok=True)
                        os.replace(dest, bpath)
                    except OSError as err:
                        # Backup failed — REFUSE to overwrite. Silently
                        # destroying the user's original file (while reporting
                        # "overwrite") is disqualifying for an official plugin.
                        actions[rel] = "write-failed"
                        failed.append(
                            {"path": rel,
                             "reason": f"backup failed, refused to overwrite "
                                       f"without a backup: {err}"})
                        partial = True
                        continue
                try:
                    os.makedirs(os.path.dirname(dest), exist_ok=True)
                    # Re-validate IMMEDIATELY before writing: a parent dir
                    # could have been swapped for a symlink after the earlier
                    # firewall check (Codex W4/5 MED TOCTOU).
                    root_real = os.path.realpath(root)
                    parent_real = os.path.realpath(os.path.dirname(dest))
                    if parent_real != root_real and \
                            not parent_real.startswith(root_real + os.sep):
                        raise OSError("parent escaped the target directory")
                    fd, tmp = tempfile.mkstemp(
                        dir=os.path.dirname(dest), prefix=".ambient-")
                    # newline="" writes the model's content byte-faithfully (no
                    # \n->\r\n translation), so the manifest sha matches disk on
                    # every platform and re-runs read back as "unchanged".
                    with os.fdopen(fd, "w", encoding="utf-8",
                                   newline="") as fh:
                        fh.write(rec["content"])
                    if os.path.islink(dest):
                        raise OSError("destination became a symlink")
                    os.replace(tmp, dest)  # plain file perms; never executable
                    actions[rel] = action
                except OSError as err:
                    actions[rel] = "write-failed"
                    failed.append({"path": rel, "reason": f"write failed: {err}"})
                    partial = True
            written = True
        else:
            print("ambient: not written (declined) — the manifest below is "
                  "cached in .ambient-build.json; re-run with --apply --yes "
                  "to write without asking", file=sys.stderr)
    files_out = [{"path": rel, "bytes": len(rec["content"].encode()),
                  "sha256": rec["sha256"],
                  "action": actions.get(rel, "generated" if not written
                                        else "create")}
                 for rel, rec in sorted(done.items())]
    reason = None
    if failed:
        reason = f"{len(failed)} file(s) failed: " + "; ".join(
            f"{f['path']} ({f['reason']})" for f in failed[:10])
    elif partial:
        # partial with no hard failures = files skipped because they already
        # exist and --force was not given. A partial must never be reason-less.
        skipped = [r for r, a in actions.items() if a == "skip-exists"]
        if skipped:
            reason = (f"{len(skipped)} file(s) already exist and were left "
                      "unchanged (pass --force to overwrite): "
                      + ", ".join(skipped[:10]))
    if args.json:
        emit_json("build", model=model, api_key=api_key,
                  partial=partial, reason=reason,
                  allow_partial=getattr(args, "allow_partial", False),
                  extra={"root": root, "files": files_out, "failed": failed,
                         "dropped": dropped,
                         "advisory_steps": advisory,
                         "notes": state.get("notes", ""),
                         "written": written, "total_bytes": total_bytes})
        return
    print(f"\nBuild result for: {task}")
    print(f"  target: {root} "
          f"({'WRITTEN' if written else 'manifest only — re-run with --apply to write'})")
    for f in files_out:
        print(f"  {f['action']:>11}  {f['path']:44} {f['bytes']:>8,} bytes")
    for f in failed:
        print(redact(f"       FAILED  {f['path']:44} {f['reason']}", api_key))
    for d in dropped:
        print(f"      DROPPED  {d:44} not in the approved plan (not written)")
    if state.get("notes"):
        print(f"\n{redact(state['notes'], api_key)}")
    if advisory:
        print("\nSuggested next steps (NOT executed — review first):")
        for s in advisory:
            print(redact(f"  {s}", api_key))
    if partial and not getattr(args, "allow_partial", False):
        sys.exit(EXIT_PARTIAL)


def cmd_mode(args):
    """Delegate-mode flag. Works without credentials (config-file only)."""
    if args.state in ("on", "off"):
        save_config_values({"AMBIENT_DELEGATE": args.state})
        print(f"Ambient delegate mode: {args.state.upper()}")
        return
    conf = read_config_file()
    ns = argparse.Namespace(model=None)
    api_key, backend = resolve_key_and_backend(conf)
    print(f"delegate={(conf.get('AMBIENT_DELEGATE') or 'off').lower()}")
    print(f"chat_model={resolve_model(ns, conf, 'chat')}")
    print(f"code_model={resolve_model(ns, conf, 'code')}")
    print(
        f"key={f'configured ({backend})' if api_key else 'MISSING (run: ambient setup)'}"
    )


SETUP_PREAMBLE = f"""Ambient setup — one-time key configuration
Ambient (ambient.xyz) is a decentralized network of miners serving open-source
models behind one OpenAI-compatible API; you pay per token.

Don't have a key yet?
  1. Sign in or create an account:  {KEY_CONSOLE_URL}
  2. Open: API Keys
  3. Create a key and copy it (it is shown only once).

Paste your key below — input is hidden, and nothing is stored until it verifies."""


def _collect_key_interactive():
    """Prompt for the key with hidden input, local pre-validation, and up to
    3 attempts (a stray Enter or a mangled paste re-prompts instead of
    aborting the whole flow)."""
    import getpass
    import warnings
    # PREFLIGHT echo control BEFORE any key is typed: by the time getpass's
    # GetPassWarning fires, the key was already read WITH ECHO — visible in
    # scrollback (Codex W2/3 HIGH). termios probing types nothing.
    if os.name != "nt":
        try:
            import termios
            termios.tcgetattr(sys.stdin.fileno())
        except (ImportError, OSError, ValueError):
            sys.exit(
                "ambient: this terminal cannot hide typed input — the key "
                "would be visible. Pipe it instead: ambient setup --key-stdin"
            )
    print(SETUP_PREAMBLE)
    for attempt in range(3):
        with warnings.catch_warnings(record=True) as caught:
            warnings.simplefilter("always")
            try:
                key = getpass.getpass("Ambient API key (input hidden): ")
            except (EOFError, KeyboardInterrupt):
                sys.exit("\nambient: cancelled — nothing saved")
        if any(isinstance(w.message, getpass.GetPassWarning) for w in caught):
            # Backstop: getpass STILL fell back to echoing despite the
            # preflight — the pasted value may be visible. Refuse it.
            sys.exit(
                "ambient: this terminal echoed the input — treat that key as "
                f"exposed: rotate it at {KEY_CONSOLE_URL}, then use: "
                "ambient setup --key-stdin"
            )
        key = key.strip()
        if key.lower().startswith("bearer "):
            key = key[7:].strip()
        problem = key_paste_problem(key)
        if problem is None:
            return key
        more = "" if attempt == 2 else "  Try again (Ctrl-C quits)."
        print(f"  {problem}{more}")
    sys.exit("ambient: no valid key after 3 attempts — nothing saved")


def _verify_and_store_key(key, conf, use_file):
    """Verify a key with a real authenticated completion, then store it —
    Keychain/libsecret preferred, 0600 env file otherwise. Returns
    (models, probe_detail, where, funds_issue). Exits with a per-category
    diagnosis + support pointer when the key can't be certified."""
    api_url = resolve_api_url(conf)
    host = urllib.parse.urlsplit(api_url).hostname
    print(f"Verifying key with {host} (one tiny paid completion, <$0.001)…",
          file=sys.stderr)
    try:
        status, body = api_request(api_url, key, "/v1/models", timeout=30)
        if status != 200:
            category, diagnosis = classify_error(status, body, key)
            sys.exit(f"ambient [{category}]: {diagnosis} Nothing was saved.\n"
                     f"{SUPPORT_LINE}")
        models = body.get("data", [])
        # /v1/models is unauthenticated, so really verify the key with a tiny
        # completion (fractions of a cent).
        ok, category, detail = auth_probe(api_url, key, models)
    except NetworkError as err:
        sys.exit(
            f"ambient [network]: cannot reach Ambient ({err}). Check your "
            "internet connection and try again — nothing saved; if other "
            f"sites load fine, Ambient itself may be unreachable.\n{SUPPORT_LINE}"
        )
    funds_issue = False
    if not ok:
        if category == "funds":
            # A 402/insufficient-credits response PROVES the key authenticated
            # (the account was identified). Refusing to save it would force a
            # full re-run after top-up for no security gain — save it, and
            # route the user to the console (onboarding sweep MED).
            funds_issue = True
        elif category == "key":
            sys.exit(
                "ambient [key]: Ambient rejected this key — it may be "
                "mistyped, revoked, or inactive. Re-copy it from "
                f"{KEY_CONSOLE_URL} → API Keys, or create a fresh one. "
                f"Nothing was saved.\n{SUPPORT_LINE}"
            )
        elif category in ("rate", "service"):
            sys.exit(
                f"ambient [{category}]: could not verify the key right now "
                f"({detail}) — an Ambient-side problem, not your key. Nothing "
                f"was saved. Retry in a minute: ambient setup\n{SUPPORT_LINE}"
            )
        else:
            sys.exit(f"ambient [{category}]: key check FAILED: {detail} — "
                     f"nothing saved.\n{SUPPORT_LINE}")
    if not use_file and keychain_available():
        if not keychain_write(key):
            # Fail closed: never silently downgrade to plaintext on a Mac.
            sys.exit(
                "ambient: Keychain write failed — nothing saved. Retry, or store "
                "in the env file explicitly with: ambient setup --force --file"
            )
        # Key lives in the Keychain; scrub any plaintext copy from the file.
        save_config_values({
            "AMBIENT_API_KEY": None,
            "AMBIENT_API_URL": api_url if api_url != DEFAULT_API_URL else None,
            "AMBIENT_KEY_BACKEND": "keychain",
        })
        where = ("macOS Keychain (no plaintext on disk)"
                 if secret_backend() == "keychain"
                 else "OS secret store (no plaintext on disk)")
    else:
        if use_file:
            # Explicit file backend: remove any stale Keychain entry that would
            # otherwise be dead weight (resolution already prefers the file).
            keychain_delete()
        save_config_values({
            "AMBIENT_API_KEY": key,
            "AMBIENT_API_URL": api_url if api_url != DEFAULT_API_URL else None,
            "AMBIENT_KEY_BACKEND": "file",
        })
        where = f"{CONFIG_PATH} (owner-only permissions)"
    return models, detail, where, funds_issue


def _setup_remove():
    """Offboarding: delete the stored key everywhere it may live. Removing the
    key naturally re-arms first-use onboarding (state IS key presence)."""
    kc_ok = keychain_delete()
    save_config_values({"AMBIENT_API_KEY": None, "AMBIENT_KEY_BACKEND": None})
    if not kc_ok:
        sys.exit(
            "ambient: the env file was scrubbed, but the OS secret store "
            "REFUSED the delete (locked keychain?) — the key may still be "
            "stored there. Unlock your keychain and re-run: ambient setup --remove"
        )
    if keychain_read():
        sys.exit(
            "ambient: the key still resolves from the OS secret store after "
            "the delete — remove it manually (Keychain Access → search "
            f"'{KEYCHAIN_SERVICE}') or re-run: ambient setup --remove"
        )
    print("Key removed from the OS secret store and the env file.")
    print("Sticky settings (default models, delegate mode) were kept — delete")
    print(f"{CONFIG_PATH} to reset everything. Reconfigure any time: ambient setup")
    if os.environ.get("AMBIENT_API_KEY"):
        print(
            "note: AMBIENT_API_KEY is still set in this shell's environment "
            "and will keep working until you unset it.",
            file=sys.stderr,
        )


def cmd_setup(args):
    """First-run key onboarding: collect, locally pre-validate, verify with a
    real authenticated completion, store securely, then show the welcome
    panel. --remove offboards; --force rotates."""
    conf = read_config_file()
    if getattr(args, "remove", False):
        _setup_remove()
        return
    existing, backend = resolve_key_and_backend(conf)
    if existing and not args.force:
        where = {
            "keychain": "macOS Keychain",
            "secret-tool": "OS secret store",
            "file": CONFIG_PATH,
            "env": "the AMBIENT_API_KEY environment variable",
        }.get(backend, backend or "unknown")
        sys.exit(
            f"ambient: a key is already configured ({where}).\n"
            "  Rotate/replace: ambient setup --force\n"
            "  Remove:         ambient setup --remove"
        )
    if args.key_stdin:
        key = sys.stdin.readline().strip()
        if key.lower().startswith("bearer "):
            key = key[7:].strip()
        problem = key_paste_problem(key)
        if problem:
            sys.exit(f"ambient: {problem} — nothing saved")
    elif sys.stdin.isatty():
        key = _collect_key_interactive()
    else:
        sys.exit("ambient: no TTY — pipe the key via: ambient setup --key-stdin")
    models, detail, where, funds_issue = _verify_and_store_key(
        key, conf, args.file)
    print()
    print_welcome_panel(models, where, detail, read_config_file(), funds_issue)


def cmd_doctor(args):
    """Step-by-step health check that names the actual culprit. Works with any
    amount of configuration present."""
    conf = read_config_file()
    api_key, backend = resolve_key_and_backend(conf)
    api_url = resolve_api_url(conf)
    print(f"ambient {__version__}  ·  endpoint {api_url}", file=sys.stderr)

    def report(check, ok, detail):
        tag = paint("PASS", "32") if ok else paint("FAIL", "31")
        print(f"{tag:4}  {check:14} {detail}")

    if os.path.exists(CONFIG_PATH):
        mode_bits = os.stat(CONFIG_PATH).st_mode & 0o777
        report("config", mode_bits == 0o600,
               f"{CONFIG_PATH} (perms {oct(mode_bits)[2:]})")
    else:
        report("config", False, f"{CONFIG_PATH} missing — run: ambient setup")
    if api_key:
        hardening = ""
        if backend == "file" and keychain_available():
            hardening = " — harden: `ambient setup --force` moves it into the Keychain"
        report("key", True, f"present ({backend}){hardening}")
    else:
        report("key", False, "MISSING — run: ambient setup")

    try:
        status, body = api_request(api_url, api_key or "none", "/v1/models", timeout=30)
    except NetworkError as err:
        report("network", False, str(err))
        print("\nDIAGNOSIS: cannot reach Ambient at all — check YOUR internet first; "
              "if other sites work, Ambient may be unreachable/down.")
        sys.exit(1)
    if status != 200:
        _, diagnosis = classify_error(status, body, api_key)
        report("service", False, diagnosis)
        print(f"\nDIAGNOSIS: {diagnosis}")
        sys.exit(1)
    models = body.get("data", [])
    ready = ready_model_ids(models)
    report("network", True, f"api reachable; {len(models)} models, {len(ready)} live")

    if not api_key:
        print("\nDIAGNOSIS: no API key configured. Run: ambient setup")
        sys.exit(1)
    try:
        ok, category, detail = auth_probe(api_url, api_key, models)
    except NetworkError as err:
        report("auth", False, str(err))
        print("\nDIAGNOSIS: network dropped mid-check — retry ambient doctor.")
        sys.exit(1)
    report("auth+billing", ok, detail)

    ns = argparse.Namespace(model=None)
    allow_c, hide_c, show_c, _notes_c = curation(conf)
    for kind in ("chat", "code"):
        m = resolve_model(ns, conf, kind)
        known = any(x.get("id") == m for x in models if isinstance(x, dict))
        live = m in ready
        hidden_tag = (" (hidden by curation — still works)"
                      if is_hidden(m, allow_c, hide_c, show_c) else "")
        report(f"{kind}_model", known,
               f"{m} — {'READY' if live else 'no live workers right now' if known else 'NOT IN CATALOG — pick again: ambient use'}{hidden_tag}")
    if allow_c or hide_c:
        cat_ids = [x.get("id") for x in models
                   if isinstance(x, dict) and x.get("id")]
        vis = [i for i in cat_ids
               if not is_hidden(i, allow_c, hide_c, show_c)]
        report("curation", bool(vis) or not cat_ids,
               f"{len(vis)} surfaced / {len(cat_ids) - len(vis)} hidden"
               + ("" if vis or not cat_ids
                  else " — the menu is EMPTY; fix: ambient curate reset"))

    # --- environment checks (informational; never flip the diagnosis) -------
    which_amb = shutil.which("ambient")
    this = _this_script()
    if which_amb and os.path.realpath(which_amb) == this:
        report("launcher", True, "`ambient` is on your PATH -> this install")
    elif which_amb:
        report("launcher", True,
               f"`ambient` on PATH points at {which_amb} (another install) — "
               "refresh with: ambient link")
    else:
        report("launcher", False,
               "`ambient` is not on your PATH — fix: ambient link")
    py_ok = sys.version_info >= (3, 8)
    report("python", py_ok,
           f"{sys.version.split()[0]}"
           + ("" if sys.version_info >= (3, 10)
              else " (<3.10: stream-timeout diagnoses are less precise)"))
    if shutil.which("opencode"):
        agent_detail = "opencode installed"
        agent_ok = True
        try:
            with open(OPENCODE_CONFIG_PATH, encoding="utf-8") as fh:
                oc = json.load(fh)
            if "ambient" in (oc.get("provider") or {}):
                agent_detail += "; ambient provider configured"
            else:
                agent_detail += "; provider auto-configures on first `ambient agent`"
        except FileNotFoundError:
            agent_detail += "; config auto-creates on first `ambient agent`"
        except (OSError, json.JSONDecodeError):
            agent_ok = False
            agent_detail = (f"{OPENCODE_CONFIG_PATH} is invalid JSON — "
                            "`ambient agent` will misbehave; fix or delete it")
        report("agent", agent_ok, agent_detail)
    else:
        report("agent", True,
               "opencode not installed (optional — brew install opencode)")
    try:
        n_cache = len([e for e in os.listdir(CACHE_DIR) if e.endswith(".json")])
        cache_mode = os.stat(CACHE_DIR).st_mode & 0o777
        report("cache", cache_mode == 0o700,
               f"{n_cache} entries at {CACHE_DIR} (perms {oct(cache_mode)[2:]})")
    except OSError:
        report("cache", True, "empty (created on first map-reduce)")

    if ok:
        print("\nDIAGNOSIS: healthy. Key valid, account billable, API reachable."
              + ("" if ready else " (No models have live workers this minute — retry soon.)"))
    else:
        print(f"\nDIAGNOSIS [{category}]: {detail}")
        sys.exit(1)


def cmd_usage(args):
    """Local spend summary (Ambient exposes no balance endpoint)."""
    conf = read_config_file()
    records = []
    bad = 0
    try:
        with open(USAGE_PATH, encoding="utf-8") as fh:
            for line in fh:
                if not line.strip():
                    continue
                try:
                    records.append(json.loads(line))  # skip corrupt lines
                except json.JSONDecodeError:
                    bad += 1
    except FileNotFoundError:
        sys.exit("ambient: no usage recorded yet")
    except OSError as err:
        sys.exit(f"ambient: cannot read {USAGE_PATH}: {err}")
    if bad:
        print(f"ambient: skipped {bad} corrupt usage line(s)", file=sys.stderr)
    cutoff = time.time() - args.days * 86400
    recent = [r for r in records if _as_pos_int(r.get("ts"), 0) >= cutoff]
    if not recent:
        sys.exit(f"ambient: no usage in the last {args.days} days")
    pricing = {}
    try:
        api_url = resolve_api_url(conf)
        for m in fetch_models(api_url, "unused"):
            p = m.get("pricing") or {}
            try:
                pricing[m["id"]] = (float(p.get("input", 0)), float(p.get("output", 0)))
            except (TypeError, ValueError):
                pass
    except (NetworkError, SystemExit):
        pass  # offline: token counts still print, cost column shows n/a
    totals = {}
    for r in recent:
        model = str(r.get("model", "?"))
        t = totals.setdefault(model, {"calls": 0, "in": 0, "out": 0})
        t["calls"] += 1
        # Corrupt-but-parseable records must be skipped like unparseable ones,
        # not TypeError into [internal] (Codex final LOW).
        t["in"] += _as_pos_int(r.get("in"), 0)
        t["out"] += _as_pos_int(r.get("out"), 0)
    grand = 0.0
    priced_all = True
    rows = []
    for model, t in sorted(totals.items()):
        if model in pricing:
            cost = (t["in"] * pricing[model][0] + t["out"] * pricing[model][1]) / 1e6
            grand += cost
            rows.append({**t, "model": model, "est_cost": round(cost, 4)})
        else:
            priced_all = False
            rows.append({**t, "model": model, "est_cost": None})
    if getattr(args, "json", False):
        print(json.dumps({
            "days": args.days,
            "models": rows,
            "total_est_cost": round(grand, 4),
            "all_priced": priced_all,
        }, indent=2))
        return
    print(f"Ambient usage, last {args.days} days:")
    for r in rows:
        cost_s = f"${r['est_cost']:.4f}" if r["est_cost"] is not None else "n/a"
        print(
            f"  {r['model']:42} {r['calls']:4} calls  in={r['in']:>9,}  "
            f"out={r['out']:>9,}  est {cost_s}"
        )
    print(f"Total estimated: ${grand:.4f}" + ("" if priced_all else " (+ unpriced models)"))


def _this_script():
    """Absolute real path of the running CLI (symlink-resolved)."""
    return os.path.realpath(os.path.abspath(sys.argv[0] or __file__))


def cmd_link(args):
    """Put a stable `ambient` launcher on PATH. Marketplace installs live in a
    VERSIONED cache dir that changes on every update — a symlink in
    ~/.local/bin survives updates (distribution sweep HIGH: no stable path for
    `ambient setup`, which needs the user's own terminal)."""
    target = _this_script()
    dest_dir = os.path.expanduser(getattr(args, "dir", None) or "~/.local/bin")
    dest = os.path.join(dest_dir, "ambient")
    if getattr(args, "remove", False):
        if os.path.islink(dest):
            points_at = os.path.realpath(dest)
            if os.path.basename(points_at) == "ambient":
                os.unlink(dest)
                print(f"removed: {dest}")
            else:
                sys.exit(f"ambient: {dest} points at {points_at} — not an "
                         "ambient launcher, refusing to delete it")
        elif os.path.exists(dest):
            sys.exit(f"ambient: {dest} is not a symlink — refusing to delete "
                     "a foreign file")
        else:
            print(f"nothing to remove at {dest}")
        return
    if os.path.exists(dest) and not os.path.islink(dest):
        sys.exit(
            f"ambient: {dest} exists and is not a symlink — refusing to "
            "overwrite it. Pass --dir DIR to link somewhere else."
        )
    try:
        os.makedirs(dest_dir, exist_ok=True)
        if os.name == "nt":  # symlinks need privileges on Windows — shim it
            shim = os.path.join(dest_dir, "ambient.cmd")
            with open(shim, "w", encoding="utf-8") as fh:
                fh.write(f'@python "{target}" %*\r\n')
            print(f"wrote launcher: {shim}")
            return
        tmp = dest + f".tmp-{os.getpid()}"
        os.symlink(target, tmp)
        os.replace(tmp, dest)
    except OSError as err:
        sys.exit(f"ambient: could not create the link ({err})")
    print(f"linked: {dest} -> {target}")
    if dest_dir not in os.environ.get("PATH", "").split(os.pathsep):
        print(
            f"note: {dest_dir} is not on your PATH yet — add this to your "
            f'shell profile:\n  export PATH="{dest_dir}:$PATH"'
        )


def cmd_cache(args):
    """Local data lifecycle: inspect or purge the chunk cache (entries hold
    model output that quotes your code; TTL 7 days, 0600)."""
    try:
        entries = [e for e in os.listdir(CACHE_DIR) if e.endswith(".json")]
    except OSError:
        entries = []
    if args.action == "clear":
        cutoff = (time.time() - args.older_than * 86400
                  if getattr(args, "older_than", None) else None)
        removed = 0
        for e in entries:
            p = os.path.join(CACHE_DIR, e)
            try:
                if cutoff is not None and os.stat(p).st_mtime > cutoff:
                    continue
                os.unlink(p)
                removed += 1
            except OSError:
                pass
        print(f"cache: removed {removed} of {len(entries)} entries "
              f"({CACHE_DIR})")
        return
    total = 0
    for e in entries:
        try:
            total += os.stat(os.path.join(CACHE_DIR, e)).st_size
        except OSError:
            pass
    print(f"cache: {len(entries)} entries, {total:,} bytes at {CACHE_DIR}")
    print("clear with: ambient cache clear [--older-than DAYS]")


OPENCODE_CONFIG_PATH = os.path.expanduser("~/.config/opencode/opencode.json")


def ensure_opencode_config(api_url, model):
    """Fresh-install fix: create/repair the opencode provider config so
    `ambient agent` works out of the box instead of failing on a missing file.
    Never overwrites an existing 'ambient' provider the user may have tuned."""
    cfg = {}
    try:
        with open(OPENCODE_CONFIG_PATH, encoding="utf-8") as fh:
            cfg = json.load(fh)
    except FileNotFoundError:
        pass
    except (OSError, json.JSONDecodeError):
        # Leave a hand-edited/broken config alone — but SAY so, or the user
        # meets an inexplicable opencode failure (doctor also flags this).
        print(
            f"ambient: {OPENCODE_CONFIG_PATH} could not be parsed — leaving it "
            "alone; `ambient agent` may misbehave (see: ambient doctor)",
            file=sys.stderr,
        )
        return
    providers = cfg.setdefault("provider", {})
    if "ambient" in providers:
        # Non-destructively union the CURRENT model into the provider's model
        # map (agentic sweep: the map was written once at install, so after
        # `ambient use <new>` the agent passed a model id opencode didn't
        # know). User-tuned options stay untouched.
        amb = providers["ambient"]
        if not isinstance(amb, dict):
            return
        models_map = amb.setdefault("models", {})
        if isinstance(models_map, dict) and model not in models_map:
            models_map[model] = {"name": model}
        else:
            return  # nothing to add — don't rewrite the file
    else:
        cfg.setdefault("$schema", "https://opencode.ai/config.json")
        providers["ambient"] = {
            "npm": "@ai-sdk/openai-compatible",
            "name": "Ambient (ambient.xyz)",
            "options": {"baseURL": f"{api_url}/v1",
                        "apiKey": "{env:AMBIENT_API_KEY}"},
            "models": {model: {"name": model}},
        }
    try:
        # Atomic write so a mid-write failure can't destroy the user's existing
        # opencode config with its custom providers (Ambient self-audit #2).
        conf_dir = os.path.dirname(OPENCODE_CONFIG_PATH)
        os.makedirs(conf_dir, exist_ok=True)
        tmp = OPENCODE_CONFIG_PATH + ".tmp"
        with open(tmp, "w", encoding="utf-8") as fh:
            json.dump(cfg, fh, indent=2)
            fh.flush()
            os.fsync(fh.fileno())
        os.replace(tmp, OPENCODE_CONFIG_PATH)
        print(
            f"ambient: wrote opencode provider config → {OPENCODE_CONFIG_PATH}",
            file=sys.stderr,
        )
    except OSError as err:
        print(f"ambient: could not write opencode config ({err})", file=sys.stderr)


def cmd_agent(args, api_key, api_url, conf):
    if not shutil.which("opencode"):
        sys.exit(
            "ambient: opencode not found on PATH. Install it with:\n"
            "  brew install opencode      (or see https://opencode.ai)"
        )
    model = resolve_model(args, conf, "code")
    if getattr(args, "model", None):
        note_if_hidden(args.model, conf)
    ensure_opencode_config(api_url, model)
    print(
        "ambient: the agent reads files itself — the secrets tripwire does "
        "NOT cover this lane; keep .env/credentials out of its working tree.",
        file=sys.stderr,
    )
    # The key is passed to opencode via its process environment — the standard
    # credential model used by aws/gh/docker/codex (env_key). It is NOT hidden
    # from opencode; do not ask an agent to print its environment.
    env = dict(os.environ, AMBIENT_API_KEY=api_key)
    extra = list(args.agent_args)
    if extra and extra[0] == "run":
        argv = ["opencode", "run", "--model", f"ambient/{model}"] + extra[1:]
    else:
        argv = ["opencode", "--model", f"ambient/{model}"] + extra
    try:
        os.execvpe("opencode", argv, env)
    except FileNotFoundError:
        sys.exit("ambient: opencode not found on PATH (brew install opencode)")


def cmd_codex(args, api_key, api_url, conf):
    sys.exit(
        "ambient: Codex CLI cannot talk to Ambient yet — Codex >=0.142 only speaks "
        "the OpenAI Responses API, and Ambient's /v1/responses gateway rejects "
        "Codex's 'namespace' tool type and typed message content (verified "
        "2026-07-02). The provider config is already in place in ~/.codex; once "
        "Ambient's validator accepts/ignores unknown tool types this will work.\n"
        "Use the working agentic terminal instead:  ambient agent"
    )


class _Parser(argparse.ArgumentParser):
    """Usage errors exit 64 (EX_USAGE), not argparse's default 2 — exit 2 is
    reserved for PARTIAL results, and agentic callers must be able to tell
    "my flags were wrong" from "coverage was incomplete". Mistyped subcommands
    get a did-you-mean."""

    def error(self, message):
        extra = ""
        m = re.search(r"invalid choice: '([^']+)'", message)
        if m:
            cand = re.search(r"choose from (.+)\)", message)
            choices = ([c.strip().strip("'") for c in cand.group(1).split(",")]
                       if cand else [])
            close = difflib.get_close_matches(m.group(1), choices, n=1, cutoff=0.5)
            if close:
                extra = f"\ndid you mean: {close[0]}?"
        if _json_in_argv():
            # The --json failure contract is TOTAL: even argparse's own
            # rejections reach a machine caller as the envelope (exit 64),
            # never prose. --help and successful parses are untouched.
            emit_json_error(_argv_command(), "usage", f"{message}{extra}",
                            exit_code=EXIT_USAGE)
        self.print_usage(sys.stderr)
        self.exit(EXIT_USAGE,
                  f"{self.prog}: error: {message}{extra}\ntry: {self.prog} -h\n")


def add_common_flags(parser):
    parser.add_argument(
        "-m", "--model", default=None, metavar="ID",
        help="model id for this run only (see: ambient models); overrides the "
             "sticky default")
    parser.add_argument(
        "--max-tokens", type=int, default=None,
        help="output token budget (default: auto-sized per model; reasoning "
             "models get more so thinking AND the answer both fit)")
    parser.add_argument("--temperature", type=float, default=0.1,
                        help="sampling temperature 0.0-2.0 (default 0.1)")
    parser.add_argument(
        "--timeout", type=int, default=DEFAULT_TIMEOUT_S,
        help="per-call SILENCE timeout in seconds — data flow resets it; not "
             "a total cap (default 300)")
    parser.add_argument("--raw", action="store_true", help="print full JSON response")
    parser.add_argument(
        "--fallback", action="store_true",
        help="auto-retry on the first READY model if the chosen one has no workers "
             "(or set AMBIENT_FALLBACK=on)",
    )
    parser.add_argument(
        "--allow-partial", action="store_true",
        help="accept an incomplete result (some chunks failed/truncated) with exit 0 "
             "instead of the default loud non-zero exit",
    )
    parser.add_argument(
        "--allow-cost", action="store_true",
        help="proceed even if the estimated spend exceeds AMBIENT_MAX_SPEND (default $5)",
    )
    parser.add_argument(
        "--yes", "-y", action="store_true",
        help="skip the interactive cost confirmation on large jobs",
    )
    parser.add_argument(
        "--no-cache", action="store_true",
        help="don't reuse cached chunk results from a previous run (map-reduce)",
    )
    parser.add_argument(
        "--cache-ttl", type=int, default=None, metavar="SECONDS",
        help="max age of a reusable cached chunk (default 7 days)",
    )
    parser.add_argument(
        "--parallel", type=int, default=None, metavar="N",
        help="max concurrent chunk/model calls, 1-16 (default "
             f"{MAX_PARALLEL_CHUNKS}; or set AMBIENT_MAX_PARALLEL)",
    )


def main():
    parser = _Parser(
        prog="ambient", description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument("--version", "-V", action="version",
                        version=f"ambient {__version__}")
    sub = parser.add_subparsers(dest="command", required=False,
                                metavar="<command>", parser_class=_Parser)

    sub.add_parser("version", help="print version")
    p_models = sub.add_parser("models", help="list models")
    p_models.add_argument("--json", action="store_true", help="machine-readable list")
    p_models.add_argument("--all", action="store_true",
                          help="include models hidden by your curation")

    p_curate = sub.add_parser(
        "curate", help="pick which models the menus surface (hide/show/only/note)"
    )
    p_curate.add_argument(
        "verb", nargs="?",
        choices=["status", "hide", "show", "only", "note", "reset"],
        default="status", help="what to do (default: show current curation)")
    p_curate.add_argument("ids", nargs="*",
                          help="model ids or globs (e.g. qwen/*); for `note`: "
                               "<id> then the note text")

    p_setup = sub.add_parser("setup", help="first-run: store + verify API key")
    p_setup.add_argument("--key-stdin", action="store_true", help="read key from stdin")
    p_setup.add_argument("--force", action="store_true", help="replace existing key")
    p_setup.add_argument(
        "--file", action="store_true",
        help="store in the env file instead of the macOS Keychain",
    )
    p_setup.add_argument(
        "--remove", action="store_true",
        help="delete the stored key (Keychain + env file) — clean offboarding",
    )

    p_link = sub.add_parser(
        "link", help="put a stable `ambient` launcher on your PATH (~/.local/bin)"
    )
    p_link.add_argument("--dir", default=None, metavar="DIR",
                        help="link directory (default ~/.local/bin)")
    p_link.add_argument("--remove", action="store_true",
                        help="remove the launcher symlink")

    p_cache = sub.add_parser(
        "cache", help="inspect or clear the local chunk cache"
    )
    p_cache.add_argument("action", nargs="?", choices=["status", "clear"],
                         default="status", help="status (default) or clear")
    p_cache.add_argument("--older-than", type=int, default=None, metavar="DAYS",
                         help="clear only entries older than DAYS")

    p_trust = sub.add_parser(
        "trust-url",
        help="explicitly trust a non-Ambient API endpoint (self-hosted gateway)",
    )
    p_trust.add_argument("url", nargs="?", help="https:// endpoint to trust")
    p_trust.add_argument("--reset", action="store_true",
                         help="clear the trusted endpoint (back to api.ambient.xyz)")

    p_usage = sub.add_parser("usage", help="local token/cost summary")
    p_usage.add_argument("--days", type=int, default=30,
                         help="look-back window in days (default 30)")
    p_usage.add_argument("--json", action="store_true", help="machine-readable summary")

    p_mode = sub.add_parser("mode", help="delegate mode: on / off / status")
    p_mode.add_argument("state", nargs="?", choices=["on", "off"], default=None,
                        help="on/off; omit to print current status")

    sub.add_parser("doctor", help="diagnose key/funds/model/network/service issues")

    p_use = sub.add_parser("use", help="pick the sticky default model")
    p_use.add_argument("model_id", nargs="?", help="model id (omit for interactive menu)")
    p_use.add_argument("--chat", action="store_true", help="only set the chat/audit default")
    p_use.add_argument("--code", action="store_true", help="only set the code/agent default")
    p_use.add_argument("--all", action="store_true",
                       help="pick from every model, including curated-out ones")

    p_ask = sub.add_parser(
        "ask", help="one-shot completion",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""examples:
  ambient ask "explain CRDTs in two paragraphs"
  cat design.md | ambient ask "list the open questions" -
  ambient ask "summarize" --json           (stable machine envelope)""")
    p_ask.add_argument(
        "prompt", nargs="*",
        help="the question; add '-' to ALSO read stdin "
             "(cat doc.txt | ambient ask \"summarize\" -)")
    p_ask.add_argument("-s", "--system", help="system prompt")
    p_ask.add_argument(
        "--allow-secrets", action="store_true",
        help="bypass the credentials tripwire (false positives only)",
    )
    p_ask.add_argument(
        "--json", action="store_true",
        help="emit a stable JSON envelope instead of prose",
    )
    add_common_flags(p_ask)

    p_audit = sub.add_parser(
        "audit", help="second-opinion code audit",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""examples:
  git diff | ambient audit
  ambient audit src/pay.py --focus security --format report
  ambient audit --staged --json
  ambient audit src/*.py --dry-run       (plan + cost, nothing sent)
  ambient audit app.py --consensus moonshotai/kimi-k2.7-code,z-ai/glm-5.2""")
    p_audit.add_argument("paths", nargs="*",
                         help="files to audit (or pipe a diff on stdin)")
    p_audit.add_argument("--focus", help="e.g. 'security', 'concurrency'")
    p_audit.add_argument(
        "--allow-secrets", action="store_true",
        help="bypass the credentials tripwire (false positives only)",
    )
    p_audit.add_argument(
        "--format", choices=["prose", "json", "report"], default="prose",
        help="prose (default) | json (machine-readable findings) | report "
             "(clean findings table)",
    )
    p_audit.add_argument(
        "--json", dest="format", action="store_const", const="json",
        help="shorthand for --format json",
    )
    p_audit.add_argument(
        "--dry-run", action="store_true",
        help="show the plan (model, budget, chunks, cost ceiling) and exit — no call",
    )
    p_audit.add_argument(
        "--staged", action="store_true",
        help="audit `git diff --cached` WITH full context of each changed file",
    )
    p_audit.add_argument(
        "--diff", metavar="REF", nargs="?", const="HEAD",
        help="audit `git diff REF` (default HEAD) with full changed-file context",
    )
    p_audit.add_argument(
        "--consensus", metavar="M1,M2",
        help="audit with several models and rank findings corroborated by 2+ "
             "first (usually only 2 models are READY at once)",
    )
    add_common_flags(p_audit)

    p_map = sub.add_parser(
        "map",
        help="bulk lane: run ONE prompt independently over MANY items "
             "(files or stdin lines), streaming one result per item",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""examples:
  ambient map "summarize this file in one sentence" src/*.py
  cat titles.txt | ambient map "classify: bug, feature, or question?"
  cat q.jsonl | ambient map "answer concisely" --jsonl --json
Each item is ONE single-shot call (the prompt is the system instruction,
the item is the user message). Output streams per item as it completes —
under --json as JSONL (one envelope per line, always carrying the item id).
One batch cost gate up front; re-runs serve finished items from the cache
and re-bill only the missing ones.""")
    p_map.add_argument(
        "prompt",
        help="the instruction applied INDEPENDENTLY to each item")
    p_map.add_argument(
        "paths", nargs="*",
        help="files — each file is ONE item (glob via your shell); omit to "
             "read one item per stdin line")
    p_map.add_argument(
        "--jsonl", action="store_true",
        help='stdin lines are JSON objects: {"input": "...", "id": ...} '
             "(id optional; falls back to the line's item index)")
    p_map.add_argument(
        "--json", action="store_true",
        help="emit one JSON envelope per item (JSONL) instead of prose")
    p_map.add_argument(
        "--allow-secrets", action="store_true",
        help="bypass the credentials tripwire (false positives only)",
    )
    add_common_flags(p_map)

    p_code = sub.add_parser("code", help="code generation")
    p_code.add_argument("task", nargs="*", help="what to build, in plain words")
    p_code.add_argument("-f", "--context", action="append", metavar="FILE",
                        help="context file the generation should match (repeatable)")
    p_code.add_argument(
        "--allow-secrets", action="store_true",
        help="bypass the credentials tripwire (false positives only)",
    )
    p_code.add_argument(
        "--json", action="store_true",
        help="emit a stable JSON envelope instead of prose",
    )
    add_common_flags(p_code)

    p_build = sub.add_parser(
        "build",
        help="plan + generate a set of files from a task (manifest-first; "
             "never executes anything)",
    )
    p_build.add_argument("task", nargs="*", help="what to build, in plain words")
    p_build.add_argument(
        "--dir", default=None, metavar="DIR",
        help="target directory (default: current dir; REQUIRED for headless --apply)")
    p_build.add_argument("-f", "--context", action="append", metavar="FILE",
                         help="context file the build should match (repeatable)")
    p_build.add_argument(
        "--apply", action="store_true",
        help="write the generated files into --dir (default: manifest only)")
    p_build.add_argument(
        "--force", action="store_true",
        help="overwrite existing files (originals saved to .ambient-build.bak/)")
    p_build.add_argument(
        "--plan-only", action="store_true",
        help="run just the cheap planning call, print the plan, stop")
    p_build.add_argument(
        "--dry-run", action="store_true",
        help="show model/budget/caps/cost with NO API calls")
    p_build.add_argument("--max-files", type=int, default=32,
                         help="cap on planned files (default 32)")
    p_build.add_argument("--max-file-bytes", type=int, default=200_000,
                         help="cap on one generated file (default 200,000)")
    p_build.add_argument(
        "--no-resume", action="store_true",
        help="ignore a previous interrupted run's cached plan/files")
    p_build.add_argument("--json", action="store_true",
                         help="emit the machine-readable manifest envelope")
    p_build.add_argument(
        "--allow-secrets", action="store_true",
        help="bypass the credentials tripwire (false positives only)")
    add_common_flags(p_build)

    p_agent = sub.add_parser(
        "agent",
        help="interactive agentic terminal on Ambient (opencode TUI). For "
             "headless builds Claude can review, use: ambient build",
    )
    p_agent.add_argument("-m", "--model", default=None,
                         help="model id for this session only")
    p_agent.add_argument("agent_args", nargs=argparse.REMAINDER,
                         help="passed straight to opencode; first arg 'run' = "
                              "headless one-task mode")

    p_codex = sub.add_parser("codex", help="blocked upstream; see `ambient agent`")
    p_codex.add_argument("codex_args", nargs=argparse.REMAINDER)

    # Never accept a key as a command-line argument: argv lands in shell
    # history and process listings (security sweep). Refuse BEFORE argparse
    # can echo the token back in an 'unrecognized arguments' error.
    if len(sys.argv) > 2 and sys.argv[1] == "setup":
        for tok in sys.argv[2:]:
            if tok.startswith("-"):
                continue
            if (len(tok) >= 20 and re.fullmatch(r"[A-Za-z0-9_.\-]{20,}", tok)) \
                    or any(p.search(tok) for p in SECRET_PATTERNS):
                sys.exit(
                    "ambient: it looks like you passed your API key on the "
                    "command line — it is now in your shell history. Run "
                    "`ambient setup` (interactive, hidden input) instead, and "
                    f"ROTATE that key at {KEY_CONSOLE_URL}."
                )
    args = parser.parse_args()
    if args.command == "version":
        print(f"ambient {__version__}")
        return
    if args.command is None:  # bare `ambient` → onboarding banner, not an error
        print(build_banner())
        return
    if "~" in CONFIG_PATH:
        _fail_exit(
            args, _argv_command(), "config",
            "cannot resolve your home directory (HOME unset). "
            "Set HOME and retry."
        )
    # Foolproofing: clamp nonsensical numeric args instead of letting them run.
    if getattr(args, "max_tokens", None) is not None:
        if args.max_tokens < MIN_OUTPUT_TOKENS:
            print(
                f"ambient: --max-tokens {args.max_tokens} is too low for a reasoning "
                f"model (it needs room to think AND answer) — raising to "
                f"{MIN_OUTPUT_TOKENS}",
                file=sys.stderr,
            )
            args.max_tokens = MIN_OUTPUT_TOKENS
        elif args.max_tokens > 200_000:
            print("ambient: --max-tokens capped at 200000", file=sys.stderr)
            args.max_tokens = 200_000
    if getattr(args, "temperature", None) is not None:
        t = args.temperature
        if t != t or not (0.0 <= t <= 2.0):  # NaN or out of range
            fixed = 0.1 if t != t else max(0.0, min(2.0, t))
            print(
                f"ambient: --temperature {t} is invalid — using {fixed}",
                file=sys.stderr,
            )
            args.temperature = fixed
    if getattr(args, "timeout", None) is not None and args.timeout <= 0:
        print(
            f"ambient: --timeout must be positive — using {DEFAULT_TIMEOUT_S}s",
            file=sys.stderr,
        )
        args.timeout = DEFAULT_TIMEOUT_S
    # These work before any credentials exist:
    if args.command == "codex":
        cmd_codex(args, None, None, None)
        return
    if args.command == "mode":
        cmd_mode(args)
        return
    if args.command == "setup":
        cmd_setup(args)
        return
    if args.command == "doctor":
        cmd_doctor(args)
        return
    if args.command == "usage":
        cmd_usage(args)
        return
    if args.command == "link":
        cmd_link(args)
        return
    if args.command == "cache":
        cmd_cache(args)
        return
    if args.command == "curate":
        cmd_curate(args)
        return
    if args.command == "trust-url":
        if args.reset:
            cmd_trust_url_reset()
        elif args.url:
            cmd_trust_url(args)
        else:
            usage_exit("trust-url needs a URL (or --reset)")
        return
    if args.command == "models":
        # The catalog endpoint is unauthenticated — let a curious stranger see
        # the live network BEFORE creating an account (pre-signup funnel).
        conf = read_config_file()
        key, _ = resolve_key_and_backend(conf)
        try:
            cmd_models(args, key or "none", resolve_api_url(conf), conf)
        except NetworkError as err:
            sys.exit(f"ambient [network]: {err}")
        return
    api_key, api_url, conf = load_config()
    handlers = {
        "use": cmd_use,
        "ask": cmd_ask,
        "audit": cmd_audit,
        "map": cmd_map,
        "code": cmd_code,
        "build": cmd_build,
        "agent": cmd_agent,
    }
    try:
        handlers[args.command](args, api_key, api_url, conf)
    except ChatError as err:
        # A map-reduce that exhausts its retries raises ChatError up here — show
        # it as the clean classified diagnosis, not a generic internal error.
        # A --json caller gets the machine-readable error envelope instead.
        if _json_mode(args):
            emit_json_error(args.command, err.category, err.diagnosis, api_key)
        sys.exit(f"ambient [{err.category}]: {err.diagnosis}")
    except NetworkError as err:
        if _json_mode(args):
            emit_json_error(args.command, "network", str(err), api_key)
        sys.exit(
            f"ambient [network]: {err}. Check your internet connection; if other "
            "sites work, Ambient may be unreachable — run: ambient doctor"
        )


def shielded_main():
    """No raw traceback ever reaches the user: every unexpected failure becomes
    a clean, redacted, one-line diagnosis. AMBIENT_DEBUG=1 restores tracebacks."""
    try:
        main()
    except (KeyboardInterrupt, EOFError):
        sys.stderr.write("\nambient: cancelled\n")
        sys.exit(130)
    except SystemExit:
        raise
    except NetworkError as err:
        msg = (f"{err}. Check your internet connection; if other "
               "sites work, Ambient may be unreachable — run: ambient doctor")
        _fail_exit(None, _argv_command(), "network", msg,
                   prose=f"ambient [network]: {msg}")
    except Exception as err:  # noqa: BLE001 — the whole point is a clean floor
        if os.environ.get("AMBIENT_DEBUG") == "1":
            raise
        # Resolve the REAL key (env > Keychain > file) so redaction works even
        # when the key is in the macOS Keychain and absent from the env file
        # (Ambient self-audit #2: a conf-only lookup redacted with "" = no-op).
        key = ""
        try:
            key = resolve_key_and_backend(read_config_file())[0] or ""
        except Exception:  # noqa: BLE001
            pass
        detail = redact(f"{type(err).__name__}: {err}", key)[:300]
        msg = (f"unexpected error ({detail}). Nothing was harmed. "
               "Run 'ambient doctor' to check the basics; set AMBIENT_DEBUG=1 to see "
               "full details.")
        # Even the last-resort floor honors the --json contract (redacted).
        _fail_exit(None, _argv_command(), "internal", msg, api_key=key,
                   prose=f"ambient [internal]: {msg}")


if __name__ == "__main__":
    shielded_main()
